---
import "../styles/global.css";
import SeoHead from "../components/SeoHead.astro";
import { shironeIconMap } from "../lib/shironeIconMap";

const pageTitle = "鑑定結果 | 白音七";
const pageDescription = "白音七の鑑定結果ページ";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead title={pageTitle} description={pageDescription} noindex />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/history">履歴一覧</a>
          <a href="/privacy">プライバシーポリシー</a>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main class="fortune-result">
      <section class="fortune-container">
        <div class="fortune-result-frame">
          <div id="resultHeadArea"></div>
          <div id="resultBodyArea"></div>

          <div class="fortune-result-cta">
            <h2>この流れ、残しておきませんか？</h2>

            <p>
              今日の結果を一度きりで終わらせず、<br />
              あなた自身の変化として積み重ねていくことができます。
            </p>

            <p id="saveMessage" class="fortune-result-message"></p>

            <div id="resultActions" class="fortune-result-actions">
              <a href="/diagnosis" class="fortune-btn primary">
                もう一度占う
              </a>

              <button id="saveBtn" class="fortune-btn secondary" type="button">
                この結果を記録する
              </button>
            </div>
          </div>

          <div class="fortune-premium-box">
            <div class="fortune-premium-inner">
              <h2 class="fortune-premium-title">
                もっと深く読み解く鑑定は、現在準備中です。
              </h2>

              <p class="fortune-premium-lead">
                今日の占いを大切にしながら、<br />
                さらに深い読み解きの扉も少しずつ整えています。
              </p>

              <div class="fortune-premium-content">
                <div class="fortune-premium-item">
                  <h3 class="fortune-premium-heading">
                    <img
                      class="fortune-premium-icon"
                      src={shironeIconMap.lpBadge}
                      alt="数秘術のイラスト"
                      loading="lazy"
                      decoding="async"
                    />
                    <span>数秘術（本質）</span>
                  </h3>
                  <p>ピタゴラス式チャートで、生まれ持つ資質と人生の役割を解析</p>
                </div>

                <div class="fortune-premium-item">
                  <h3 class="fortune-premium-heading">
                    <img
                      class="fortune-premium-icon"
                      src={shironeIconMap.zodiac}
                      alt="占星術のイラスト"
                      loading="lazy"
                      decoding="async"
                    />
                    <span>占星術（流れ）</span>
                  </h3>
                  <p>運気の波とタイミングを読み取り、最適な行動時期を導く</p>
                </div>

                <div class="fortune-premium-item">
                  <h3 class="fortune-premium-heading">
                    <img
                      class="fortune-premium-icon"
                      src={shironeIconMap.nameNumber}
                      alt="姓名判断・手相のイラスト"
                      loading="lazy"
                      decoding="async"
                    />
                    <span>姓名判断・手相</span>
                  </h3>
                  <p>あなたの現在地と変化の兆しを多角的に分析</p>
                </div>

                <div class="fortune-premium-item">
                  <h3 class="fortune-premium-heading">
                    <img
                      class="fortune-premium-icon"
                      src={shironeIconMap.thinkingWave}
                      alt="バイオリズムのイラスト"
                      loading="lazy"
                      decoding="async"
                    />
                    <span>バイオリズム</span>
                  </h3>
                  <p>日々の流れを可視化し、運気の上げ方を具体化</p>
                </div>
              </div>

              <div class="fortune-premium-cta">
                <button id="premiumBtn" class="fortune-btn gold big" type="button">
                  ✧ 深い鑑定の扉
                </button>
                <p class="fortune-premium-note">
                  ※今後、会員向けの深掘り鑑定として整えていきます
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script>
      // @ts-nocheck
      import { buildDailyFortune } from "../lib/fortuneEngine";
      import { runShironeEngine } from "../lib/shironeEngine";
      import { shironeIconMap } from "../lib/shironeIconMap";
      import {
        getShironePhaseDetail,
        getShironeTypeByBirthDate,
        getShironeTypeDisplayName,
      } from "../lib/shironeTypes";

      const authArea = document.getElementById("authArea");
      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      if (authArea) {
        if (token && email) {
          authArea.innerHTML = `
            <span class="fortune-user">${email}</span>
            <button id="logoutBtn" class="fortune-nav-logout" type="button">ログアウト</button>
          `;

          document.getElementById("logoutBtn")?.addEventListener("click", () => {
            localStorage.removeItem("token");
            localStorage.removeItem("loginEmail");
            window.location.href = "/";
          });
        } else {
          authArea.innerHTML = `
            <a href="/login" class="fortune-nav-pill">会員ログイン</a>
          `;
        }
      }

      const input = JSON.parse(localStorage.getItem("fortuneInput") || "null");
      const resultHeadArea = document.getElementById("resultHeadArea");
      const resultBodyArea = document.getElementById("resultBodyArea");
      const saveBtn = document.getElementById("saveBtn");
      const saveMessage = document.getElementById("saveMessage");
      const resultActions = document.getElementById("resultActions");
      const premiumBtn = document.getElementById("premiumBtn");
      const HISTORY_SAVE_API =
        "https://mydmaywesh.execute-api.ap-northeast-1.amazonaws.com/prod/history";

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function toHtmlLines(value) {
        return escapeHtml(value).replaceAll("\n", "<br />");
      }

      const iconHintTones = new Set(["gold", "purple", "blue", "green", "gray"]);
      const typeIconImages = {
        moonlight: "/images/types-icons/moon-lantern.png",
        stargazer: "/images/types-icons/sky-compass.png",
        "water-mirror": "/images/types-icons/water-mirror.png",
        "flower-keeper": "/images/types-icons/sakura-emblem.png",
        windpath: "/images/types-icons/wind-feather.png",
        "fire-knot": "/images/types-icons/fire-knot.png",
        shirone: "/images/types-icons/magic-circle.png",
        sumine: "/images/types-icons/crystal-geometry.png",
        futane: "/images/types-icons/twin-moons.png",
        amane: "/images/types-icons/holy-light.png"
      };
      const biorhythmLabels = {
        physical: "体",
        emotional: "心",
        intellectual: "思考"
      };
      const biorhythmLevelLabels = {
        low: "静める",
        middle: "整える",
        high: "満ちる"
      };
      const biorhythmLevelValues = {
        low: 1,
        middle: 2,
        high: 3
      };
      const biorhythmWaveSeries = [
        { key: "physical", label: "身体", period: 23, className: "physical" },
        { key: "emotional", label: "感情", period: 28, className: "emotional" },
        { key: "intellectual", label: "思考", period: 33, className: "intellectual" }
      ];
      const biorhythmWaveRange = 15;
      const biorhythmSvgWidth = 600;
      const biorhythmSvgHeight = 220;
      const biorhythmSvgPaddingX = 32;
      const biorhythmSvgMidY = 108;
      const biorhythmSvgAmplitude = 68;

      function normalizeIconHintTone(tone) {
        const value = String(tone || "gray");
        return iconHintTones.has(value) ? value : "gray";
      }

      function normalizeIconHint(hint) {
        if (!hint || typeof hint !== "object") return null;

        const icon = String(hint.icon || "").trim();
        const label = String(hint.label || "").trim();
        const value = String(hint.value || "").trim();

        if (!icon && !label && !value) return null;

        return {
          icon: icon || "・",
          label: label || "手がかり",
          value,
          tone: normalizeIconHintTone(hint.tone)
        };
      }

      function extractIconHints(source) {
        if (!source || typeof source !== "object") return [];

        const candidates = [
          source.iconHints,
          source.icon_hints,
          source.result?.iconHints,
          source.result?.icon_hints,
          source.historyPayloadV2?.result?.iconHints,
          source.history_payload_v2?.result?.iconHints,
          source.result?.historyPayloadV2?.result?.iconHints,
          source.result?.history_payload_v2?.result?.iconHints
        ];

        const rawHints = candidates.find((candidate) => Array.isArray(candidate));
        if (!rawHints) return [];

        return rawHints.map(normalizeIconHint).filter(Boolean);
      }

      function renderIconHints(source) {
        const iconHints = Array.isArray(source)
          ? source.map(normalizeIconHint).filter(Boolean)
          : extractIconHints(source);

        if (!iconHints.length) return "";

        return `
          <section class="fortune-icon-hints-section" aria-label="今日の小さな手がかり">
            <h2 class="fortune-icon-hints-title">今日の小さな手がかり</h2>
            <div class="fortune-icon-hints-grid">
              ${iconHints
                .map(
                  (hint) => `
                    <article class="fortune-icon-hint-card tone-${hint.tone}">
                      <div class="fortune-icon-hint-symbol">${escapeHtml(hint.icon)}</div>
                      <div class="fortune-icon-hint-text">
                        <div class="fortune-icon-hint-label">${escapeHtml(hint.label)}</div>
                        <div class="fortune-icon-hint-value">${escapeHtml(hint.value)}</div>
                      </div>
                    </article>
                  `
                )
                .join("")}
            </div>
          </section>
        `;
      }

      function renderShironeTypeCard(birthDate) {
        const shironeType = getShironeTypeByBirthDate(String(birthDate || ""));
        if (!shironeType) return "";
        const displayName = getShironeTypeDisplayName(shironeType);
        const phaseDetail = shironeType.phase
          ? getShironePhaseDetail(shironeType, shironeType.phase.key)
          : "";
        const phaseHtml = shironeType.phase
          ? `
              <p>${escapeHtml(shironeType.phase.label)}</p>
              <p>${escapeHtml(phaseDetail || shironeType.phase.description)}</p>
            `
          : shironeType.specialNote
            ? `<p>${escapeHtml(shironeType.specialNote)}</p>`
            : "";

        return `
          <section class="fortune-seven-type-card" aria-label="あなたの属性">
            <div class="fortune-seven-type-label">あなたの属性</div>
            <div class="fortune-seven-type-main">
              <div>
                <h2>${escapeHtml(displayName)}${shironeType.phase ? `・${escapeHtml(shironeType.phase.label)}` : ""}</h2>
                <p>${escapeHtml(shironeType.catchphrase)}</p>
                ${phaseHtml}
              </div>
              <span>${escapeHtml(shironeType.reading)}</span>
            </div>
            <a href="/types">属性一覧を見る</a>
          </section>
        `;
      }

      function renderShironeSections(sections) {
        if (!Array.isArray(sections) || sections.length === 0) return "";

        const validSections = sections
          .map((section) => ({
            title: String(section?.title || "").trim(),
            body: String(section?.body || "").trim()
          }))
          .filter((section) => section.title || section.body);

        if (validSections.length === 0) return "";

        return `
          <section class="fortune-shirone-sections" aria-label="白音七からの読み解き">
            <h2 class="fortune-shirone-sections-title">白音七からの読み解き</h2>
            <div class="fortune-shirone-section-list">
              ${validSections
                .map(
                  (section) => `
                    <article class="fortune-shirone-section">
                      ${section.title ? `<h3>${escapeHtml(section.title)}</h3>` : ""}
                      ${section.body ? `<p>${toHtmlLines(section.body)}</p>` : ""}
                    </article>
                  `
                )
                .join("")}
            </div>
          </section>
        `;
      }

      function renderLineIcon(name) {
        const icons = {
          calendar: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <rect x="8" y="9" width="16" height="15" rx="3"></rect>
              <path d="M11 7v5M21 7v5M8 14h16M12 18h2M18 18h2"></path>
            </svg>
          `,
          zodiac: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <path d="M16 6l1.7 5.2H23l-4.3 3.1 1.7 5.1-4.4-3.2-4.4 3.2 1.7-5.1L9 11.2h5.3L16 6z"></path>
              <path d="M7 24c5-3.2 11-3.2 18 0" opacity=".7"></path>
            </svg>
          `,
          path: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <path d="M8 23c5-11 12 1 16-10"></path>
              <circle cx="8" cy="23" r="2"></circle>
              <circle cx="24" cy="13" r="2"></circle>
            </svg>
          `,
          daylight: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <circle cx="16" cy="16" r="4"></circle>
              <path d="M16 6v4M16 22v4M6 16h4M22 16h4M9.4 9.4l2.8 2.8M19.8 19.8l2.8 2.8M22.6 9.4l-2.8 2.8M12.2 19.8l-2.8 2.8"></path>
            </svg>
          `,
          name: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <path d="M10 8h12a3 3 0 013 3v10a3 3 0 01-3 3H10a3 3 0 01-3-3V11a3 3 0 013-3z"></path>
              <path d="M12 14h8M12 19h5"></path>
              <path d="M12 8c.4-2 1.7-3 4-3s3.6 1 4 3"></path>
            </svg>
          `,
          key: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <circle cx="12" cy="16" r="4"></circle>
              <path d="M16 16h9M22 16v4M19 16v3"></path>
            </svg>
          `,
          moon: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <path d="M21 7c-5 1.5-8 5.5-8 10.1 0 3.8 2.2 6.9 5.8 8.4C12.7 25.1 8 20.5 8 14.9 8 9.8 12 5.7 17.2 5c1.2-.1 2.5.6 3.8 2z"></path>
            </svg>
          `,
          starline: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <circle cx="9" cy="20" r="1.8"></circle>
              <circle cx="16" cy="10" r="1.8"></circle>
              <circle cx="23" cy="18" r="1.8"></circle>
              <path d="M10.3 18.6l4.4-6.5M17.4 11.4l4.3 5.2"></path>
            </svg>
          `,
          wave: `
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <path d="M6 13c3.3-3 6.7 3 10 0s6.7-3 10 0"></path>
              <path d="M6 20c3.3-3 6.7 3 10 0s6.7-3 10 0" opacity=".72"></path>
            </svg>
          `
        };

        return icons[name] || "";
      }

      function getHintIconName(hint) {
        const key = String(hint?.key || "").toLowerCase();
        const label = String(hint?.label || "");
        const value = String(hint?.value || "");

        if (key.includes("numerology") || label.includes("数") || value.includes("LP")) return "lpBadge";
        if (key.includes("astrology") || label.includes("星")) return "zodiac";
        if (key.includes("biorhythm") || label.includes("波")) return "thinkingWave";
        return "";
      }

      function renderIllustrationIcon(src, alt, className = "") {
        if (!src) return "";

        return `
          <img
            class="${escapeHtml(className)}"
            src="${escapeHtml(src)}"
            alt="${escapeHtml(alt)}"
            loading="lazy"
            decoding="async"
          />
        `;
      }

      function renderDailyKeyCards(fortune) {
        const cards = [
          { label: "鑑定日", value: fortune.fortuneDate, icon: shironeIconMap.calendar, alt: "月の暦のアイコン" },
          { label: "星座", value: fortune.zodiac, icon: shironeIconMap.zodiac, alt: "星座盤のアイコン" },
          { label: "ライフパス", value: fortune.lifePathNumber, icon: shironeIconMap.lifepath, alt: "星の道のアイコン" },
          { label: "パーソナルデイ", value: fortune.personalDayNumber, icon: shironeIconMap.personalDay, alt: "今日の光のアイコン" },
          { label: "名前ナンバー", value: fortune.nameNumber, icon: shironeIconMap.nameNumber, alt: "名前とペンのアイコン" },
          { label: "キーワード", value: fortune.keyword, icon: shironeIconMap.keyword, alt: "鍵とリボンのアイコン", featured: true }
        ];

        return `
          <section class="fortune-key-section" aria-label="今日の鍵">
            <div class="fortune-section-head">
              <span class="fortune-section-kicker">TODAY'S KEY</span>
              <h2>今日の鍵</h2>
            </div>
            <div class="fortune-key-grid">
              ${cards
                .map(
                  (card) => `
                    <article class="fortune-key-card${card.featured ? " is-featured" : ""}">
                      <span class="fortune-illustration-icon fortune-key-symbol">${renderIllustrationIcon(card.icon, card.alt, "fortune-illustration-icon-image")}</span>
                      <div>
                        <p class="fortune-key-label">${escapeHtml(card.label)}</p>
                        <p class="fortune-key-value">${escapeHtml(card.value)}</p>
                      </div>
                    </article>
                  `
                )
                .join("")}
            </div>
          </section>
        `;
      }

      function extractBiorhythm(source) {
        if (!source || typeof source !== "object") return null;

        const candidates = [
          source.knowledgePayload?.context?.biorhythm,
          source.knowledge_payload?.context?.biorhythm,
          source.historyPayloadV2?.knowledgePayload?.context?.biorhythm,
          source.history_payload_v2?.knowledgePayload?.context?.biorhythm,
          source.result?.knowledgePayload?.context?.biorhythm,
          source.result?.knowledge_payload?.context?.biorhythm,
          source.result?.historyPayloadV2?.knowledgePayload?.context?.biorhythm,
          source.result?.history_payload_v2?.knowledgePayload?.context?.biorhythm
        ];

        return (
          candidates.find(
            (candidate) =>
              candidate &&
              typeof candidate === "object" &&
              candidate.physical &&
              candidate.emotional &&
              candidate.intellectual
          ) || null
        );
      }

      function normalizeBiorhythmLevel(level) {
        const value = String(level || "middle");
        return Object.prototype.hasOwnProperty.call(biorhythmLevelValues, value) ? value : "middle";
      }

      function parseDateValue(value) {
        const match = String(value || "").match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if (!match) return null;

        const year = Number(match[1]);
        const month = Number(match[2]);
        const day = Number(match[3]);
        const date = new Date(Date.UTC(year, month - 1, day));

        if (
          date.getUTCFullYear() !== year ||
          date.getUTCMonth() !== month - 1 ||
          date.getUTCDate() !== day
        ) {
          return null;
        }

        return date;
      }

      function daysBetween(fromDate, toDate) {
        const dayMs = 24 * 60 * 60 * 1000;
        return Math.round((toDate.getTime() - fromDate.getTime()) / dayMs);
      }

      function getWavePoint(dayOffset, elapsedDays, period) {
        const graphWidth = biorhythmSvgWidth - biorhythmSvgPaddingX * 2;
        const x =
          biorhythmSvgPaddingX +
          ((dayOffset + biorhythmWaveRange) / (biorhythmWaveRange * 2)) * graphWidth;
        const wave = Math.sin((2 * Math.PI * (elapsedDays + dayOffset)) / period);
        const y = biorhythmSvgMidY - wave * biorhythmSvgAmplitude;

        return { x, y };
      }

      function renderBiorhythmWavePath(elapsedDays, period) {
        return Array.from({ length: biorhythmWaveRange * 2 + 1 }, (_, index) => {
          const dayOffset = index - biorhythmWaveRange;
          const point = getWavePoint(dayOffset, elapsedDays, period);
          return `${index === 0 ? "M" : "L"} ${point.x.toFixed(1)} ${point.y.toFixed(1)}`;
        }).join(" ");
      }

      function renderBiorhythmWaveGraph(birthDate, fortuneDate) {
        const birth = parseDateValue(birthDate);
        const today = parseDateValue(fortuneDate);
        if (!birth || !today) return "";

        const elapsedDays = daysBetween(birth, today);
        const todayX = biorhythmSvgWidth / 2;
        const paths = biorhythmWaveSeries
          .map((series) => {
            const todayPoint = getWavePoint(0, elapsedDays, series.period);
            return `
              <path class="fortune-bio-wave-line ${series.className}" d="${renderBiorhythmWavePath(elapsedDays, series.period)}" />
              <circle class="fortune-bio-wave-point ${series.className}" cx="${todayPoint.x.toFixed(1)}" cy="${todayPoint.y.toFixed(1)}" r="4.2" />
            `;
          })
          .join("");

        return `
          <div class="fortune-bio-wave-wrap">
            <p class="fortune-bio-wave-lead">
              今日を中心に<br />
              身体・感情・思考の波を静かに映しています
            </p>
            <svg class="fortune-bio-wave" viewBox="0 0 ${biorhythmSvgWidth} ${biorhythmSvgHeight}" role="img" aria-label="今日を中心にしたバイオリズムの波形">
              <line class="fortune-bio-wave-axis" x1="${biorhythmSvgPaddingX}" y1="${biorhythmSvgMidY}" x2="${biorhythmSvgWidth - biorhythmSvgPaddingX}" y2="${biorhythmSvgMidY}" />
              <line class="fortune-bio-wave-today" x1="${todayX}" y1="24" x2="${todayX}" y2="${biorhythmSvgHeight - 34}" />
              <text class="fortune-bio-wave-label" x="${biorhythmSvgPaddingX}" y="${biorhythmSvgHeight - 12}">-15日</text>
              <text class="fortune-bio-wave-label today" x="${todayX}" y="${biorhythmSvgHeight - 12}">今日</text>
              <text class="fortune-bio-wave-label end" x="${biorhythmSvgWidth - biorhythmSvgPaddingX}" y="${biorhythmSvgHeight - 12}">+15日</text>
              ${paths}
            </svg>
            <div class="fortune-bio-wave-legend" aria-label="波形の凡例">
              ${biorhythmWaveSeries
                .map(
                  (series) => `
                    <span class="${series.className}">
                      <i></i>${escapeHtml(series.label)}
                    </span>
                  `
                )
                .join("")}
            </div>
          </div>
        `;
      }

      function renderBiorhythmGauge(source, birthDate, fortuneDate) {
        const biorhythm = extractBiorhythm(source);
        if (!biorhythm) return "";
        const waveGraph = renderBiorhythmWaveGraph(birthDate, fortuneDate);

        const rows = ["physical", "emotional", "intellectual"].map((key) => {
          const level = normalizeBiorhythmLevel(biorhythm[key]);
          const value = biorhythmLevelValues[level];

          return `
            <article class="fortune-bio-card level-${level}">
              <div class="fortune-bio-card-head">
                <span>${escapeHtml(biorhythmLabels[key])}</span>
                <strong>${escapeHtml(biorhythmLevelLabels[level])}</strong>
              </div>
              <div class="fortune-bio-gauge" aria-label="${escapeHtml(biorhythmLabels[key])} ${escapeHtml(biorhythmLevelLabels[level])}">
                ${[1, 2, 3]
                  .map((step) => `<span class="${step <= value ? "is-lit" : ""}"></span>`)
                  .join("")}
              </div>
              <p>${escapeHtml(level)}</p>
            </article>
          `;
        });

        return `
          <section class="fortune-biorhythm-section" aria-label="今日の波">
            <div class="fortune-section-head">
              <span class="fortune-section-kicker">TODAY'S WAVE</span>
              <h2>今日の波</h2>
            </div>
            ${waveGraph}
            <div class="fortune-bio-grid">
              ${rows.join("")}
            </div>
          </section>
        `;
      }

      function renderVisualIconHints(source) {
        const iconHints = Array.isArray(source)
          ? source.map(normalizeIconHint).filter(Boolean)
          : extractIconHints(source);

        if (!iconHints.length) return "";

        return `
          <section class="fortune-icon-hints-section" aria-label="今日の小さな手がかり">
            <div class="fortune-section-head">
              <span class="fortune-section-kicker">SMALL SIGNS</span>
              <h2>今日の小さな手がかり</h2>
            </div>
            <div class="fortune-icon-hints-grid">
              ${iconHints
                .map((hint) => {
                  const iconName = getHintIconName(hint);
                  const iconSrc = shironeIconMap[iconName];
                  const iconAlt = iconName === "lpBadge"
                    ? "数秘の手がかりを示すアイコン"
                    : iconName === "zodiac"
                      ? "星の手がかりを示すアイコン"
                      : iconName === "thinkingWave"
                        ? "波の手がかりを示すアイコン"
                        : "";

                  return `
                    <article class="fortune-icon-hint-card tone-${hint.tone}">
                      <div class="fortune-illustration-icon fortune-icon-hint-symbol">
                        ${iconSrc ? renderIllustrationIcon(iconSrc, iconAlt, "fortune-illustration-icon-image") : escapeHtml(hint.icon)}
                      </div>
                      <div class="fortune-icon-hint-text">
                        <div class="fortune-icon-hint-label">${escapeHtml(hint.label)}</div>
                        <div class="fortune-icon-hint-value">${escapeHtml(hint.value)}</div>
                      </div>
                    </article>
                  `;
                })
                .join("")}
            </div>
          </section>
        `;
      }

      function renderVisualShironeTypeCard(birthDate) {
        const shironeType = getShironeTypeByBirthDate(String(birthDate || ""));
        if (!shironeType) return "";
        const displayName = getShironeTypeDisplayName(shironeType);
        const phaseLabel = shironeType.phase ? shironeType.phase.label : "";
        const title = phaseLabel ? `${displayName}・${phaseLabel}` : displayName;
        const iconSrc = typeIconImages[shironeType.slug];
        const phaseDetail = shironeType.phase
          ? getShironePhaseDetail(shironeType, shironeType.phase.key)
          : "";
        const phaseHtml = shironeType.phase
          ? `
              <div class="fortune-seven-type-phase">
                <span>${escapeHtml(shironeType.phase.label)}</span>
                <p>${escapeHtml(phaseDetail || shironeType.phase.description)}</p>
              </div>
            `
          : shironeType.specialNote
            ? `<div class="fortune-seven-type-phase"><p>${escapeHtml(shironeType.specialNote)}</p></div>`
            : "";
        const iconHtml = iconSrc
          ? renderIllustrationIcon(iconSrc, `${displayName}の属性を示すアイコン`, "fortune-illustration-icon-image")
          : `<span>${escapeHtml(shironeType.icon || displayName.slice(0, 1))}</span>`;

        return `
          <section class="fortune-seven-type-card" aria-label="あなたの属性">
            <div class="fortune-seven-type-label">あなたの属性</div>
            <div class="fortune-seven-type-main">
              <div class="fortune-seven-type-icon">
                ${iconHtml}
              </div>
              <div class="fortune-seven-type-copy">
                <h2>${escapeHtml(title)}</h2>
                <span>${escapeHtml(shironeType.reading)}</span>
                <p>${escapeHtml(shironeType.catchphrase)}</p>
                ${phaseHtml}
              </div>
            </div>
            <a href="/types">属性一覧を見る</a>
          </section>
        `;
      }

      if (!input || !input.name || !input.birthday) {
        if (resultHeadArea) {
          resultHeadArea.innerHTML = `
            <h1 class="fortune-result-title">鑑定結果が見つかりません</h1>
            <p class="fortune-result-message">
              先に診断ページで入力してください。
            </p>
          `;
        }

        if (resultBodyArea) {
          resultBodyArea.innerHTML = `
            <div class="fortune-result-actions">
              <a href="/diagnosis" class="fortune-btn primary">占い入力へ進む</a>
            </div>
          `;
        }

        if (saveBtn) saveBtn.style.display = "none";
        if (premiumBtn) premiumBtn.style.display = "none";
      } else {
        const name = String(input.name || "").trim();
        const birthday = String(input.birthday || "");
        const gender = input.gender || "";
        let fortune = null;

        try {
          fortune = buildDailyFortune({ name, birthday, gender });
        } catch (error) {
          console.error(error);

          if (resultHeadArea) {
            resultHeadArea.innerHTML = `
              <h1 class="fortune-result-title">入力内容を確認してください</h1>
              <p class="fortune-result-message">
                もう一度、鑑定情報を入力してください。
              </p>
            `;
          }

          if (resultBodyArea) {
            resultBodyArea.innerHTML = `
              <div class="fortune-result-actions">
                <a href="/diagnosis" class="fortune-btn primary">鑑定情報を入力する</a>
              </div>
            `;
          }

          if (saveBtn) saveBtn.style.display = "none";
          if (premiumBtn) premiumBtn.style.display = "none";
        }

        if (fortune) {
          let shironeResult = null;

          try {
            shironeResult = runShironeEngine({
              birthDate: birthday,
              name,
              question: input.question ? String(input.question) : undefined,
              today: fortune.fortuneDate,
              plan: "free"
            });

            fortune = {
              ...fortune,
              plan: shironeResult.plan,
              lengthRange: shironeResult.lengthRange,
              sections: shironeResult.sections,
              iconHints: shironeResult.iconHints,
              knowledgePayload: shironeResult.knowledgePayload,
              historyPayloadV2: shironeResult.historyPayloadV2
            };
          } catch (error) {
            console.error("shironeEngine result merge failed", error);
          }

        const resultPayload = {
          name,
          birthday,
          gender,
          engineVersion: fortune.engineVersion,
          fortuneDate: fortune.fortuneDate,
          lifePathNumber: fortune.lifePathNumber,
          personalDayNumber: fortune.personalDayNumber,
          nameNumber: fortune.nameNumber,
          zodiac: fortune.zodiac,
          theme: fortune.theme,
          keyword: fortune.keyword,
          today: fortune.flow,
          mind: fortune.mind,
          outer: fortune.outer,
          action: fortune.action,
          caution: fortune.caution,
          summary: fortune.summary,
          luckyAction: fortune.luckyAction,
          plan: fortune.plan,
          lengthRange: fortune.lengthRange,
          sections: fortune.sections,
          iconHints: fortune.iconHints,
          knowledgePayload: fortune.knowledgePayload,
          historyPayloadV2: fortune.historyPayloadV2
        };

        if (resultHeadArea) {
          resultHeadArea.innerHTML = `
            <div class="fortune-detail-kicker">TODAY'S READING</div>
            <h1 class="fortune-result-title">${escapeHtml(fortune.displayName)}の鑑定結果</h1>
            <p class="fortune-result-message">
              ${escapeHtml(fortune.summary)}<br />
              同じ人でも 日付が変われば流れも変わります
            </p>
          `;
        }

        if (resultBodyArea) {
          resultBodyArea.innerHTML = `
            ${renderDailyKeyCards(fortune)}

            ${renderVisualShironeTypeCard(birthday)}

            ${renderVisualIconHints(fortune)}

            ${renderBiorhythmGauge(fortune, birthday, fortune.fortuneDate)}

            <div class="fortune-result-card highlight">
              <h2>今日のテーマ</h2>
              <p>${escapeHtml(fortune.theme)}</p>
            </div>

            <div class="fortune-result-card">
              <h2>今日の流れ</h2>
              <p>${toHtmlLines(fortune.flow)}</p>
            </div>

            <div class="fortune-result-card">
              <h2>心の向き</h2>
              <p>${toHtmlLines(fortune.mind)}</p>
            </div>

            <div class="fortune-result-card">
              <h2>外から見えるあなた</h2>
              <p>${toHtmlLines(fortune.outer)}</p>
            </div>

            <div class="fortune-result-card highlight">
              <h2>今日の行動ヒント</h2>
              <p>${escapeHtml(fortune.action)}</p>
            </div>

            <div class="fortune-result-card">
              <h2>避けたいこと</h2>
              <p>${escapeHtml(fortune.caution)}</p>
            </div>

            ${renderShironeSections(fortune.sections)}
          `;
        }

        function normalizeForKey(value) {
          return String(value || "")
            .trim()
            .replace(/\s+/g, "")
            .toLowerCase();
        }

        function getCurrentUserId() {
          return (
            localStorage.getItem("user_id") ||
            localStorage.getItem("userId") ||
            localStorage.getItem("loginEmail") ||
            ""
          );
        }

        function getDedupeKey(userId) {
          return [
            "daily_engine_v1",
            normalizeForKey(userId),
            fortune.fortuneDate,
            normalizeForKey(resultPayload.name),
            normalizeForKey(resultPayload.birthday),
            normalizeForKey(resultPayload.engineVersion)
          ].join(":");
        }

        function getSavedStorageKey(userId) {
          return `shirone7_saved_today:${getDedupeKey(userId)}`;
        }

        function getSavedRecord(userId) {
          const key = getSavedStorageKey(userId);
          const raw = localStorage.getItem(key);

          if (!raw) return null;

          try {
            return JSON.parse(raw);
          } catch {
            return { saved: true };
          }
        }

        function setSavedRecord(userId, record) {
          const key = getSavedStorageKey(userId);
          localStorage.setItem(key, JSON.stringify(record));
        }

        function isSameResult(a, b) {
          return (
            a &&
            b &&
            normalizeForKey(a.name) === normalizeForKey(b.name) &&
            normalizeForKey(a.birthday) === normalizeForKey(b.birthday) &&
            a.fortuneDate === b.fortuneDate &&
            a.engineVersion === b.engineVersion
          );
        }

        function alreadySavedByLegacyList() {
          const savedItems = JSON.parse(localStorage.getItem("savedFortunes") || "[]");
          return savedItems.some((item) => isSameResult(item, resultPayload));
        }

        function alreadySaved(userId) {
          if (!userId) return false;
          return Boolean(getSavedRecord(userId)) || alreadySavedByLegacyList();
        }

        function isUnauthorizedMessage(value) {
          return String(value || "").toLowerCase().includes("unauthorized");
        }

        function getSaveErrorMessage(value, status) {
          if (status === 401 || status === 403 || isUnauthorizedMessage(value)) {
            return "ログイン状態を確認できませんでした。\nお手数ですが、もう一度ログインしてから保存してください。";
          }

          return "保存に失敗しました。\n少し時間を置いて、もう一度お試しください。";
        }

        function renderSavedState(options = {}) {
          const mode = options.mode || "saved";

          if (saveMessage) {
            saveMessage.textContent =
              mode === "already"
                ? "今日の鑑定はすでに記録されています。履歴から確認できます。"
                : "鑑定結果を記録しました。";
          }

          if (saveBtn) {
            saveBtn.textContent = "✓ 記録済み";
            saveBtn.disabled = true;
            saveBtn.classList.add("fortune-btn-disabled");
          }

          if (resultActions && !document.getElementById("historyBtn")) {
            const historyBtn = document.createElement("a");
            historyBtn.href = "/history";
            historyBtn.id = "historyBtn";
            historyBtn.className = "fortune-btn violet";
            historyBtn.textContent = "履歴を見る";
            resultActions.appendChild(historyBtn);
          }
        }

        const currentUserIdForSavedCheck = getCurrentUserId();

        if (currentUserIdForSavedCheck && alreadySaved(currentUserIdForSavedCheck)) {
          renderSavedState({ mode: "already" });
        }

        saveBtn?.addEventListener("click", async () => {
          if (saveMessage) saveMessage.textContent = "";

          const token = String(localStorage.getItem("token") || "").trim();

          if (!token) {
            sessionStorage.setItem("pendingFortuneResult", JSON.stringify(resultPayload));
            if (saveMessage) {
              saveMessage.textContent =
                "ログイン状態を確認できませんでした。\n結果を保存するには、もう一度ログインしてください。";
            }
            return;
          }

          const userId = getCurrentUserId();

          if (!userId) {
            if (saveMessage) {
              saveMessage.textContent =
                "ログイン状態を確認できませんでした。\n結果を保存するには、もう一度ログインしてください。";
            }
            return;
          }

          const dedupeKey = getDedupeKey(userId);

          if (alreadySaved(userId)) {
            renderSavedState({ mode: "already" });
            return;
          }

          if (saveBtn) {
            saveBtn.disabled = true;
            saveBtn.textContent = "記録中...";
          }

          let historyId = "";
          let saveResponseStatus = null;
          let saveResponseBody = null;

          try {
            historyId = crypto.randomUUID();
            const createdAt = new Date().toISOString();

            const savePayload = {
              history_id: historyId,
              type: "normal",
              source: "daily_engine_v1",
              dedupe_key: dedupeKey,
              title: `今日の鑑定 ${fortune.fortuneDate}`,
              input_title: `今日の鑑定 ${fortune.fortuneDate}`,
              name: resultPayload.name,
              birth_date: resultPayload.birthday,
              gender: resultPayload.gender,
              category: "general",
              status: "completed",
              created_at: createdAt,
              updated_at: createdAt,
              result_preview: resultPayload.summary,
              summary: resultPayload.summary,
              result_text: [
                resultPayload.summary,
                resultPayload.theme,
                resultPayload.today,
                resultPayload.mind,
                resultPayload.outer,
                resultPayload.action,
                resultPayload.caution
              ].filter(Boolean).join("\n\n"),
              result: {
                ...resultPayload,
                dedupeKey
              }
            };

            const res = await fetch(HISTORY_SAVE_API, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                Authorization: "Bearer " + token
              },
              body: JSON.stringify(savePayload)
            });

            const data = await res.json().catch(() => ({}));
            saveResponseStatus = res.status;
            saveResponseBody = data;

            if (!res.ok) {
              const saveError = new Error(getSaveErrorMessage(data?.message || data?.error, res.status));
              saveError.status = res.status;
              saveError.response = data;
              throw saveError;
            }

            const savedItems = JSON.parse(localStorage.getItem("savedFortunes") || "[]");

            savedItems.unshift({
              id: historyId,
              createdAt,
              dedupeKey,
              ...resultPayload
            });

            localStorage.setItem("savedFortunes", JSON.stringify(savedItems.slice(0, 100)));

            setSavedRecord(userId, {
              saved: true,
              historyId,
              createdAt,
              dedupeKey,
              name: resultPayload.name,
              birthday: resultPayload.birthday,
              fortuneDate: resultPayload.fortuneDate,
              engineVersion: resultPayload.engineVersion
            });

            renderSavedState({ mode: "saved" });
          } catch (error) {
            console.error("fortune result save failed", {
              error,
              endpoint: HISTORY_SAVE_API,
              origin: window.location.origin,
              status: error?.status || saveResponseStatus,
              response: error?.response || saveResponseBody,
              hasToken: Boolean(token),
              hasUserId: Boolean(userId),
              historyId
            });

            if (saveBtn) {
              saveBtn.disabled = false;
              saveBtn.textContent = "この結果を記録する";
            }

            if (saveMessage) {
              saveMessage.textContent = getSaveErrorMessage(error?.message);
            }
          }
        });

        premiumBtn?.addEventListener("click", () => {
          const currentToken = localStorage.getItem("token");

          if (currentToken) {
            window.location.href = "/premium";
          } else {
            window.location.href = "/login?redirect=/premium";
          }
        });
        }
      }
    </script>

