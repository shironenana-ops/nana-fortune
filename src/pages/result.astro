---
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>鑑定結果 | 白音七</title>
    <meta name="description" content="白音七の鑑定結果ページ" />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/history">履歴一覧</a>
          <a href="/privacy">プライバシーポリシー</a>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main class="fortune-result">
      <section class="fortune-container">
        <div class="fortune-result-frame">
          <div id="resultHeadArea"></div>
          <div id="resultBodyArea"></div>

          <div class="fortune-result-cta">
            <h2>この流れ、残しておきませんか？</h2>

            <p>
              今日の結果を一度きりで終わらせず、<br />
              あなた自身の変化として積み重ねていくことができます。
            </p>

            <p id="saveMessage" class="fortune-result-message"></p>

            <div id="resultActions" class="fortune-result-actions">
              <a href="/diagnosis" class="fortune-btn primary">
                もう一度占う
              </a>

              <button id="saveBtn" class="fortune-btn secondary" type="button">
                この結果を記録する
              </button>
            </div>
          </div>

          <div class="fortune-premium-box">
            <div class="fortune-premium-inner">
              <h2 class="fortune-premium-title">
                このまま進んだ未来、見えてますか？
              </h2>

              <p class="fortune-premium-lead">
                今回の鑑定は入口にすぎません。<br />
                白音七メソッドでは、あなたの人生の流れ・本質・未来の分岐まで読み解きます。
              </p>

              <div class="fortune-premium-content">
                <div class="fortune-premium-item">
                  <h3>🔢 数秘術（本質）</h3>
                  <p>ピタゴラス式チャートで、生まれ持つ資質と人生の役割を解析</p>
                </div>

                <div class="fortune-premium-item">
                  <h3>🌙 占星術（流れ）</h3>
                  <p>運気の波とタイミングを読み取り、最適な行動時期を導く</p>
                </div>

                <div class="fortune-premium-item">
                  <h3>🧬 姓名判断・手相</h3>
                  <p>あなたの現在地と変化の兆しを多角的に分析</p>
                </div>

                <div class="fortune-premium-item">
                  <h3>📈 バイオリズム</h3>
                  <p>日々の流れを可視化し、運気の上げ方を具体化</p>
                </div>
              </div>

              <div class="fortune-premium-cta">
                <button id="premiumBtn" class="fortune-btn gold big" type="button">
                  ✧ この先の運命を見る
                </button>
                <p class="fortune-premium-note">
                  ※この先の鑑定は会員限定で提供されています
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script>
      // @ts-nocheck
      import { buildDailyFortune } from "../lib/fortuneEngine";
      import { runShironeEngine } from "../lib/shironeEngine";
      import { getShironeTypeByBirthDate } from "../lib/shironeTypes";

      const authArea = document.getElementById("authArea");
      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      if (authArea) {
        if (token && email) {
          authArea.innerHTML = `
            <span class="fortune-user">${email}</span>
            <button id="logoutBtn" class="fortune-nav-logout" type="button">ログアウト</button>
          `;

          document.getElementById("logoutBtn")?.addEventListener("click", () => {
            localStorage.removeItem("token");
            localStorage.removeItem("loginEmail");
            window.location.href = "/";
          });
        } else {
          authArea.innerHTML = `
            <a href="/login" class="fortune-nav-pill">会員ログイン</a>
          `;
        }
      }

      const input = JSON.parse(localStorage.getItem("fortuneInput") || "null");
      const resultHeadArea = document.getElementById("resultHeadArea");
      const resultBodyArea = document.getElementById("resultBodyArea");
      const saveBtn = document.getElementById("saveBtn");
      const saveMessage = document.getElementById("saveMessage");
      const resultActions = document.getElementById("resultActions");
      const premiumBtn = document.getElementById("premiumBtn");

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function toHtmlLines(value) {
        return escapeHtml(value).replaceAll("\n", "<br />");
      }

      function toAttributeName(typeName) {
        return String(typeName || "").replace(/タイプ$/, "属性");
      }

      const iconHintTones = new Set(["gold", "purple", "blue", "green", "gray"]);

      function normalizeIconHintTone(tone) {
        const value = String(tone || "gray");
        return iconHintTones.has(value) ? value : "gray";
      }

      function normalizeIconHint(hint) {
        if (!hint || typeof hint !== "object") return null;

        const icon = String(hint.icon || "").trim();
        const label = String(hint.label || "").trim();
        const value = String(hint.value || "").trim();

        if (!icon && !label && !value) return null;

        return {
          icon: icon || "・",
          label: label || "手がかり",
          value,
          tone: normalizeIconHintTone(hint.tone)
        };
      }

      function extractIconHints(source) {
        if (!source || typeof source !== "object") return [];

        const candidates = [
          source.iconHints,
          source.icon_hints,
          source.result?.iconHints,
          source.result?.icon_hints,
          source.historyPayloadV2?.result?.iconHints,
          source.history_payload_v2?.result?.iconHints,
          source.result?.historyPayloadV2?.result?.iconHints,
          source.result?.history_payload_v2?.result?.iconHints
        ];

        const rawHints = candidates.find((candidate) => Array.isArray(candidate));
        if (!rawHints) return [];

        return rawHints.map(normalizeIconHint).filter(Boolean);
      }

      function renderIconHints(source) {
        const iconHints = Array.isArray(source)
          ? source.map(normalizeIconHint).filter(Boolean)
          : extractIconHints(source);

        if (!iconHints.length) return "";

        return `
          <section class="fortune-icon-hints-section" aria-label="今日の小さな手がかり">
            <h2 class="fortune-icon-hints-title">今日の小さな手がかり</h2>
            <div class="fortune-icon-hints-grid">
              ${iconHints
                .map(
                  (hint) => `
                    <article class="fortune-icon-hint-card tone-${hint.tone}">
                      <div class="fortune-icon-hint-symbol">${escapeHtml(hint.icon)}</div>
                      <div class="fortune-icon-hint-text">
                        <div class="fortune-icon-hint-label">${escapeHtml(hint.label)}</div>
                        <div class="fortune-icon-hint-value">${escapeHtml(hint.value)}</div>
                      </div>
                    </article>
                  `
                )
                .join("")}
            </div>
          </section>
        `;
      }

      function renderShironeTypeCard(birthDate) {
        const shironeType = getShironeTypeByBirthDate(String(birthDate || ""));
        if (!shironeType) return "";

        return `
          <section class="fortune-seven-type-card" aria-label="あなたの属性">
            <div class="fortune-seven-type-label">あなたの属性</div>
            <div class="fortune-seven-type-main">
              <div>
                <h2>${escapeHtml(toAttributeName(shironeType.typeName))}</h2>
                <p>${escapeHtml(shironeType.catchphrase)}</p>
              </div>
              <span>${escapeHtml(shironeType.reading)}</span>
            </div>
            <a href="/types">属性一覧を見る</a>
          </section>
        `;
      }

      function renderShironeSections(sections) {
        if (!Array.isArray(sections) || sections.length === 0) return "";

        const validSections = sections
          .map((section) => ({
            title: String(section?.title || "").trim(),
            body: String(section?.body || "").trim()
          }))
          .filter((section) => section.title || section.body);

        if (validSections.length === 0) return "";

        return `
          <section class="fortune-shirone-sections" aria-label="白音七からの読み解き">
            <h2 class="fortune-shirone-sections-title">白音七からの読み解き</h2>
            <div class="fortune-shirone-section-list">
              ${validSections
                .map(
                  (section) => `
                    <article class="fortune-shirone-section">
                      ${section.title ? `<h3>${escapeHtml(section.title)}</h3>` : ""}
                      ${section.body ? `<p>${toHtmlLines(section.body)}</p>` : ""}
                    </article>
                  `
                )
                .join("")}
            </div>
          </section>
        `;
      }

      if (!input || !input.name || !input.birthday) {
        if (resultHeadArea) {
          resultHeadArea.innerHTML = `
            <h1 class="fortune-result-title">鑑定結果が見つかりません</h1>
            <p class="fortune-result-message">
              先に診断ページで入力してください。
            </p>
          `;
        }

        if (resultBodyArea) {
          resultBodyArea.innerHTML = `
            <div class="fortune-result-actions">
              <a href="/diagnosis" class="fortune-btn primary">占い入力へ進む</a>
            </div>
          `;
        }

        if (saveBtn) saveBtn.style.display = "none";
        if (premiumBtn) premiumBtn.style.display = "none";
      } else {
        const name = String(input.name || "").trim();
        const birthday = String(input.birthday || "");
        const gender = input.gender || "";
        let fortune = null;

        try {
          fortune = buildDailyFortune({ name, birthday, gender });
        } catch (error) {
          console.error(error);

          if (resultHeadArea) {
            resultHeadArea.innerHTML = `
              <h1 class="fortune-result-title">入力内容を確認してください</h1>
              <p class="fortune-result-message">
                もう一度、鑑定情報を入力してください。
              </p>
            `;
          }

          if (resultBodyArea) {
            resultBodyArea.innerHTML = `
              <div class="fortune-result-actions">
                <a href="/diagnosis" class="fortune-btn primary">鑑定情報を入力する</a>
              </div>
            `;
          }

          if (saveBtn) saveBtn.style.display = "none";
          if (premiumBtn) premiumBtn.style.display = "none";
        }

        if (fortune) {
          let shironeResult = null;

          try {
            shironeResult = runShironeEngine({
              birthDate: birthday,
              name,
              question: input.question ? String(input.question) : undefined,
              today: fortune.fortuneDate,
              plan: "free"
            });

            fortune = {
              ...fortune,
              plan: shironeResult.plan,
              lengthRange: shironeResult.lengthRange,
              sections: shironeResult.sections,
              iconHints: shironeResult.iconHints,
              knowledgePayload: shironeResult.knowledgePayload,
              historyPayloadV2: shironeResult.historyPayloadV2
            };
          } catch (error) {
            console.error("shironeEngine result merge failed", error);
          }

        const resultPayload = {
          name,
          birthday,
          gender,
          engineVersion: fortune.engineVersion,
          fortuneDate: fortune.fortuneDate,
          lifePathNumber: fortune.lifePathNumber,
          personalDayNumber: fortune.personalDayNumber,
          nameNumber: fortune.nameNumber,
          zodiac: fortune.zodiac,
          theme: fortune.theme,
          keyword: fortune.keyword,
          today: fortune.flow,
          mind: fortune.mind,
          outer: fortune.outer,
          action: fortune.action,
          caution: fortune.caution,
          summary: fortune.summary,
          luckyAction: fortune.luckyAction,
          plan: fortune.plan,
          lengthRange: fortune.lengthRange,
          sections: fortune.sections,
          iconHints: fortune.iconHints,
          knowledgePayload: fortune.knowledgePayload,
          historyPayloadV2: fortune.historyPayloadV2
        };

        if (resultHeadArea) {
          resultHeadArea.innerHTML = `
            <div class="fortune-detail-kicker">TODAY'S READING</div>
            <h1 class="fortune-result-title">${escapeHtml(fortune.displayName)}の鑑定結果</h1>
            <p class="fortune-result-message">
              ${escapeHtml(fortune.summary)}<br />
              同じ人でも 日付が変われば流れも変わります
            </p>
          `;
        }

        if (resultBodyArea) {
          resultBodyArea.innerHTML = `
            <div class="fortune-result-card">
              <h2>今日の鍵</h2>
              <p><strong>鑑定日：</strong>${escapeHtml(fortune.fortuneDate)}</p>
              <p><strong>星座：</strong>${escapeHtml(fortune.zodiac)}</p>
              <p><strong>ライフパス：</strong>${fortune.lifePathNumber}</p>
              <p><strong>パーソナルデイ：</strong>${fortune.personalDayNumber}</p>
              <p><strong>名前ナンバー：</strong>${fortune.nameNumber}</p>
              <p><strong>キーワード：</strong>${escapeHtml(fortune.keyword)}</p>
            </div>

            ${renderShironeTypeCard(birthday)}

            ${renderIconHints(fortune)}

            <div class="fortune-result-card highlight">
              <h2>今日のテーマ</h2>
              <p>${escapeHtml(fortune.theme)}</p>
            </div>

            <div class="fortune-result-card">
              <h2>今日の流れ</h2>
              <p>${toHtmlLines(fortune.flow)}</p>
            </div>

            <div class="fortune-result-card">
              <h2>心の向き</h2>
              <p>${toHtmlLines(fortune.mind)}</p>
            </div>

            <div class="fortune-result-card">
              <h2>外から見えるあなた</h2>
              <p>${toHtmlLines(fortune.outer)}</p>
            </div>

            <div class="fortune-result-card highlight">
              <h2>今日の行動ヒント</h2>
              <p>${escapeHtml(fortune.action)}</p>
            </div>

            <div class="fortune-result-card">
              <h2>避けたいこと</h2>
              <p>${escapeHtml(fortune.caution)}</p>
            </div>

            ${renderShironeSections(fortune.sections)}
          `;
        }

        function normalizeForKey(value) {
          return String(value || "")
            .trim()
            .replace(/\s+/g, "")
            .toLowerCase();
        }

        function getCurrentUserId() {
          return (
            localStorage.getItem("user_id") ||
            localStorage.getItem("userId") ||
            localStorage.getItem("loginEmail") ||
            ""
          );
        }

        function getDedupeKey(userId) {
          return [
            "daily_engine_v1",
            normalizeForKey(userId),
            fortune.fortuneDate,
            normalizeForKey(resultPayload.name),
            normalizeForKey(resultPayload.birthday),
            normalizeForKey(resultPayload.engineVersion)
          ].join(":");
        }

        function getSavedStorageKey(userId) {
          return `shirone7_saved_today:${getDedupeKey(userId)}`;
        }

        function getSavedRecord(userId) {
          const key = getSavedStorageKey(userId);
          const raw = localStorage.getItem(key);

          if (!raw) return null;

          try {
            return JSON.parse(raw);
          } catch {
            return { saved: true };
          }
        }

        function setSavedRecord(userId, record) {
          const key = getSavedStorageKey(userId);
          localStorage.setItem(key, JSON.stringify(record));
        }

        function isSameResult(a, b) {
          return (
            a &&
            b &&
            normalizeForKey(a.name) === normalizeForKey(b.name) &&
            normalizeForKey(a.birthday) === normalizeForKey(b.birthday) &&
            a.fortuneDate === b.fortuneDate &&
            a.engineVersion === b.engineVersion
          );
        }

        function alreadySavedByLegacyList() {
          const savedItems = JSON.parse(localStorage.getItem("savedFortunes") || "[]");
          return savedItems.some((item) => isSameResult(item, resultPayload));
        }

        function alreadySaved(userId) {
          if (!userId) return false;
          return Boolean(getSavedRecord(userId)) || alreadySavedByLegacyList();
        }

        function isUnauthorizedMessage(value) {
          return String(value || "").toLowerCase().includes("unauthorized");
        }

        function getSaveErrorMessage(value, status) {
          if (status === 401 || status === 403 || isUnauthorizedMessage(value)) {
            return "ログイン状態を確認できませんでした。\nお手数ですが、もう一度ログインしてから保存してください。";
          }

          return "保存に失敗しました。\n少し時間を置いて、もう一度お試しください。";
        }

        function renderSavedState(options = {}) {
          const mode = options.mode || "saved";

          if (saveMessage) {
            saveMessage.textContent =
              mode === "already"
                ? "今日の鑑定はすでに記録されています。履歴から確認できます。"
                : "鑑定結果を記録しました。";
          }

          if (saveBtn) {
            saveBtn.textContent = "✓ 記録済み";
            saveBtn.disabled = true;
            saveBtn.classList.add("fortune-btn-disabled");
          }

          if (resultActions && !document.getElementById("historyBtn")) {
            const historyBtn = document.createElement("a");
            historyBtn.href = "/history";
            historyBtn.id = "historyBtn";
            historyBtn.className = "fortune-btn violet";
            historyBtn.textContent = "履歴を見る";
            resultActions.appendChild(historyBtn);
          }
        }

        const currentUserIdForSavedCheck = getCurrentUserId();

        if (currentUserIdForSavedCheck && alreadySaved(currentUserIdForSavedCheck)) {
          renderSavedState({ mode: "already" });
        }

        saveBtn?.addEventListener("click", async () => {
          if (saveMessage) saveMessage.textContent = "";

          const token = String(localStorage.getItem("token") || "").trim();

          if (!token) {
            sessionStorage.setItem("pendingFortuneResult", JSON.stringify(resultPayload));
            if (saveMessage) {
              saveMessage.textContent =
                "ログイン状態を確認できませんでした。\n結果を保存するには、もう一度ログインしてください。";
            }
            return;
          }

          const userId = getCurrentUserId();

          if (!userId) {
            if (saveMessage) {
              saveMessage.textContent =
                "ログイン状態を確認できませんでした。\n結果を保存するには、もう一度ログインしてください。";
            }
            return;
          }

          const dedupeKey = getDedupeKey(userId);

          if (alreadySaved(userId)) {
            renderSavedState({ mode: "already" });
            return;
          }

          if (saveBtn) {
            saveBtn.disabled = true;
            saveBtn.textContent = "記録中...";
          }

          try {
            const historyId = crypto.randomUUID();
            const createdAt = new Date().toISOString();

            const savePayload = {
              history_id: historyId,
              type: "normal",
              source: "daily_engine_v1",
              dedupe_key: dedupeKey,
              title: `今日の鑑定 ${fortune.fortuneDate}`,
              input_title: `今日の鑑定 ${fortune.fortuneDate}`,
              name: resultPayload.name,
              birth_date: resultPayload.birthday,
              gender: resultPayload.gender,
              category: "general",
              status: "completed",
              created_at: createdAt,
              updated_at: createdAt,
              result_preview: resultPayload.summary,
              summary: resultPayload.summary,
              result_text: [
                resultPayload.summary,
                resultPayload.theme,
                resultPayload.today,
                resultPayload.mind,
                resultPayload.outer,
                resultPayload.action,
                resultPayload.caution
              ].filter(Boolean).join("\n\n"),
              result: {
                ...resultPayload,
                dedupeKey
              }
            };

            const res = await fetch(
              "https://mydmaywesh.execute-api.ap-northeast-1.amazonaws.com/prod/history",
              {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                  Authorization: "Bearer " + token
                },
                body: JSON.stringify(savePayload)
              }
            );

            const data = await res.json().catch(() => ({}));

            if (!res.ok) {
              throw new Error(getSaveErrorMessage(data?.message || data?.error, res.status));
            }

            const savedItems = JSON.parse(localStorage.getItem("savedFortunes") || "[]");

            savedItems.unshift({
              id: historyId,
              createdAt,
              dedupeKey,
              ...resultPayload
            });

            localStorage.setItem("savedFortunes", JSON.stringify(savedItems.slice(0, 100)));

            setSavedRecord(userId, {
              saved: true,
              historyId,
              createdAt,
              dedupeKey,
              name: resultPayload.name,
              birthday: resultPayload.birthday,
              fortuneDate: resultPayload.fortuneDate,
              engineVersion: resultPayload.engineVersion
            });

            renderSavedState({ mode: "saved" });
          } catch (error) {
            console.error(error);

            if (saveBtn) {
              saveBtn.disabled = false;
              saveBtn.textContent = "この結果を記録する";
            }

            if (saveMessage) {
              saveMessage.textContent = getSaveErrorMessage(error?.message);
            }
          }
        });

        premiumBtn?.addEventListener("click", () => {
          const currentToken = localStorage.getItem("token");

          if (currentToken) {
            window.location.href = "/premium";
          } else {
            window.location.href = "/login?redirect=/premium";
          }
        });
        }
      }
    </script>

    <style is:global>
      .fortune-seven-type-card {
        margin: 1rem 0 1.2rem;
        padding: 1rem 1.05rem;
        border: 1px solid rgba(226, 191, 92, 0.2);
        border-radius: 18px;
        background:
          linear-gradient(135deg, rgba(182, 140, 255, 0.08), rgba(127, 181, 255, 0.03)),
          rgba(255, 255, 255, 0.025);
      }

      .fortune-seven-type-label {
        margin-bottom: 0.55rem;
        color: rgba(255, 236, 179, 0.68);
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
      }

      .fortune-seven-type-main {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
      }

      .fortune-seven-type-main h2 {
        margin: 0 0 0.35rem;
        color: #fff0bf;
        font-size: 1.15rem;
        letter-spacing: 0;
      }

      .fortune-seven-type-main p {
        margin: 0;
        color: rgba(255, 236, 179, 0.86);
        line-height: 1.7;
      }

      .fortune-seven-type-main span {
        flex: 0 0 auto;
        color: rgba(255, 236, 179, 0.62);
        font-size: 0.84rem;
        white-space: nowrap;
      }

      .fortune-seven-type-card a {
        display: inline-flex;
        width: fit-content;
        margin-top: 0.75rem;
        color: #ffe58f;
        font-size: 0.84rem;
        text-decoration: underline;
        text-underline-offset: 0.25em;
      }

      .fortune-icon-hints-section {
        margin: 1.2rem 0;
      }

      .fortune-icon-hints-title {
