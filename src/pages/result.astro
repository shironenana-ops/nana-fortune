---
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>鑑定結果 | 白音七</title>
    <meta name="description" content="白音七の鑑定結果ページ" />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/history">履歴一覧</a>
          <a href="/privacy">プライバシーポリシー</a>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main class="fortune-result">
      <section class="fortune-container">
        <div class="fortune-result-frame">
          <div id="resultHeadArea"></div>
          <div id="resultBodyArea"></div>

          <div class="fortune-result-cta">
            <h2>この流れ、残しておきませんか？</h2>

            <p>
              今日の結果を一度きりで終わらせず、<br />
              あなた自身の変化として積み重ねていくことができます。
            </p>

            <p id="saveMessage" class="fortune-result-message"></p>

            <div id="resultActions" class="fortune-result-actions">
              <a href="/diagnosis" class="fortune-btn primary">
                もう一度占う
              </a>

              <button id="saveBtn" class="fortune-btn secondary" type="button">
                この結果を記録する
              </button>
            </div>
          </div>

          <div class="fortune-premium-box">
            <div class="fortune-premium-inner">
              <h2 class="fortune-premium-title">
                このまま進んだ未来、見えてますか？
              </h2>

              <p class="fortune-premium-lead">
                今回の鑑定は入口にすぎません。<br />
                白音七メソッドでは、あなたの人生の流れ・本質・未来の分岐まで読み解きます。
              </p>

              <div class="fortune-premium-content">
                <div class="fortune-premium-item">
                  <h3>🔢 数秘術（本質）</h3>
                  <p>ピタゴラス式チャートで、生まれ持つ資質と人生の役割を解析</p>
                </div>

                <div class="fortune-premium-item">
                  <h3>🌙 占星術（流れ）</h3>
                  <p>運気の波とタイミングを読み取り、最適な行動時期を導く</p>
                </div>

                <div class="fortune-premium-item">
                  <h3>🧬 生命診断・手相</h3>
                  <p>あなたの現在地と変化の兆しを多角的に分析</p>
                </div>

                <div class="fortune-premium-item">
                  <h3>📈 バイオリズム</h3>
                  <p>日々の流れを可視化し、運気の上げ方を具体化</p>
                </div>
              </div>

              <div class="fortune-premium-cta">
                <button id="premiumBtn" class="fortune-btn gold big" type="button">
                  ✧ この先の運命を見る
                </button>
                <p class="fortune-premium-note">
                  ※この先の鑑定は会員限定で提供されています
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script>
      const authArea = document.getElementById("authArea");
      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      if (token && email) {
        authArea.innerHTML = `
          <span class="fortune-user">${email}</span>
          <button id="logoutBtn" class="fortune-nav-logout" type="button">⏻ ログアウト</button>
        `;

        document.getElementById("logoutBtn").addEventListener("click", () => {
          localStorage.removeItem("token");
          localStorage.removeItem("loginEmail");
          window.location.href = "/";
        });
      } else {
        authArea.innerHTML = `
          <a href="/login" class="fortune-nav-pill">会員ログイン</a>
        `;
      }

      const input = JSON.parse(localStorage.getItem("fortuneInput") || "null");
      const resultHeadArea = document.getElementById("resultHeadArea");
      const resultBodyArea = document.getElementById("resultBodyArea");

      if (!input || !input.name || !input.birthday) {
        resultHeadArea.innerHTML = `
          <h1 class="fortune-result-title">鑑定結果が見つかりません</h1>
          <p class="fortune-result-message">
            先に診断ページで入力してください。
          </p>
        `;

        resultBodyArea.innerHTML = `
          <div class="fortune-result-actions">
            <a href="/diagnosis" class="fortune-btn primary">占い入力へ進む</a>
          </div>
        `;

        document.getElementById("saveBtn").style.display = "none";
        document.getElementById("premiumBtn").style.display = "none";
      } else {
        const name = input.name.trim();
        const birthday = input.birthday;
        const gender = input.gender || "";

        const date = new Date(birthday);
        const month = date.getMonth() + 1;
        const day = date.getDate();

        function digitSum(value) {
          return String(value)
            .replace(/\D/g, "")
            .split("")
            .reduce((sum, n) => sum + Number(n), 0);
        }

        function reduceNumber(num) {
          let n = num;
          while (n > 9) {
            n = String(n)
              .split("")
              .reduce((sum, v) => sum + Number(v), 0);
          }
          return n;
        }

        const currentYear = new Date().getFullYear();
        const yearNumber = reduceNumber(digitSum(month) + digitSum(day) + digitSum(currentYear));

        const yearThemes = {
          1: "始まり直しと決断",
          2: "調整と対人バランス",
          3: "表現と広がり",
          4: "整備と安定",
          5: "変化と挑戦",
          6: "愛情と責任",
          7: "内省と見直し",
          8: "結果と実行",
          9: "完了と手放し"
        };

        const yearActions = {
          1: "新しく始めたいことを一つ決めて、最初の一歩だけでも踏み出してみましょう。",
          2: "急いで答えを出すより、人との距離感や流れを整えることが運を呼びます。",
          3: "思っていることを言葉にしてみることで、停滞がほどけやすくなります。",
          4: "生活や仕事の足元を整えるほど、あとから安心感がついてきます。",
          5: "いつもと違う選択肢を一つ試すことで、流れが大きく動き始めます。",
          6: "大切な人や自分の居場所に目を向けることで、心の軸が戻ってきます。",
          7: "無理に外へ広げるより、今は内側を整える時間を持つことが大切です。",
          8: "決めたことを実行に移し、結果につなげる意識が運気を押し上げます。",
          9: "抱え込みすぎているものを一つ手放すことで、次の流れが入りやすくなります。"
        };

        function getZodiac(month, day) {
          if ((month === 3 && day >= 21) || (month === 4 && day <= 19)) return "牡羊座";
          if ((month === 4 && day >= 20) || (month === 5 && day <= 20)) return "牡牛座";
          if ((month === 5 && day >= 21) || (month === 6 && day <= 21)) return "双子座";
          if ((month === 6 && day >= 22) || (month === 7 && day <= 22)) return "蟹座";
          if ((month === 7 && day >= 23) || (month === 8 && day <= 22)) return "獅子座";
          if ((month === 8 && day >= 23) || (month === 9 && day <= 22)) return "乙女座";
          if ((month === 9 && day >= 23) || (month === 10 && day <= 23)) return "天秤座";
          if ((month === 10 && day >= 24) || (month === 11 && day <= 22)) return "蠍座";
          if ((month === 11 && day >= 23) || (month === 12 && day <= 21)) return "射手座";
          if ((month === 12 && day >= 22) || (month === 1 && day <= 19)) return "山羊座";
          if ((month === 1 && day >= 20) || (month === 2 && day <= 18)) return "水瓶座";
          return "魚座";
        }

        const zodiac = getZodiac(month, day);

        const zodiacMessages = {
          "牡羊座": "勢いはある日ですが、先走りすぎるよりも一呼吸置くことで評価が安定します。",
          "牡牛座": "無理に動かすより、今あるものを大切に整えることで流れが良くなります。",
          "双子座": "情報や会話が鍵になる日です。軽やかなやり取りが運をつないでくれます。",
          "蟹座": "安心できる場所を整えることで、本来の力が発揮しやすくなります。",
          "獅子座": "自分らしさを出すことが追い風になりますが、押しつけすぎない柔らかさも大切です。",
          "乙女座": "細かな気づきが武器になります。小さな修正が大きな安定につながります。",
          "天秤座": "人とのバランスを丁寧に取るほど、今日の運気は味方になってくれます。",
          "蠍座": "一つのことに深く向き合うほど、見えていなかった本音が浮かび上がります。",
          "射手座": "前向きな視点が運を動かします。少し先を見る意識が流れを明るくします。",
          "山羊座": "着実さが力になる日です。派手さよりも確実さを優先すると良いでしょう。",
          "水瓶座": "いつもと違う発想が生きる日です。固まったやり方を少し崩すと風通しが良くなります。",
          "魚座": "感受性が高まりやすい日です。優しさを向ける相手を選ぶことが大切です。"
        };

        const strippedName = name.replace(/\s/g, "");
        const nameScore = reduceNumber(
          Array.from(strippedName).reduce((sum, ch) => sum + ch.charCodeAt(0), 0)
        );

        const nameTendencies = {
          1: "外からは意志の強い人、先頭に立てる人として見られやすい傾向があります。",
          2: "外からは穏やかで気配りができる人として受け取られやすい傾向があります。",
          3: "外からは明るく話しやすい人、場を和ませる人として映りやすいです。",
          4: "外からは堅実で信用できる人、任せやすい人として見られやすいです。",
          5: "外からは柔軟で変化に強い人、動きのある人として映りやすいです。",
          6: "外からは面倒見が良く、責任感のある人として見られやすいです。",
          7: "外からは落ち着いていて、物事を深く考える人として見られやすいです。",
          8: "外からは結果に強い人、頼れる人として認識されやすいです。",
          9: "外からは包容力があり、広い視点を持つ人として映りやすいです。"
        };

        const displayName = `${name}さん`;

        const todayResult =
          `${displayName}の今年のイヤーナンバーは「${yearNumber}」。` +
          `今は「${yearThemes[yearNumber]}」の流れにあります。` +
          `今日は無理に大きく動かすより、今の流れに合った一手を選ぶことで、運が自然に開いていきます。`;

        const outerResult =
          `${displayName}は星の配置で見ると「${zodiac}」の気質を持っています。` +
          `${zodiacMessages[zodiac]} ` +
          `${nameTendencies[nameScore]}`;

        const actionResult = yearActions[yearNumber];

        const resultPayload = {
          name: name,
          birthday: birthday,
          gender: gender,
          yearNumber: yearNumber,
          zodiac: zodiac,
          nameScore: nameScore,
          today: todayResult,
          outer: outerResult,
          action: actionResult
        };

        resultHeadArea.innerHTML = `
          <h1 class="fortune-result-title">${displayName}の鑑定結果</h1>
          <p class="fortune-result-message">
            イヤーナンバー・占星術・姓名診断をもとに、今日の流れを読み解きました。
          </p>
        `;

        resultBodyArea.innerHTML = `
          <div class="fortune-result-card">
            <h2>入力情報</h2>
            <p><strong>お名前：</strong>${name}</p>
            <p><strong>生年月日：</strong>${birthday}</p>
            <p><strong>星座：</strong>${zodiac}</p>
            <p><strong>イヤーナンバー：</strong>${yearNumber}</p>
          </div>

          <div class="fortune-result-card">
            <h2>今日の流れ</h2>
            <p>${todayResult}</p>
          </div>

          <div class="fortune-result-card">
            <h2>外側から見える傾向</h2>
            <p>${outerResult}</p>
          </div>

          <div class="fortune-result-card highlight">
            <h2>今日の行動ヒント</h2>
            <p>${actionResult}</p>
          </div>
        `;

        const saveBtn = document.getElementById("saveBtn");
        const saveMessage = document.getElementById("saveMessage");
        const resultActions = document.getElementById("resultActions");

        function renderSavedState() {
          saveMessage.textContent = "鑑定結果を記録しました。";

          if (saveBtn) {
            saveBtn.textContent = "✓ 記録済み";
            saveBtn.disabled = true;
            saveBtn.classList.add("fortune-btn-disabled");
          }

          if (!document.getElementById("historyBtn")) {
            const historyBtn = document.createElement("a");
            historyBtn.href = "/history";
            historyBtn.id = "historyBtn";
            historyBtn.className = "fortune-btn violet";
            historyBtn.textContent = "履歴を見る";
            resultActions.appendChild(historyBtn);
          }
        }

        function isSameResult(a, b) {
          return (
            a &&
            b &&
            a.name === b.name &&
            a.birthday === b.birthday &&
            a.today === b.today &&
            a.outer === b.outer &&
            a.action === b.action
          );
        }

        function alreadySaved() {
          const savedItems = JSON.parse(localStorage.getItem("savedFortunes") || "[]");
          return savedItems.some((item) => isSameResult(item, resultPayload));
        }

        if (alreadySaved()) {
          renderSavedState();
        }

        saveBtn.addEventListener("click", async () => {
          saveMessage.textContent = "";

          const token = localStorage.getItem("token");

          if (!token) {
            sessionStorage.setItem("pendingFortuneResult", JSON.stringify(resultPayload));
            window.location.href = "/login?redirect=/result";
            return;
          }

          if (alreadySaved()) {
            renderSavedState();
            return;
          }

          try {
  const userId =
    localStorage.getItem("user_id") ||
    localStorage.getItem("userId") ||
    localStorage.getItem("loginEmail") ||
    "";

  if (!userId) {
    saveMessage.textContent = "ログイン情報が見つかりません。もう一度ログインしてください。";
    window.location.href = "/login?redirect=/result";
    return;
  }

  const historyId = crypto.randomUUID();
  const createdAt = new Date().toISOString();

  const res = await fetch(
    "https://mydmaywesh.execute-api.ap-northeast-1.amazonaws.com/prod/history",
    {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        user_id: userId,
        history_id: historyId,
        type: "normal",
        source: "free_result",
        title: "今日の鑑定",
        name: resultPayload.name,
        birth_date: resultPayload.birthday,
        gender: resultPayload.gender,
        category: "general",
        status: "completed",
        created_at: createdAt,
        updated_at: createdAt,
        result: resultPayload
      })
    }
  );

  const data = await res.json().catch(() => ({}));

  if (!res.ok) {
    throw new Error(data?.message || data?.error || "履歴保存に失敗しました。");
  }

  const savedItems = JSON.parse(localStorage.getItem("savedFortunes") || "[]");

  savedItems.unshift({
    id: historyId,
    createdAt: createdAt,
    ...resultPayload
  });

  localStorage.setItem("savedFortunes", JSON.stringify(savedItems));

  renderSavedState();
} catch (error) {
  console.error(error);
  saveMessage.textContent = error?.message || "保存に失敗しました。";
}
        });

        const premiumBtn = document.getElementById("premiumBtn");
        premiumBtn.addEventListener("click", () => {
          const currentToken = localStorage.getItem("token");

          if (currentToken) {
            window.location.href = "/premium";
          } else {
            window.location.href = "/login?redirect=/premium";
          }
        });
      }
    </script>
  </body>
</html>