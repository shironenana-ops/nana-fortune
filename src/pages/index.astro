---
import "../styles/global.css";

const siteTitle = "白音七";
const siteCatch = "今日のあなたに静かな灯りを 名前と生年月日から今の流れと次の一歩を読み解く占い";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle} | TOP</title>
    <meta name="description" content={siteCatch} />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/diagnosis">今日の鑑定</a>
          <a href="/types">属性</a>
          <a href="/compat">相性占い</a>
          <a href="/history">履歴一覧</a>
          <span id="memberLinks"></span>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main>
      <section class="fortune-hero top-hero">
        <div class="fortune-container">
          <div class="fortune-hero-frame top-hero-frame">
            <div class="fortune-hero-ornament" aria-hidden="true"></div>

            <div class="top-hero-layout">
              <div class="fortune-hero-main top-hero-main">
              <div class="fortune-kicker">白音七メソッド</div>

              <div class="fortune-title-wrap">
                <div class="fortune-stars" aria-hidden="true">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>

                <div class="fortune-title-line"></div>

                <h1 class="fortune-hero-title">
                  <span class="line line-1">今日のあなたに</span>
                  <span class="line line-2">静かな灯りを</span>
                  <span class="line line-3">迷う日も 疲れた日も</span>
                  <span class="line line-4">次の一歩をそっと照らします</span>
                </h1>

                <div class="fortune-title-line bottom"></div>
              </div>

              <p class="fortune-lead top-lead">
                こわい言葉で決めつけず<br />
                今日のあなたに静かに寄り添います
              </p>

              <p class="fortune-method-line top-method-line">
                名前と生年月日から、今日のテーマ・心の向き・外から見えるあなた・避けたいことを読み解きます。<br />
                結果は会員登録で履歴として残せます。
              </p>

              <div class="top-answer-strip" aria-label="白音七でわかること">
                <span>今日の流れ</span>
                <span>外から見える傾向</span>
                <span>行動ヒント</span>
                <span>避けたいこと</span>
              </div>

              <div class="top-cta-panel">
                <a class="top-cta-card top-cta-card--primary" href="/diagnosis">
                  <span class="top-cta-kicker">まずは無料</span>
                  <strong>今日の占いをはじめる</strong>
                  <small>名前と生年月日だけで鑑定</small>
                </a>

                <a class="top-cta-card top-cta-card--types" href="/types">
                  <span class="top-cta-kicker">無料で読む</span>
                  <strong>属性を見る</strong>
                  <small>あなたの属性を知る入口</small>
                </a>

                <a class="top-cta-card top-cta-card--violet" href="/compat">
                  <span class="top-cta-kicker">関係を見る</span>
                  <strong>相性占いへ</strong>
                  <small>恋愛 夫婦 家族 仕事仲間にも</small>
                </a>

                <a class="top-cta-card top-cta-card--ghost" href="/members" id="heroMemberBtn">
                  <span class="top-cta-kicker">記録する</span>
                  <strong>会員ページへ</strong>
                  <small>履歴を保存して読み返す</small>
                </a>
              </div>

              <p class="top-beta-note">
                現在は、無料で触れられる鑑定と履歴機能を中心に公開しています。<br />
                一部の深い鑑定は<br />
                今後段階的に整えていきます
              </p>
              </div>

              <div class="top-hero-visual" aria-hidden="true">
                <img src="/images/door.png" alt="" loading="eager" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="fortune-section top-sample-section">
        <div class="fortune-container">
          <div class="fortune-section-frame top-sample-frame">
            <div class="top-section-head">
              <div>
                <div class="section-title-with-icon">
                  <img src="/images/moon1.png" alt="" class="top-heading-icon" loading="lazy" />
                  <div>
                    <div class="fortune-kicker">SAMPLE READING</div>
                    <h2 class="fortune-section-title">鑑定で届く言葉</h2>
                  </div>
                </div>
              </div>
              <p class="fortune-section-sub">
                説明だけではなく<br />
                実際の鑑定に近い形で結果をお届けします
              </p>
            </div>

            <div class="top-sample-result">
              <article class="sample-main-card">
                <div class="sample-date">今日の鍵</div>
                <h3>整える日</h3>
                <p>
                  あれこれ広げるより、今あるものを並べ直す日。<br />
                  急がず、ひとつだけ選ぶことで流れが戻ります。
                </p>
              </article>

              <div class="sample-mini-grid">
                <article>
                  <span>外から見えるあなた</span>
                  <p>穏やかだけど芯が強い人</p>
                </article>

                <article>
                  <span>心の向き</span>
                  <p>本音を隠すより小さく出すと整う</p>
                </article>

                <article>
                  <span>行動ヒント</span>
                  <p>今日やることをひとつだけ決める</p>
                </article>

                <article>
                  <span>避けたいこと</span>
                  <p>相手に合わせすぎて自分を消すこと</p>
                </article>
              </div>
            </div>

            <div class="top-sample-actions">
              <a class="fortune-btn primary" href="/diagnosis">自分の今日を見てみる</a>
            </div>
          </div>
        </div>
      </section>

      <section class="fortune-section top-menu-section">
        <div class="fortune-container">
          <div class="fortune-section-frame">
            <div class="top-section-head">
              <div>
                <div class="fortune-kicker">WHAT YOU CAN DO</div>
                <h2 class="fortune-section-title">白音七でできること</h2>
              </div>
              <p class="fortune-section-sub">
                読まなくても、何をする場所なのか分かるように。<br />
                属性、今日の占い、相性、履歴、会員登録を入口として用意しています。
              </p>
            </div>

            <div class="top-visual-menu">
              <a class="visual-menu-card" href="/types">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/moon2.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>属性診断</h3>
                  <p>生年月日からあなたの属性を読む</p>
                </div>
              </a>

              <a class="visual-menu-card" href="/diagnosis">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/moon1.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>今日の占い</h3>
                  <p>今日の流れと行動ヒントを見る</p>
                </div>
              </a>

              <a class="visual-menu-card" href="/compat">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/moon2.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>相性占い</h3>
                  <p>気になる人との関係を静かに読む</p>
                </div>
              </a>

              <a class="visual-menu-card" href="/history">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/book.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>鑑定履歴</h3>
                  <p>過去の自分の流れを残す</p>
                </div>
              </a>

              <a class="visual-menu-card" href="/join">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/door.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>会員登録</h3>
                  <p>結果を記録してあとから読み返す</p>
                </div>
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="fortune-section top-status-section">
        <div class="fortune-container">
          <div class="fortune-section-frame">
            <div class="top-section-head">
              <div>
                <div class="fortune-kicker">SHIRONE GUIDE</div>
                <h2 class="fortune-section-title">今ご利用いただけること</h2>
              </div>
              <p class="fortune-section-sub">
                安心して試せるよう、使える範囲を分けて案内しています。
              </p>
            </div>

            <div class="top-status-grid">
              <article class="status-card available">
                <div class="status-label">今すぐ無料</div>
                <h3>無料でできること</h3>
                <ul>
                  <li>今日の占い</li>
                  <li>属性診断</li>
                  <li>相性占い</li>
                  <li>鑑定結果の表示</li>
                </ul>
              </article>

              <article class="status-card member">
                <div class="status-label">会員登録</div>
                <h3>登録するとできること</h3>
                <ul>
                  <li>鑑定履歴の保存</li>
                  <li>過去結果の読み返し</li>
                  <li>履歴の削除</li>
                </ul>
              </article>

              <article class="status-card preparing">
                <div class="status-label">これから整えること</div>
                <h3>正式公開に向けて少しずつ整えています</h3>
                <ul>
                  <li>音声鑑定</li>
                  <li>深掘り鑑定</li>
                  <li>有料プラン</li>
                </ul>
              </article>
            </div>

            <p class="top-safe-note">
              一部の深い鑑定は<br />
              今後段階的に整えていきます<br />
              必要なところから 少しずつお使いいただけます
            </p>
          </div>
        </div>
      </section>

      <section class="fortune-section">
        <div class="fortune-container">
          <div class="fortune-section-frame">
            <div class="top-section-head">
              <div>
                <div class="fortune-kicker">SHIRONE7 METHOD</div>
                <h2 class="fortune-section-title">白音七ならではの読み解き</h2>
              </div>
              <p class="fortune-section-sub">
                結果を断定するのではなく、今日の行動へ落とし込む。<br />
                そして履歴として残し、自分の流れをあとから見返せるようにします。
              </p>
            </div>

            <div class="method-visual-callout">
              <div>
                <p>
                  白音七は、占いを一度きりの結果ではなく、
                  今日の自分を見つめるための小さな記録として扱います。
                </p>
              </div>
              <img src="/images/book.png" alt="" loading="lazy" />
            </div>

            <div class="fortune-grid-3">
              <article class="fortune-card glow">
                <div class="fortune-number">1</div>
                <h3>断定しない</h3>
                <p>
                  良い悪いで終わらせず、今の状態をやさしく整理します。
                </p>
              </article>

              <article class="fortune-card glow">
                <div class="fortune-number">2</div>
                <h3>行動に変える</h3>
                <p>
                  今日どう過ごすか、何を避けるかまで短く受け取れます。
                </p>
              </article>

              <article class="fortune-card glow">
                <div class="fortune-number">3</div>
                <h3>記録して育てる</h3>
                <p>
                  一度きりで終わらせず、履歴から自分の変化を見返せます。
                </p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="fortune-bottom-cta">
        <div class="fortune-container">
          <div class="fortune-bottom-cta-frame">
            <h2>今日の流れを見てみませんか</h2>
            <p>
              迷った朝に<br />
              なんとなく不安な日に<br />
              まずは今の自分を静かに確認してみてください
            </p>

            <div class="fortune-bottom-actions" id="bottomCtaActions">
              <a class="fortune-btn primary" href="/diagnosis">今日の占いをはじめる</a>
              <a class="fortune-btn secondary" href="/login?redirect=/members">記録を残す</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="fortune-footer">
      <div class="fortune-container fortune-footer-inner">
        <div>© {new Date().getFullYear()} 白音七</div>

        <div class="fortune-footer-links">
          <a href="/">TOP</a>
          <a href="/types">属性診断</a>
          <a href="/members">会員ページ</a>
          <a href="/history">履歴一覧</a>
          <a href="/terms">利用規約</a>
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/commercial-transactions">特定商取引法に基づく表記</a>
          <a href="/disclaimer">免責事項</a>
          <a href="/contact">お問い合わせ</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const authArea = document.getElementById("authArea");
      const memberLinks = document.getElementById("memberLinks");
      const bottomCtaActions = document.getElementById("bottomCtaActions");
      const heroMemberBtn = document.getElementById("heroMemberBtn");

      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      if (token && email) {
        if (memberLinks) {
          memberLinks.innerHTML = `
            <a href="/members">会員ページ</a>
          `;
        }

        if (authArea) {
          authArea.innerHTML = `
            <span class="fortune-user">${escapeHtml(email)}</span>
            <button id="logoutBtn" class="fortune-nav-logout" type="button">ログアウト</button>
          `;
        }

        const logoutBtn = document.getElementById("logoutBtn");
        if (logoutBtn) {
          logoutBtn.addEventListener("click", () => {
            localStorage.removeItem("token");
            localStorage.removeItem("loginEmail");
            localStorage.removeItem("userId");
            localStorage.removeItem("user_id");
            window.location.href = "/";
          });
        }

        if (bottomCtaActions) {
          bottomCtaActions.innerHTML = `
            <a class="fortune-btn primary" href="/diagnosis">今日の占いをはじめる</a>
            <a class="fortune-btn violet" href="/compat">相性占いへ</a>
            <a class="fortune-btn secondary" href="/members">会員ページへ</a>
          `;
        }

        if (heroMemberBtn) {
          heroMemberBtn.href = "/members";
          heroMemberBtn.innerHTML = `
            <span class="top-cta-kicker">記録する</span>
            <strong>会員ページへ</strong>
            <small>履歴を保存して読み返す</small>
          `;
        }
      } else {
        if (memberLinks) {
          memberLinks.innerHTML = `
            <a href="/join" class="fortune-btn gold">会員登録</a>
          `;
        }

        if (authArea) {
          authArea.innerHTML = `
            <a href="/login?redirect=/members" class="fortune-nav-pill">会員ログイン</a>
          `;
        }

        if (bottomCtaActions) {
          bottomCtaActions.innerHTML = `
            <a class="fortune-btn primary" href="/diagnosis">今日の占いをはじめる</a>
            <a class="fortune-btn violet" href="/compat">相性占いへ</a>
            <a href="/join" class="fortune-btn gold">会員登録</a>
          `;
        }

        if (heroMemberBtn) {
          heroMemberBtn.href = "/login?redirect=/members";
          heroMemberBtn.innerHTML = `
            <span class="top-cta-kicker">記録する</span>
            <strong>会員ログイン</strong>
            <small>履歴を残すにはログイン</small>
          `;
        }
      }
    </script>

    <style is:global>
      .top-hero-frame {
        position: relative;
        overflow: hidden;
      }

      .top-hero-main {
        max-width: 920px;
      }

      .top-lead {
        font-size: clamp(1rem, 2vw, 1.2rem);
      }

      .fortune-hero-title .line-4 {
        font-size: clamp(1.75rem, 4vw, 3.3rem);
      }

      .top-method-line {
        max-width: 780px;
      }

      .top-answer-strip {
        margin: 1.15rem 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem 1.05rem;
      }

      .top-answer-strip span {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        min-height: 30px;
        padding: 0;
        border-radius: 0;
        border: 0;
        background: transparent;
        box-shadow: none;
        color: rgba(255, 240, 184, 0.86);
        cursor: default;
        font-size: 0.9rem;
        font-weight: 700;
      }

      .top-answer-strip span::before {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: rgba(229, 190, 74, 0.66);
        box-shadow: 0 0 10px rgba(229, 190, 74, 0.18);
        flex: 0 0 auto;
      }

      .top-actions {
        margin-top: 1.35rem;
      }

      .top-beta-note {
        margin-top: 1rem;
        color: rgba(255, 240, 190, 0.76);
        font-size: 0.92rem;
        line-height: 1.75;
      }

      .top-section-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(240px, 0.78fr);
        gap: 1.3rem;
        align-items: end;
        margin-bottom: 1.35rem;
      }

      .top-section-head .fortune-kicker {
        margin-bottom: 0.7rem;
      }

      .top-section-head .fortune-section-sub {
        margin: 0;
      }

      .top-sample-result {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.45fr);
        gap: 1rem;
        align-items: stretch;
      }

      .visual-menu-card {
        border: 1px solid rgba(224, 184, 72, 0.28);
        border-radius: 22px;
        background:
          linear-gradient(145deg, rgba(15, 19, 42, 0.94), rgba(16, 14, 34, 0.9));
        box-shadow: 0 22px 60px rgba(0, 0, 0, 0.22);
      }

      .sample-main-card {
        padding: 0.35rem 0 0.35rem 1.15rem;
        border: 0;
        border-left: 1px solid rgba(224, 184, 72, 0.28);
        border-radius: 0;
        background: transparent;
        box-shadow: none;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .sample-date {
        width: fit-content;
        border: 0;
        border-radius: 0;
        padding: 0;
        color: #ffe58f;
        font-size: 0.78rem;
        font-weight: 700;
        margin-bottom: 0.9rem;
      }

      .sample-main-card h3 {
        margin: 0 0 0.7rem;
        color: #fff0b8;
        font-size: clamp(1.7rem, 4vw, 2.5rem);
      }

      .sample-main-card p,
      .sample-mini-grid p,
      .visual-menu-card p,
      .status-card li,
      .top-safe-note {
        color: rgba(255, 240, 190, 0.84);
        line-height: 1.8;
      }

      .sample-mini-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0;
      }

      .sample-mini-grid article {
        padding: 0.95rem 0;
        border: 0;
        border-top: 1px solid rgba(224, 184, 72, 0.16);
        border-radius: 0;
        background: transparent;
        box-shadow: none;
        cursor: default;
      }

      .sample-mini-grid article:nth-child(odd) {
        padding-right: 1rem;
      }

      .sample-mini-grid article:nth-child(even) {
        padding-left: 1rem;
      }

      .sample-mini-grid span {
        display: block;
        margin-bottom: 0.5rem;
        color: #e5be4a;
        font-size: 0.84rem;
        font-weight: 800;
      }

      .sample-mini-grid p {
        margin: 0;
        font-weight: 700;
      }

      .top-sample-actions {
        margin-top: 1.25rem;
        display: flex;
        justify-content: center;
      }

      .top-visual-menu {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
      }

      .visual-menu-card {
        display: grid;
        gap: 0.95rem;
        padding: 1.1rem;
        text-decoration: none;
        transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
      }

      .visual-menu-card:hover {
        transform: translateY(-3px);
        border-color: rgba(255, 226, 133, 0.58);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
      }

      .visual-illustration {
        min-height: 112px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background:
          radial-gradient(circle at 50% 40%, rgba(229, 190, 74, 0.14), transparent 58%),
          radial-gradient(circle at 20% 15%, rgba(144, 95, 255, 0.18), transparent 45%),
          rgba(255, 255, 255, 0.025);
        overflow: hidden;
      }

      .visual-illustration svg {
        width: 86px;
        height: 86px;
        fill: none;
        stroke: #f2dd9a;
        stroke-width: 4;
        stroke-linecap: round;
        stroke-linejoin: round;
