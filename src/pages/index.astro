---
import "../styles/global.css";
import SeoHead from "../components/SeoHead.astro";

const siteTitle = "白音七";
const pageTitle = "白音七｜名前と生年月日から今日を読み解く静かな占い";
const pageDescription =
  "白音七は、名前と生年月日から今日の流れや心の向きを静かに読み解くWeb鑑定サービスです。無料鑑定、属性診断、相性占いをお試しいただけます。";
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://www.nana-fortune.com/#website",
      name: siteTitle,
      url: "https://www.nana-fortune.com/",
      description:
        "名前と生年月日から今日の流れや心の向きを静かに読み解くWeb鑑定サービスです。",
      inLanguage: "ja",
    },
    {
      "@type": "Organization",
      "@id": "https://www.nana-fortune.com/#organization",
      name: siteTitle,
      url: "https://www.nana-fortune.com/",
      sameAs: ["https://x.com/shirone_nana"],
    },
  ],
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead title={pageTitle} description={pageDescription} jsonLd={jsonLd} />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/diagnosis">今日の鑑定</a>
          <a href="/types">属性一覧</a>
          <a href="/compat">相性占い</a>
          <a href="/history">履歴一覧</a>
          <span id="memberLinks"></span>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main>
      <section class="fortune-hero top-hero">
        <div class="fortune-container">
          <div class="fortune-hero-frame top-hero-frame">
            <div class="fortune-hero-ornament" aria-hidden="true"></div>

            <div class="top-hero-layout">
              <div class="top-hero-visual-banner">
                <picture>
                  <source
                    media="(max-width: 720px)"
                    srcset="/images/shirone-nana-hero-960.webp"
                    type="image/webp"
                  />
                  <source srcset="/images/shirone-nana-hero.webp" type="image/webp" />
                  <img
                    src="/images/shirone-nana-hero.png"
                    alt="七つの属性の光を導く白音七"
                    width="1672"
                    height="941"
                    fetchpriority="high"
                  />
                </picture>

                <div class="fortune-hero-main top-hero-main">
                <div class="fortune-kicker">白音七式 星音術</div>

                <div class="fortune-title-wrap">
                  <div class="fortune-stars" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>

                  <div class="fortune-title-line"></div>

                  <h1 class="fortune-hero-title">
                    <span class="line line-1">生年月日から</span>
                    <span class="line line-2">あなたの属性を読み解きます</span>
                  </h1>

                  <div class="fortune-title-line bottom"></div>
                </div>

                <p class="fortune-lead top-lead">
                  自分はどんな性質を持ち<br />
                  何を意識すると歩きやすいのか<br />
                  七つの属性からお届けします
                </p>

                <div class="top-answer-strip" aria-label="この鑑定でわかること">
                  <span>白音七属性</span>
                  <span>あなたの本質</span>
                  <span>性質の生かし方</span>
                </div>

                </div>
              </div>

              <div class="top-quick-column">
                <section class="top-quick-card" aria-labelledby="topQuickHeading">
                  <div class="top-quick-card-head">
                    <div>
                      <div class="top-quick-eyebrow">FREE READING</div>
                      <h2 id="topQuickHeading">あなたの属性を知る</h2>
                    </div>
                    <span class="top-quick-free">無料・登録不要</span>
                  </div>

                  <p class="top-quick-privacy">
                    この簡易鑑定の入力内容と結果は保存されません
                  </p>

                  <form id="topQuickForm" class="top-quick-form" novalidate>
                    <div class="top-quick-field">
                      <label for="topQuickBirthday">生年月日</label>
                      <input
                        id="topQuickBirthday"
                        name="birthday"
                        type="date"
                        min="1900-01-01"
                        aria-describedby="topQuickBirthdayError"
                        required
                      />
                      <p id="topQuickBirthdayError" class="top-quick-error" aria-live="polite"></p>
                    </div>

                    <button type="submit" class="fortune-btn primary top-quick-submit">
                      自分の属性を見る
                    </button>
                  </form>

                  <div
                    id="topQuickResult"
                    class="top-quick-result"
                    aria-live="polite"
                    aria-atomic="true"
                    tabindex="-1"
                    hidden
                  >
                    <div class="top-quick-result-kicker">YOUR SHIRONE TYPE</div>

                    <article class="top-quick-result-main top-quick-identity">
                      <div id="topQuickIcon" class="top-quick-type-icon" aria-hidden="true"></div>
                      <div>
                        <span>あなたの属性</span>
                        <h3 id="topQuickTypeName"></h3>
                        <p id="topQuickPhaseName" class="top-quick-phase"></p>
                      </div>
                    </article>

                    <article class="top-quick-detail">
                      <h3>あなたはこんな人</h3>
                      <div id="topQuickIdentity"></div>
                    </article>

                    <article class="top-quick-detail">
                      <h3>得意なこと</h3>
                      <p id="topQuickStrengths"></p>
                    </article>

                    <article class="top-quick-detail top-quick-guidance">
                      <h3>この性質を生かすために</h3>
                      <p id="topQuickGuidance"></p>
                      <p id="topQuickCautions"></p>
                    </article>

                    <p class="top-quick-next-note">
                      基本属性が分かったら、お名前の響きと今日の流れを重ねて、<br class="pc-only" />
                      今のあなたをもう少し詳しく読み解けます。
                    </p>

                    <nav class="top-quick-links" aria-label="鑑定結果から次へ進む">
                      <a href="/diagnosis" class="fortune-btn primary">今日の詳しい鑑定を見る</a>
                    </nav>
                  </div>
                </section>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="fortune-section top-sample-section">
        <div class="fortune-container">
          <div class="fortune-section-frame top-sample-frame">
            <div class="top-section-head">
              <div>
                <div class="section-title-with-icon">
                  <img src="/images/moon1.png" alt="" class="top-heading-icon" loading="lazy" />
                  <div>
                    <div class="fortune-kicker">SAMPLE READING</div>
                    <h2 class="fortune-section-title">鑑定で届く言葉</h2>
                  </div>
                </div>
              </div>
              <p class="fortune-section-sub">
                説明だけではなく<br />
                実際の鑑定に近い形で結果をお届けします
              </p>
            </div>

            <div class="top-sample-result">
              <article class="sample-main-card">
                <div class="sample-date">今日の鍵</div>
                <h3>整える日</h3>
                <p>
                  あれこれ広げるより、今あるものを並べ直す日。<br />
                  急がず、ひとつだけ選ぶことで流れが戻ります。
                </p>
              </article>

              <div class="sample-mini-grid">
                <article>
                  <span>外から見えるあなた</span>
                  <p>穏やかだけど芯が強い人</p>
                </article>

                <article>
                  <span>心の向き</span>
                  <p>本音を隠すより小さく出すと整う</p>
                </article>

                <article>
                  <span>行動ヒント</span>
                  <p>今日やることをひとつだけ決める</p>
                </article>

                <article>
                  <span>避けたいこと</span>
                  <p>相手に合わせすぎて自分を消すこと</p>
                </article>
              </div>
            </div>

            <div class="top-sample-actions">
              <a class="fortune-btn primary" href="/diagnosis">自分の今日を見てみる</a>
            </div>
          </div>
        </div>
      </section>

      <section class="fortune-section top-menu-section">
        <div class="fortune-container">
          <div class="fortune-section-frame">
            <div class="top-section-head">
              <div>
                <div class="fortune-kicker">WHAT YOU CAN DO</div>
                <h2 class="fortune-section-title">白音七でできること</h2>
              </div>
              <p class="fortune-section-sub">
                読まなくても、何をする場所なのか分かるように。<br />
                今日の占い、属性、相性、履歴、会員登録を入口として用意しています。
              </p>
            </div>

            <div class="top-visual-menu">
              <a class="visual-menu-card" href="/diagnosis">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/moon1.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>今日の占い</h3>
                  <p>今日の流れと行動ヒントを見る</p>
                </div>
              </a>

              <a class="visual-menu-card" href="/types">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/moon2.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>属性診断</h3>
                  <p>生年月日からあなたの属性を読む</p>
                </div>
              </a>

              <a class="visual-menu-card" href="/compat">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/moon2.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>相性占い</h3>
                  <p>気になる人との関係を静かに読む</p>
                </div>
              </a>

              <a class="visual-menu-card" href="/history">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/book.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>鑑定履歴</h3>
                  <p>過去の自分の流れを残す</p>
                </div>
              </a>

              <a class="visual-menu-card" href="/join">
                <div class="visual-illustration image-illustration" aria-hidden="true">
                  <img src="/images/door.png" alt="" loading="lazy" />
                </div>
                <div>
                  <h3>会員登録</h3>
                  <p>結果を記録してあとから読み返す</p>
                </div>
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="fortune-section top-status-section">
        <div class="fortune-container">
          <div class="fortune-section-frame">
            <div class="top-section-head">
              <div>
                <div class="fortune-kicker">SHIRONE GUIDE</div>
                <h2 class="fortune-section-title">今ご利用いただけること</h2>
              </div>
              <p class="fortune-section-sub">
                安心して試せるよう、使える範囲を分けて案内しています。
              </p>
            </div>

            <div class="top-status-grid">
              <article class="status-card available">
                <div class="status-label">今すぐ無料</div>
                <h3>無料でできること</h3>
                <ul>
                  <li>今日の占い</li>
                  <li>属性診断</li>
                  <li>相性占い</li>
                  <li>鑑定結果の表示</li>
                </ul>
              </article>

              <article class="status-card member">
                <div class="status-label">会員登録</div>
                <h3>登録するとできること</h3>
                <ul>
                  <li>鑑定履歴の保存</li>
                  <li>過去結果の読み返し</li>
                  <li>履歴の削除</li>
                </ul>
              </article>

              <article class="status-card preparing">
                <div class="status-label">これから整えること</div>
                <h3>正式公開に向けて少しずつ整えています</h3>
                <ul>
                  <li>音声鑑定</li>
                  <li>深掘り鑑定</li>
                  <li>有料プラン</li>
                </ul>
              </article>
            </div>

            <p class="top-safe-note">
              一部の深い鑑定は<br />
              今後段階的に整えていきます<br />
              必要なところから 少しずつお使いいただけます
            </p>
          </div>
        </div>
      </section>

      <section class="fortune-section">
        <div class="fortune-container">
          <div class="fortune-section-frame">
            <div class="top-section-head">
              <div>
                <div class="fortune-kicker">SHIRONE SEION METHOD</div>
                <h2 class="fortune-section-title">白音七ならではの読み解き</h2>
              </div>
              <p class="fortune-section-sub">
                結果を断定するのではなく、今日の行動へ落とし込む。<br />
                そして履歴として残し、自分の流れをあとから見返せるようにします。
              </p>
            </div>

            <div class="method-visual-callout">
              <div>
                <p>
                  白音七式 星音術は、名前の響き 生年月日の数字 星の流れ 白音七属性を重ねて、
                  今日のあなたを静かに読み解く独自の鑑定法です。
                </p>
              </div>
              <img src="/images/book.png" alt="" loading="lazy" />
            </div>

            <div class="fortune-grid-3">
              <article class="fortune-card glow">
                <div class="fortune-number">1</div>
                <h3>断定しない</h3>
                <p>
                  良い悪いで終わらせず、今の状態をやさしく整理します。
                </p>
              </article>

              <article class="fortune-card glow">
                <div class="fortune-number">2</div>
                <h3>行動に変える</h3>
                <p>
                  今日どう過ごすか、何を避けるかまで短く受け取れます。
                </p>
              </article>

              <article class="fortune-card glow">
                <div class="fortune-number">3</div>
                <h3>記録して育てる</h3>
                <p>
                  一度きりで終わらせず、履歴から自分の変化を見返せます。
                </p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="fortune-bottom-cta">
        <div class="fortune-container">
          <div class="fortune-bottom-cta-frame">
            <h2>今日の流れを見てみませんか</h2>
            <p>
              迷った朝に<br />
              なんとなく不安な日に<br />
              まずは今の自分を静かに確認してみてください
            </p>

            <div class="fortune-bottom-actions" id="bottomCtaActions">
              <a class="fortune-btn primary" href="/diagnosis">今日の占いをはじめる</a>
              <a class="fortune-btn secondary" href="/login?redirect=/members">記録を残す</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="fortune-footer">
      <div class="fortune-container fortune-footer-inner">
        <div>© {new Date().getFullYear()} 白音七</div>

        <div class="fortune-footer-links">
          <a href="/">TOP</a>
          <a href="/types">属性診断</a>
          <a href="/members">会員ページ</a>
          <a href="/history">履歴一覧</a>
          <a href="/terms">利用規約</a>
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/commercial-transactions">特定商取引法に基づく表記</a>
          <a href="/disclaimer">免責事項</a>
          <a href="/contact">お問い合わせ</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const authArea = document.getElementById("authArea");
      const memberLinks = document.getElementById("memberLinks");
      const bottomCtaActions = document.getElementById("bottomCtaActions");
      const heroMemberBtn = document.getElementById("heroMemberBtn");

      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      if (token && email) {
        if (memberLinks) {
          memberLinks.innerHTML = `
            <a href="/members">会員ページ</a>
          `;
        }

        if (authArea) {
          authArea.innerHTML = `
            <span class="fortune-user">${escapeHtml(email)}</span>
            <button id="logoutBtn" class="fortune-nav-logout" type="button">ログアウト</button>
          `;
        }

        const logoutBtn = document.getElementById("logoutBtn");
        if (logoutBtn) {
          logoutBtn.addEventListener("click", () => {
            localStorage.removeItem("token");
            localStorage.removeItem("loginEmail");
            localStorage.removeItem("userId");
            localStorage.removeItem("user_id");
            window.location.href = "/";
          });
        }

        if (bottomCtaActions) {
          bottomCtaActions.innerHTML = `
            <a class="fortune-btn primary" href="/diagnosis">今日の占いをはじめる</a>
            <a class="fortune-btn violet" href="/compat">相性占いへ</a>
            <a class="fortune-btn secondary" href="/members">会員ページへ</a>
          `;
        }

        if (heroMemberBtn) {
          heroMemberBtn.href = "/members";
          heroMemberBtn.innerHTML = `
            <span class="top-cta-kicker">記録する</span>
            <strong>会員ページへ</strong>
            <small>履歴を保存して読み返す</small>
          `;
        }

      } else {
        if (memberLinks) {
          memberLinks.innerHTML = `
            <a href="/join" class="fortune-btn gold">会員登録</a>
          `;
        }

        if (authArea) {
          authArea.innerHTML = `
            <a href="/login?redirect=/members" class="fortune-nav-pill">会員ログイン</a>
          `;
        }

        if (bottomCtaActions) {
          bottomCtaActions.innerHTML = `
            <a class="fortune-btn primary" href="/diagnosis">今日の占いをはじめる</a>
            <a class="fortune-btn violet" href="/compat">相性占いへ</a>
            <a href="/join" class="fortune-btn gold">会員登録</a>
          `;
        }

        if (heroMemberBtn) {
          heroMemberBtn.href = "/login?redirect=/members";
          heroMemberBtn.innerHTML = `
            <span class="top-cta-kicker">記録する</span>
            <strong>会員ログイン</strong>
            <small>履歴を残すにはログイン</small>
          `;
        }

      }
    </script>

    <script>
      import {
        buildTopQuickReading,
        TopQuickReadingValidationError
      } from "../lib/topQuickReading";

      const quickForm = document.getElementById("topQuickForm");
      const quickBirthday = document.getElementById("topQuickBirthday");
      const quickBirthdayError = document.getElementById("topQuickBirthdayError");
      const quickResult = document.getElementById("topQuickResult");

      function localDateValue(date = new Date()) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const day = String(date.getDate()).padStart(2, "0");
        return `${year}-${month}-${day}`;
      }

      if (quickBirthday instanceof HTMLInputElement) {
        quickBirthday.max = localDateValue();
      }

      function clearQuickErrors() {
        if (quickBirthdayError) quickBirthdayError.textContent = "";
        quickBirthday?.removeAttribute("aria-invalid");
      }

      function showQuickError(message) {
        if (quickBirthdayError) quickBirthdayError.textContent = message;
        quickBirthday?.setAttribute("aria-invalid", "true");
        quickBirthday?.focus();
      }

      function setResultText(id, value) {
        const element = document.getElementById(id);
        if (element) element.textContent = String(value ?? "");
      }

      quickForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        clearQuickErrors();

        try {
          const result = buildTopQuickReading({
            birthday: quickBirthday instanceof HTMLInputElement ? quickBirthday.value : ""
          });

          setResultText("topQuickIcon", result.icon);
          setResultText("topQuickTypeName", result.typeName);
          setResultText("topQuickPhaseName", result.phaseName);
          setResultText("topQuickStrengths", result.strengths);
          setResultText("topQuickGuidance", result.guidance);
          setResultText("topQuickCautions", result.cautions);

          const identity = document.getElementById("topQuickIdentity");
          if (identity) {
            const paragraphs = result.identitySummary.map((text) => {
              const paragraph = document.createElement("p");
              paragraph.textContent = text;
              return paragraph;
            });
            identity.replaceChildren(...paragraphs);
          }

          if (quickResult) {
            quickResult.hidden = false;
            const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
            quickResult.scrollIntoView({ behavior: reduceMotion ? "auto" : "smooth", block: "start" });
            quickResult.focus({ preventScroll: true });
          }
        } catch (error) {
          if (error instanceof TopQuickReadingValidationError) {
            showQuickError(error.message);
            return;
          }

          showQuickError("入力内容を確認してください。");
        }
      });
    </script>

    <style is:global>
      .top-hero-frame {
        position: relative;
        overflow: hidden;
      }

      .top-hero-main {
        max-width: 920px;
      }

      .top-lead {
        font-size: clamp(1rem, 2vw, 1.2rem);
      }

      .fortune-hero-title .line-4 {
        font-size: clamp(1.75rem, 4vw, 3.3rem);
      }

      .top-method-line {
        max-width: 780px;
      }

      .top-answer-strip {
        margin: 1.15rem 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem 1.05rem;
      }

      .top-answer-strip span {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        min-height: 30px;
        padding: 0;
        border-radius: 0;
        border: 0;
        background: transparent;
        box-shadow: none;
