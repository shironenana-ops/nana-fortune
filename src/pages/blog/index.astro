---
import "../../styles/global.css";

const siteTitle = "白音七";
const siteCatch = "白音七からのお知らせや開発記録を少しずつ届ける場所です";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>占い日記 | {siteTitle}</title>
    <meta name="description" content={siteCatch} />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/history">履歴一覧</a>
          <span id="memberLinks"></span>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main class="blog-coming-soon-page">
      <section class="fortune-container blog-coming-soon-shell">
        <div class="blog-coming-soon-hero">
          <span class="blog-label">FORTUNE DIARY</span>

          <h1>
            白音七からのお知らせを<br />
            少しずつ届けます
          </h1>

          <p>
            日々の流れや整えごとを<br />
            静かに残していく場所です
          </p>

          <div class="blog-note">
            <p>
              今はまず<br />
              今日の鑑定と履歴保存からお使いいただけます
            </p>
          </div>

          <div class="blog-actions">
            <a href="/diagnosis" class="fortune-btn primary">今日の占いへ</a>
            <a href="/history" class="fortune-btn ghost">履歴を見る</a>
            <a href="/" class="fortune-btn ghost">TOPへ戻る</a>
          </div>
        </div>

        <section class="blog-preview-card">
          <div class="blog-preview-head">
            <span class="blog-label">NEXT NOTES</span>
            <h2>これから届けていくこと</h2>
          </div>

          <div class="blog-preview-grid">
            <article class="blog-preview-item">
              <span>01</span>
              <h3>日々の占い記録</h3>
              <p>今日の流れを残しながら変化を見返せるようにします</p>
            </article>

            <article class="blog-preview-item">
              <span>02</span>
              <h3>白音七メソッド解説</h3>
              <p>数秘術や占星術を日常に落とし込む読み方を整えます</p>
            </article>

            <article class="blog-preview-item">
              <span>03</span>
              <h3>お知らせ</h3>
              <p>機能追加や改善の流れをここで確認できるようにします</p>
            </article>
          </div>
        </section>
      </section>
    </main>

    <footer class="fortune-footer">
      <div class="fortune-container fortune-footer-inner">
        <p>© 2026 白音七</p>
        <nav>
          <a href="/">TOP</a>
          <a href="/members">会員ページ</a>
          <a href="/history">履歴一覧</a>
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/disclaimer">免責事項</a>
          <a href="/contact">お問い合わせ</a>
        </nav>
      </div>
    </footer>

    <script is:inline>
      const memberLinks = document.getElementById("memberLinks");
      const authArea = document.getElementById("authArea");
      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      if (token && email) {
        if (memberLinks) {
          memberLinks.innerHTML = `
            <a href="/members">会員ページ</a>
            <a href="/diagnosis">会員限定鑑定</a>
          `;
        }

        if (authArea) {
          authArea.innerHTML = `
            <span class="fortune-user">${email}</span>
            <button id="logoutBtn" class="fortune-nav-logout">ログアウト</button>
          `;
        }

        const logoutBtn = document.getElementById("logoutBtn");
        if (logoutBtn) {
          logoutBtn.addEventListener("click", () => {
            localStorage.removeItem("token");
            localStorage.removeItem("loginEmail");
            localStorage.removeItem("userId");
            window.location.href = "/";
          });
        }
      } else {
        if (memberLinks) {
          memberLinks.innerHTML = "";
        }

        if (authArea) {
          authArea.innerHTML = `
            <a href="/login" class="fortune-nav-pill">会員ログイン</a>
          `;
        }
      }
    </script>

    <style is:global>
      .blog-coming-soon-page {
        min-height: calc(100vh - 80px);
        padding: 4.8rem 0 5rem;
        background:
          radial-gradient(circle at 22% 22%, rgba(144, 95, 255, 0.16), transparent 30%),
          radial-gradient(circle at 70% 16%, rgba(229, 190, 74, 0.10), transparent 26%);
      }

      .blog-coming-soon-shell {
        max-width: 980px;
        display: grid;
        gap: 1.4rem;
      }

      .blog-coming-soon-hero,
      .blog-preview-card {
        border: 1px solid rgba(224, 184, 72, 0.35);
        border-radius: 28px;
        background:
          linear-gradient(145deg, rgba(15, 19, 42, 0.94), rgba(16, 14, 34, 0.92));
        box-shadow: 0 28px 80px rgba(0, 0, 0, 0.28);
      }

      .blog-coming-soon-hero {
        padding: clamp(1.6rem, 5vw, 3rem);
        position: relative;
        overflow: hidden;
      }

      .blog-coming-soon-hero::before {
        content: "";
        position: absolute;
        inset: -30% auto auto 52%;
        width: 360px;
        height: 360px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(229, 190, 74, 0.15), transparent 62%);
        pointer-events: none;
      }

      .blog-label {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        border: 1px solid rgba(224, 184, 72, 0.55);
        border-radius: 999px;
        padding: 0.38rem 0.85rem;
        color: #ffe58f;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
      }

      .blog-coming-soon-hero h1 {
        margin: 1.1rem 0 0.9rem;
        color: #fff0b8;
        font-size: clamp(2rem, 5vw, 3.8rem);
        line-height: 1.18;
        letter-spacing: 0.04em;
        position: relative;
      }

      .blog-coming-soon-hero p,
      .blog-note p,
      .blog-preview-card p {
        color: rgba(255, 240, 190, 0.86);
        line-height: 1.9;
      }

      .blog-note {
        margin-top: 1.4rem;
        max-width: 620px;
        border: 1px solid rgba(144, 95, 255, 0.42);
        border-radius: 18px;
        background: rgba(144, 95, 255, 0.12);
        padding: 1rem 1.15rem;
        position: relative;
      }

      .blog-note p {
        margin: 0;
      }

      .blog-actions {
        margin-top: 1.5rem;
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
        position: relative;
      }

      .blog-preview-card {
        padding: clamp(1.35rem, 4vw, 2rem);
      }

      .blog-preview-head {
        display: grid;
        gap: 0.9rem;
        margin-bottom: 1.15rem;
      }

      .blog-preview-head h2 {
        margin: 0;
        color: #fff0b8;
        font-size: clamp(1.4rem, 3vw, 2rem);
      }

      .blog-preview-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .blog-preview-item {
        border: 1px solid rgba(224, 184, 72, 0.24);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.035);
        padding: 1.15rem;
      }

      .blog-preview-item span {
        display: inline-flex;
        margin-bottom: 0.65rem;
        color: #e5be4a;
        font-weight: 800;
        font-size: 0.78rem;
      }

      .blog-preview-item h3 {
        margin: 0 0 0.45rem;
        color: #fff0b8;
        font-size: 1.05rem;
      }

      .blog-preview-item p {
        margin: 0;
        font-size: 0.9rem;
      }

      @media (max-width: 760px) {
        .blog-coming-soon-page {
          padding: 2rem 0 3.5rem;
        }

        .blog-coming-soon-shell {
          padding-inline: 1rem;
        }

        .blog-preview-grid {
          grid-template-columns: 1fr;
        }

        .blog-actions .fortune-btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </body>
</html>
