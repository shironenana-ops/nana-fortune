---
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>お問い合わせ | 白音七</title>
    <meta
      name="description"
      content="白音七へのお問い合わせページです。ご意見・ご要望・不具合報告などはこちらからご確認ください。"
    />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/diagnosis">今日の鑑定</a>
          <a href="/blog">占い日記</a>
          <a href="/about">白音七とは</a>
          <a href="/compat">相性占い</a>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main class="fortune-result">
      <section class="fortune-container">
        <div class="fortune-result-frame">
          <div class="fortune-detail-kicker">CONTACT</div>

          <h1 class="fortune-result-title">お問い合わせ</h1>

          <p class="fortune-result-message">
            白音七をご覧いただきありがとうございます<br />
            ご意見 ご要望 不具合報告などはこちらからお知らせください
          </p>

          <div class="fortune-result-card highlight">
            <h2>β版について</h2>
            <p>
              現在、白音七はβ版として公開しています。<br />
              表示崩れ、ログインまわり、履歴保存、占い結果の違和感など、
              気づいた点があればぜひお知らせください。
            </p>
          </div>

          <div class="fortune-result-card">
            <h2>お問い合わせ内容の例</h2>
            <p>
              ・ページの表示がおかしい<br />
              ・登録やログインがうまくいかない<br />
              ・鑑定履歴が表示されない<br />
              ・占い結果の文章に違和感がある<br />
              ・正式版で追加してほしい機能がある
            </p>
          </div>

          <div class="fortune-result-card">
            <h2>ご注意ください</h2>
            <p>
              占い内容に関する個別の解釈や、医療・法律・投資に関する判断については、
              お答えできない場合があります。<br />
              重要な判断が必要な場合は、必ず専門家へご相談ください。
            </p>
          </div>

          <div class="fortune-result-card highlight contact-main-card">
            <h2>お問い合わせ先</h2>
            <p>
              β版期間中のお問い合わせは<br />
              XのDMまたは投稿への返信でお知らせください
            </p>

            <div class="contact-actions">
              <a
                href="https://x.com/Kurone46847"
                class="fortune-btn primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                Xで問い合わせる
              </a>
              <a href="/history" class="fortune-btn secondary">履歴を見る</a>
            </div>

            <p class="contact-small-note">
              フォームは正式版に向けて準備中です<br />
              緊急性の高い内容や個別鑑定の詳細相談には対応できない場合があります
            </p>
          </div>

          <div class="fortune-result-actions">
            <a href="/" class="fortune-btn secondary">TOPへ戻る</a>
            <a href="/diagnosis" class="fortune-btn primary">今日の鑑定をする</a>
            <a href="/members" class="fortune-btn violet">会員ページへ</a>
          </div>
        </div>
      </section>
    </main>

    <script is:inline>
      const authArea = document.getElementById("authArea");
      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      if (authArea) {
        if (token && email) {
          authArea.innerHTML = `
            <span class="fortune-user">${email}</span>
            <button id="logoutBtn" class="fortune-nav-logout" type="button">⏻ ログアウト</button>
          `;

          const logoutBtn = document.getElementById("logoutBtn");
          if (logoutBtn) {
            logoutBtn.addEventListener("click", () => {
              localStorage.removeItem("token");
              localStorage.removeItem("loginEmail");
              localStorage.removeItem("user_id");
              localStorage.removeItem("userId");
              window.location.href = "/";
            });
          }
        } else {
          authArea.innerHTML = `
            <a href="/login" class="fortune-nav-pill">会員ログイン</a>
          `;
        }
      }
    </script>

    <style is:global>
      .contact-main-card {
        position: relative;
        overflow: hidden;
      }

      .contact-actions {
        margin-top: 1.15rem;
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
      }

      .contact-small-note {
        margin-top: 1rem;
        color: rgba(255, 240, 190, 0.76);
        font-size: 0.92rem;
      }

      @media (max-width: 760px) {
        .contact-actions .fortune-btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>

  </body>
</html>