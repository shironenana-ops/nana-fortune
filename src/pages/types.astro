---
import "../styles/global.css";
import { shironeTypes } from "../lib/shironeTypes";

const typeIconImages: Record<string, string> = {
  moonlight: "/images/types-icons/moon-lantern.png",
  stargazer: "/images/types-icons/sky-compass.png",
  "water-mirror": "/images/types-icons/water-mirror.png",
  "flower-keeper": "/images/types-icons/sakura-emblem.png",
  windpath: "/images/types-icons/wind-feather.png",
  "fire-knot": "/images/types-icons/fire-knot.png",
  shirone: "/images/types-icons/magic-circle.png",
  sumine: "/images/types-icons/crystal-geometry.png",
  futane: "/images/types-icons/twin-moons.png",
  amane: "/images/types-icons/holy-light.png",
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>白音七 属性診断 | 白音七</title>
    <meta
      name="description"
      content="白音七オリジナルの属性診断。生まれた日の数字から、あなたに宿りやすい属性を読み解きます。"
    />
    <style>
      .shirone-type-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 24px;
        align-items: stretch;
        margin: 28px 0 36px;
      }

      .shirone-type-card {
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        min-height: 214px;
        height: 100%;
        padding: 24px 22px;
        text-decoration: none;
        letter-spacing: 0;
      }

      .shirone-attribute-head {
        display: grid;
        justify-items: center;
        gap: 12px;
        margin-bottom: 16px;
        text-align: center;
      }

      .shirone-attribute-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex: 0 0 auto;
        width: 84px;
        height: 84px;
        border-radius: 26px;
        border: 1px solid rgba(242, 221, 154, 0.42);
        background:
          radial-gradient(circle at 32% 24%, rgba(255, 240, 191, 0.28), transparent 48%),
          rgba(255, 255, 255, 0.045);
        color: #fff0bf;
        font-size: 1.15rem;
        line-height: 1;
        box-shadow: 0 0 22px rgba(202, 168, 79, 0.12);
      }

      .shirone-attribute-icon img {
        display: block;
        width: 88%;
        height: 88%;
        object-fit: contain;
      }

      .shirone-type-card-title {
        display: grid;
        justify-items: center;
        gap: 4px;
      }

      .shirone-type-card-title h2 {
        margin: 0;
        color: #fff0bf;
        font-size: 1.16rem;
      }

      .shirone-type-card-title span {
        color: rgba(255, 236, 179, 0.62);
        font-size: 0.88rem;
      }

      .shirone-type-card-catch {
        margin: 0 0 14px;
        color: #f2dd9a;
        line-height: 1.9;
        letter-spacing: 0;
      }

      .shirone-type-card-meta {
        margin: auto 0 0;
        color: rgba(255, 236, 179, 0.72);
        line-height: 1.95;
        letter-spacing: 0;
      }

      .shirone-type-card-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        align-self: center;
        min-width: 128px;
        margin-top: 18px;
        padding: 9px 18px;
        border-radius: 999px;
        border: 1px solid rgba(242, 221, 154, 0.34);
        background: rgba(255, 255, 255, 0.045);
        color: #fff0bf;
        font-size: 0.92rem;
        line-height: 1.4;
        letter-spacing: 0;
        box-shadow: 0 0 20px rgba(202, 168, 79, 0.1);
      }

      .shirone-type-cta {
        margin-top: 8px;
      }

      .shirone-nav-attribute-menu {
        display: inline-flex;
        align-items: center;
      }

      .shirone-nav-attribute-details {
        display: none;
      }

  .shirone-type-gate {
    display: block;
    width: min(100%, 900px);
    margin: 4px auto 26px;
  }

  .shirone-type-gate__image {
    overflow: hidden;
    width: 100%;
    margin-inline: auto;
    border-radius: 24px;
    border: 1px solid rgba(242, 221, 154, 0.22);
    background: rgba(255, 255, 255, 0.035);
        box-shadow:
          0 18px 44px rgba(0, 0, 0, 0.28),
          0 0 42px rgba(202, 168, 79, 0.12);
        aspect-ratio: 16 / 9;
        max-height: 440px;
      }

  .shirone-type-gate__image img {
    display: block;
    width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .shirone-type-gate__caption {
        margin: 10px 0 0;
        color: rgba(255, 236, 179, 0.72);
        font-size: 0.92rem;
        line-height: 1.8;
        text-align: center;
      }

      .shirone-attribute-guide-visual {
        display: block;
        width: min(100%, 860px);
        margin: 0 auto 26px;
      }

      .shirone-attribute-guide-visual__image {
        overflow: hidden;
        width: 100%;
        margin-inline: auto;
        border-radius: 22px;
        border: 1px solid rgba(242, 221, 154, 0.2);
        background: rgba(255, 255, 255, 0.035);
        box-shadow:
          0 14px 36px rgba(0, 0, 0, 0.22),
          0 0 34px rgba(202, 168, 79, 0.1);
      }

      .shirone-attribute-guide-visual__image img {
        display: block;
        width: 100%;
        height: auto;
      }

      .shirone-type-detail-list {
        display: grid;
        gap: 20px;
        margin-top: 30px;
      }

      .shirone-type-detail-card {
        position: relative;
        overflow: hidden;
        box-sizing: border-box;
        letter-spacing: 0;
      }

      .shirone-type-detail-card p {
        line-height: 1.9;
        letter-spacing: 0;
      }

      .shirone-type-detail-card * {
        box-sizing: border-box;
      }

      .shirone-attribute-detail-head {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 14px 18px;
        margin-bottom: 14px;
      }

      .shirone-attribute-detail-head .shirone-attribute-icon {
        width: 88px;
        height: 88px;
        border-radius: 28px;
      }

      .shirone-attribute-detail-head h2 {
        margin: 0 0 4px;
      }

      .shirone-attribute-reading {
        margin: 0;
        color: rgba(255, 236, 179, 0.68);
        line-height: 1.6;
      }

      .attribute-phase-guide {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 12px;
        margin-top: 16px;
      }

      .attribute-note-card,
      .attribute-phase-guide-card,
      .attribute-detail-section {
        background: transparent;
      }

      .attribute-phase-guide-card {
        padding: 4px 0 4px 14px;
        border-left: 1px solid rgba(202, 168, 79, 0.34);
      }

      .attribute-phase-guide-card strong {
        display: block;
        margin-bottom: 4px;
        color: #f2dd9a;
        font-size: 0.92rem;
        font-weight: 600;
      }

      .attribute-note-card {
        margin: 14px 0 18px;
        padding: 2px 0 2px 14px;
        border-left: 1px solid rgba(202, 168, 79, 0.34);
      }

      .attribute-phase-guide-card h3,
      .attribute-detail-section h4 {
        margin: 0 0 8px;
        color: #fff0bf;
        font-size: 0.96rem;
        font-weight: 600;
        letter-spacing: 0;
      }

      .attribute-phase-guide-card p,
      .attribute-note-card p,
      .attribute-detail-section p {
        margin: 0;
      }

      .attribute-phase-guide-note {
        margin-top: 16px;
      }

      .attribute-detail-sections {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0 22px;
        margin-top: 18px;
        border-top: 1px solid rgba(202, 168, 79, 0.16);
      }

      .attribute-detail-section {
        padding: 17px 0;
        border-bottom: 1px solid rgba(202, 168, 79, 0.12);
      }

      @media (max-width: 640px) {
        .shirone-type-grid {
          grid-template-columns: 1fr;
          gap: 18px;
          margin: 24px 0 32px;
        }

        .shirone-type-card {
          min-height: 0;
        }

        .shirone-attribute-icon {
          width: 76px;
          height: 76px;
          border-radius: 24px;
        }

        .shirone-attribute-detail-head .shirone-attribute-icon {
          width: 78px;
          height: 78px;
          border-radius: 25px;
        }

    .shirone-type-gate {
      width: 100%;
      margin: 0 auto 22px;
    }

        .shirone-attribute-guide-visual {
          width: 100%;
          margin-bottom: 22px;
        }

        .shirone-type-gate__image {
          border-radius: 18px;
          max-height: none;
        }

        .shirone-attribute-guide-visual__image {
          border-radius: 18px;
        }

        .shirone-type-card-title {
          display: block;
        }

        .shirone-type-card-title span {
          display: block;
          margin-top: 4px;
        }

        .shirone-type-detail-list {
          gap: 18px;
          margin-top: 26px;
        }

        .attribute-detail-sections {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 768px) {
        .shirone-nav-attribute-menu {
          display: block;
          width: 100%;
          border-bottom: 1px solid rgba(242, 221, 154, 0.12);
        }

        .shirone-nav-attribute-link {
          display: none;
        }

        .shirone-nav-attribute-details {
          display: block;
          width: 100%;
        }

        .shirone-nav-attribute-details summary {
          display: flex;
          min-height: 44px;
          align-items: center;
          justify-content: space-between;
          padding: 10px 8px;
          color: var(--fortune-text-sub);
          font-size: 0.82rem;
          font-weight: 700;
          cursor: pointer;
          list-style: none;
        }

        .shirone-nav-attribute-details summary::-webkit-details-marker {
          display: none;
        }

        .shirone-nav-attribute-details summary::after {
          content: "開く";
          color: rgba(255, 236, 179, 0.62);
          font-size: 0.76rem;
          font-weight: 600;
        }

        .shirone-nav-attribute-details[open] summary::after {
          content: "閉じる";
        }

        .shirone-nav-attribute-links {
          display: grid;
          grid-template-columns: 1fr;
          gap: 8px;
          padding: 0 8px 12px;
        }

        .fortune-nav .shirone-nav-attribute-links a {
          display: inline-flex;
          width: 100%;
          min-height: 42px;
          align-items: center;
          justify-content: center;
          box-sizing: border-box;
          padding: 8px 10px;
          border: 1px solid rgba(242, 221, 154, 0.18);
          border-radius: 999px;
          background: rgba(255, 255, 255, 0.035);
          color: var(--fortune-gold-light);
          font-size: 0.82rem;
          text-align: center;
        }
      }
    </style>
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <div class="shirone-nav-attribute-menu">
            <a href="/types" class="shirone-nav-attribute-link">属性診断</a>
            <details class="shirone-nav-attribute-details">
              <summary>属性診断</summary>
              <div class="shirone-nav-attribute-links" aria-label="属性詳細へのリンク">
                {shironeTypes.map((type) => (
                  <a href={`#${type.slug}`}>{type.typeName.replace("属性", "")}</a>
                ))}
              </div>
            </details>
          </div>
          <a href="/diagnosis">今日の鑑定</a>
          <a href="/history">履歴一覧</a>
          <a href="/compat">相性占い</a>
          <a href="/contact">お問い合わせ</a>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main class="fortune-result">
      <section class="fortune-container">
        <div class="fortune-result-frame" style="max-width: 980px;">
          <div class="fortune-detail-kicker">SHIRONE ATTRIBUTES</div>

          <h1 class="fortune-result-title">白音七 属性診断</h1>

          <p class="fortune-result-message" style="text-align:center; margin-bottom:26px;">
            生まれた日の数字をほどき<br />
            あなたに宿りやすい属性を<br />
            読み解きます
          </p>

          <figure class="shirone-type-gate" aria-label="白音七の属性図鑑の扉絵">
            <div class="shirone-type-gate__image">
              <img
                src="/images/types-attribute-gate-20260705.png"
                alt="白音七の属性図鑑を象徴する、月と七つの光が浮かぶ神秘的な扉絵"
                loading="eager"
                decoding="async"
              />
            </div>
            <figcaption class="shirone-type-gate__caption">
              七つの光と、あなたの響きが出会う場所。
            </figcaption>
          </figure>

          <figure class="shirone-attribute-guide-visual" aria-label="白音七の属性体系ガイド">
            <div class="shirone-attribute-guide-visual__image">
              <img
                src="/images/types-attribute-guide-20260705.png"
                alt="白音七の基本属性、陽の相と月の相、特別属性をまとめた属性体系ガイド"
                loading="lazy"
                decoding="async"
              />
            </div>
          </figure>

          <div class="fortune-result-card highlight">
            <h2>属性診断について</h2>
            <p>
              白音七の属性診断は<br />
              生年月日から<br />
              あなたに宿りやすい属性を読み解く小さな鑑定です<br /><br />
              これは性格を決めつけるものではなく<br />
              今日の占いを少しだけ<br />
              あなたらしく受け取るための手がかりです<br /><br />
              結果は今日の占いの中で<br />
              あわせてお伝えします
            </p>
          </div>

          <div class="fortune-result-card">
            <h2>属性と相について</h2>
            <div class="attribute-phase-guide">
              <section class="attribute-phase-guide-card">
                <h3>属性</h3>
                <strong>その人が持ちやすい質</strong>
                <p>
                  月灯・星詠・水鏡など、<br />
                  生まれた日に宿りやすい気配を表します。
                </p>
              </section>
              <section class="attribute-phase-guide-card">
                <h3>相</h3>
                <strong>その質のあらわれ方</strong>
                <p>
                  陽の相は外へひらき、<br />
                  行動や表現として出やすい読み方。<br />
                  月の相は内側で深まり、<br />
                  感受性や気配として出やすい読み方です。
                </p>
              </section>
              <section class="attribute-phase-guide-card">
                <h3>読み方</h3>
                <strong>属性と相を重ねる</strong>
                <p>
                  基本属性は、<br />
                  陽の相・月の相を重ねて読みます。<br />
                  澄音・双音・天音は相に分けず、<br />
                  属性そのものの響きとして読みます。
                </p>
              </section>
            </div>
            <p class="attribute-phase-guide-note">
              優劣ではなく、読み方の違いとして扱います。
            </p>
          </div>

          <div class="shirone-type-grid">
            {shironeTypes.map((type) => (
              <a
                href={`#${type.slug}`}
                class="fortune-card shirone-type-card"
              >
                <div class="shirone-attribute-head">
                  <span class="shirone-attribute-icon">
                    <img
                      src={typeIconImages[type.slug]}
                      alt={`${type.typeName}の紋章`}
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                  <div class="shirone-type-card-title">
                    <h2>{type.typeName}</h2>
                    <span>{type.reading}</span>
                  </div>
                </div>
                <p class="shirone-type-card-catch">{type.catchphrase}</p>
                <p class="shirone-type-card-meta">
                  {type.motif}<br />
                  {type.colorsText}<br />
                  {type.kind === "base"
                    ? "陽の相・月の相で読み分けます"
                    : "属性そのものの響きとして読みます"}
                </p>
                <span class="shirone-type-card-link">詳しく見る</span>
              </a>
            ))}
          </div>

          <div class="fortune-result-card highlight shirone-type-cta">
            <h2>わたしの属性を見る</h2>
            <p>
              今日の鑑定では、名前と生年月日から今の流れを読み解きます。<br />
              属性は、これから少しずつ鑑定の読み方にも添えていく予定です。
            </p>
            <div class="fortune-result-actions" style="justify-content:flex-start;">
              <a href="/diagnosis" class="fortune-btn primary">今日の占いへ進む</a>
              <a href="/" class="fortune-btn secondary">TOPへ戻る</a>
            </div>
          </div>

          <section class="shirone-type-detail-list" aria-label="属性の詳細">
            {shironeTypes.map((type) => (
              <article id={type.slug} class="fortune-result-card shirone-type-detail-card" style="scroll-margin-top:96px;">
                <div class="shirone-attribute-detail-head">
                  <span class="shirone-attribute-icon">
                    <img
                      src={typeIconImages[type.slug]}
                      alt={`${type.typeName}の紋章`}
                      loading="lazy"
                      decoding="async"
                    />
                  </span>
                  <div>
                    <h2>{type.typeName}</h2>
                    <p class="shirone-attribute-reading">
                      {type.reading} / {type.slug}
                    </p>
                  </div>
                </div>

                <p style="color:#f2dd9a; font-size:1.02rem;">{type.catchphrase}</p>
                {type.specialNote ? (
                  <div class="attribute-note-card">
                    <p>{type.specialNote}</p>
                  </div>
                ) : null}
                <p>{type.summary}</p>

                <div class="attribute-detail-sections">
                  <section class="attribute-detail-section">
                    <h4>強み</h4>
                    <p>{type.strengths}</p>
                  </section>
                  <section class="attribute-detail-section">
                    <h4>気をつけたいこと</h4>
                    <p>{type.weakness}</p>
                  </section>
                  <section class="attribute-detail-section">
                    <h4>恋愛</h4>
                    <p>{type.love}</p>
                  </section>
                  <section class="attribute-detail-section">
                    <h4>仕事</h4>
                    <p>{type.work}</p>
                  </section>
                  <section class="attribute-detail-section">
                    <h4>人間関係</h4>
                    <p>{type.relationship}</p>
                  </section>
                  <section class="attribute-detail-section">
                    <h4>相性の見方</h4>
                    <p>{type.compatibilityHint}</p>
                  </section>
                </div>

                <p style="white-space:pre-line; color:#f2dd9a; margin-top:14px;">{type.gentleMessage}</p>
              </article>
            ))}
          </section>

          <div class="fortune-result-actions">
            <a href="/diagnosis" class="fortune-btn primary">今日の占いへ進む</a>
            <a href="/compat" class="fortune-btn violet">相性占いを見る</a>
            <a href="/" class="fortune-btn secondary">TOPへ戻る</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="fortune-footer">
      <div class="fortune-container fortune-footer-inner">
        <div>© {new Date().getFullYear()} 白音七</div>
        <nav class="fortune-footer-links" aria-label="フッターナビゲーション">
          <a href="/terms">利用規約</a>
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/commercial-transactions">特定商取引法に基づく表記</a>
          <a href="/disclaimer">免責事項</a>
          <a href="/contact">お問い合わせ</a>
        </nav>
      </div>
    </footer>

    <script>
      const authArea = document.getElementById("authArea");
      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      if (authArea) {
        if (token && email) {
          authArea.innerHTML = `
            <span class="fortune-user">${email}</span>
            <button id="logoutBtn" class="fortune-nav-logout" type="button">ログアウト</button>
          `;

          document.getElementById("logoutBtn")?.addEventListener("click", () => {
            localStorage.removeItem("token");
            localStorage.removeItem("loginEmail");
            localStorage.removeItem("user_id");
            localStorage.removeItem("userId");
            window.location.href = "/";
          });
        } else {
          authArea.innerHTML = `
            <a href="/login" class="fortune-nav-pill">会員ログイン</a>
          `;
        }
      }
    </script>
  </body>
</html>
