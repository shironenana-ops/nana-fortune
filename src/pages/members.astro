    <script is:inline>
      const memberHeaderAuth = document.getElementById("memberHeaderAuth");
      const headerToken = localStorage.getItem("token");
      const headerEmail =
        localStorage.getItem("loginEmail") ||
        localStorage.getItem("userEmail") ||
        localStorage.getItem("user_email") ||
        localStorage.getItem("userId") ||
        localStorage.getItem("user_id") ||
        "";

      function escapeHeaderHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      if (headerToken && headerEmail) {
        memberHeaderAuth.innerHTML = `
          <span class="fortune-user">${escapeHeaderHtml(headerEmail)}</span>
          <button id="memberLogoutBtn" class="fortune-nav-logout" type="button">
            ログアウト
          </button>
        `;

        document.getElementById("memberLogoutBtn")?.addEventListener("click", () => {
          localStorage.removeItem("token");
          localStorage.removeItem("loginEmail");
          localStorage.removeItem("userEmail");
          localStorage.removeItem("user_email");
          localStorage.removeItem("userId");
          localStorage.removeItem("user_id");
          window.location.href = "/";
        });
      } else {
        memberHeaderAuth.innerHTML = `
          <a href="/login?redirect=/members" class="fortune-nav-pill">会員ログイン</a>
        `;
      }
    </script>
  </body>
