  <script src="/js/billing.js" is:inline></script>

  <script is:inline>
    const USER_STATUS_API = "https://zaebx82pyf.execute-api.ap-northeast-1.amazonaws.com/user/status";
    const CHANGE_PLAN_API = "https://zaebx82pyf.execute-api.ap-northeast-1.amazonaws.com/subscription/change-plan";

    const userId =
      localStorage.getItem("userId") ||
      localStorage.getItem("user_id") ||
      localStorage.getItem("loginEmail") ||
      localStorage.getItem("userEmail") ||
      localStorage.getItem("user_email") ||
      "";

    let currentPlan = "free";
    let currentPendingPlan = "";
    let currentPeriodEnd = "";
    let currentStatusInfo = null;
    let isSubmittingPlanChange = false;

    const planNames = {
      free: "フリー会員",
      normal: "ライト会員",
      premium: "プレミアム会員",
      extra: "単発音声",
    };

    const statusNames = {
      inactive: "未契約",
      active: "有効",
      canceled: "解約済み",
      trialing: "トライアル",
      past_due: "支払保留",
    };

    function normalizePlan(rawPlan) {
      const plan = String(rawPlan || "").toLowerCase();
      if (plan === "premium") return "premium";
      if (plan === "normal" || plan === "light" || plan === "member") return "normal";
      return "free";
    }

    function formatDate(value) {
      if (!value) return "未反映";
      try {
        const d = new Date(value);
        return d.toLocaleString("ja-JP");
      } catch {
        return value;
      }
    }

    function setText(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function setStatusDot(status) {
      const dot = document.getElementById("statusDot");
      if (!dot) return;
      dot.classList.remove("is-active", "is-inactive", "is-canceled");

      if (status === "active" || status === "trialing" || status === "past_due") {
        dot.classList.add("is-active");
      } else if (status === "canceled") {
        dot.classList.add("is-canceled");
      } else {
        dot.classList.add("is-inactive");
      }
    }

    function showPlanChangeNotice(pendingPlan, effectiveAt) {
      const box = document.getElementById("planChangeNotice");
      const title = document.getElementById("planChangeNoticeTitle");
      const text = document.getElementById("planChangeNoticeText");

      if (!box || !title || !text) return;

      if (!pendingPlan) {
        box.hidden = true;
        return;
      }

      title.textContent = `${planNames[pendingPlan] || pendingPlan} への変更予約済み`;
      text.textContent = effectiveAt
        ? `${formatDate(effectiveAt)} から反映予定です。`
        : "次回更新日から反映予定です。";
      box.hidden = false;
    }

    function setBillingMessage(message, isError = false) {
      const box = document.getElementById("billingMessage");
      if (!box) return;

      if (!message) {
        box.style.display = "none";
        box.textContent = "";
        box.style.borderColor = "rgba(202, 168, 79, 0.35)";
        box.style.background = "rgba(202, 168, 79, 0.08)";
        box.style.color = "#f5e8bf";
        return;
      }

      box.style.display = "block";
      box.textContent = message;

      if (isError) {
        box.style.borderColor = "rgba(255, 128, 128, 0.35)";
        box.style.background = "rgba(127, 29, 29, 0.18)";
        box.style.color = "#ffd7d7";
      } else {
        box.style.borderColor = "rgba(202, 168, 79, 0.35)";
        box.style.background = "rgba(202, 168, 79, 0.08)";
        box.style.color = "#f5e8bf";
      }
    }

    function getEmailForCheckout() {
      return (
        localStorage.getItem("userEmail") ||
        localStorage.getItem("user_email") ||
        localStorage.getItem("userId") ||
        localStorage.getItem("user_id") ||
        ""
      );
    }

    function buildExtraCard(sourcePath) {
      return `
        <article class="plan-card" data-plan-card="extra">
          <span class="plan-card__tag">単発追加</span>
          <h3>単発音声占い</h3>
          <p>300円で音声占いを1回だけ追加できる買い切りプランです。</p>
          <div class="plan-card__price">¥300</div>
          <button class="plan-card__button" data-plan="extra" data-source-path="${sourcePath}">
            単発音声を申し込む
          </button>
        </article>
      `;
    }

    function buildNormalCard(sourcePath) {
      return `
        <article class="plan-card" data-plan-card="normal">
          <span class="plan-card__tag">月額ライト会員</span>
          <h3>ライト会員</h3>
          <p>月額980円で、音声占い5回と履歴確認ができる基本プランです。</p>
          <div class="plan-card__price">¥980 <small>/ 月</small></div>
          <button class="plan-card__button" data-plan="normal" data-source-path="${sourcePath}">
            ライト会員に申し込む
          </button>
        </article>
      `;
    }

    function buildPremiumCard(sourcePath) {
      return `
        <article class="plan-card plan-card--premium" data-plan-card="premium">
          <span class="plan-card__tag">人気No.1 プレミアム</span>
          <h3>プレミアム会員</h3>
          <p>月額2980円で、音声20回・履歴確認・深掘り鑑定まで使える本命プランです。</p>
          <div class="plan-card__price">¥2,980 <small>/ 月</small></div>
          <button class="plan-card__button" data-plan="premium" data-source-path="${sourcePath}">
            プレミアム会員に申し込む
          </button>
        </article>
      `;
    }

    function buildDowngradeCard() {
      return `
        <article class="plan-card" data-plan-card="normal">
          <span class="plan-card__tag">次回更新から変更</span>
          <h3>ライト会員へ変更</h3>
          <p>プレミアム会員からライト会員へ、次回更新日から切り替える予約を行います。</p>
          <div class="plan-card__price">¥980 <small>/ 月</small></div>
          <button class="plan-card__button" data-plan="normal">
            ライト会員へ変更予約
          </button>
        </article>
      `;
    }

    function renderPlanCards(plan, pendingPlan = "", currentPeriodEnd = "") {
      const grid = document.getElementById("planCards");
      if (!grid) return;

      const sourcePath = "/members";
      let html = "";

      if (plan === "premium") {
        html = buildExtraCard(sourcePath) + buildDowngradeCard();

        setBillingMessage(
          pendingPlan === "normal"
            ? (currentPeriodEnd
                ? `現在プレミアム会員です。ライト会員への変更は ${formatDate(currentPeriodEnd)} から反映予定です。単発追加は引き続き利用できます。`
                : "現在プレミアム会員です。ライト会員への変更を予約済みです。単発追加は引き続き利用できます。")
            : "現在プレミアム会員です。重複月額決済は表示せず、単発追加と次回更新からのライト変更のみ表示しています。"
        );
      } else if (plan === "normal") {
        html = buildPremiumCard(sourcePath) + buildExtraCard(sourcePath);
        setBillingMessage(
          "現在ライト会員です。プレミアムへのアップグレードと単発追加のみ表示しています。"
        );
      } else {
        html = buildNormalCard(sourcePath) + buildPremiumCard(sourcePath) + buildExtraCard(sourcePath);
        setBillingMessage("");
      }

      grid.innerHTML = html;
      bindPlanButtons();
      updateRenderedPlanStates(plan, pendingPlan, currentPeriodEnd);
    }

    function updateRenderedPlanStates(plan, pendingPlan = "", currentPeriodEnd = "") {
      const normalCard = document.querySelector('[data-plan-card="normal"]');
      const premiumCard = document.querySelector('[data-plan-card="premium"]');
      const normalBtn = document.querySelector('#planCards [data-plan="normal"]');
      const premiumBtn = document.querySelector('#planCards [data-plan="premium"]');

      normalCard?.classList.remove("is-current", "is-pending");
      premiumCard?.classList.remove("is-current", "is-pending");

      if (plan === "normal") {
        if (premiumBtn) {
          premiumBtn.disabled = false;
          premiumBtn.textContent = "プレミアム会員に申し込む";
        }
      }

      if (plan === "premium") {
        if (normalBtn) {
          normalBtn.disabled = false;
          normalBtn.textContent = "ライト会員へ変更予約";
        }

        if (pendingPlan === "normal") {
          normalCard?.classList.add("is-pending");
          if (normalBtn) {
            normalBtn.disabled = true;
            normalBtn.textContent = currentPeriodEnd
              ? `変更予約済み（${formatDate(currentPeriodEnd)} 反映）`
              : "変更予約済み";
          }
        }
      }
    }

    async function requestPlanChange(targetPlan) {
      if (isSubmittingPlanChange) return;
      isSubmittingPlanChange = true;

      try {
        const response = await fetch(CHANGE_PLAN_API, {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            user_id: userId,
            target_plan: targetPlan
          })
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(data?.message || data?.error || "プラン変更予約に失敗しました。");
        }

        currentPendingPlan = data.pending_plan || targetPlan;
        currentPeriodEnd = data.effective_at || currentPeriodEnd;

        showPlanChangeNotice(currentPendingPlan, currentPeriodEnd);
        renderPlanCards(currentPlan, currentPendingPlan, currentPeriodEnd);

        alert(
          data?.message ||
            `${planNames[targetPlan] || targetPlan} への変更を予約しました。`
        );
      } finally {
        isSubmittingPlanChange = false;
      }
    }

    function bindPlanButtons() {
      document.querySelectorAll("#planCards [data-plan]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const plan = btn.getAttribute("data-plan");
          const sourcePath = btn.getAttribute("data-source-path") || "/members";
          if (!plan) return;

          if (plan === "normal" && currentPlan === "premium") {
            const ok = confirm("次回更新日からライト会員へ変更予約します。よろしいですか？");
            if (!ok) return;

            try {
              await requestPlanChange("normal");
            } catch (e) {
              alert(e.message || "変更予約に失敗しました。");
            }
            return;
          }

          if (!window.startCheckout) {
            alert("申込み画面の準備が整いませんでした。\n少し時間を置いてお試しください。");
            return;
          }

          try {
            await window.startCheckout({
              user_id: userId,
              email: getEmailForCheckout(),
              plan,
              source_path: sourcePath,
            });
          } catch (e) {
            console.error(e);
            alert("申込み画面へ進めませんでした。\nもう一度お試しください。");
          }
        });
      });
    }

    async function loadMembershipStatus() {
      const loading = document.getElementById("statusLoading");
      const errorBox = document.getElementById("statusError");
      const errorText = document.getElementById("statusErrorText");

      if (!userId) {
        loading.hidden = true;
        errorBox.hidden = false;
        errorText.textContent = "ユーザーIDが見つかりません。ログインし直してください。";
        return;
      }

      try {
        const res = await fetch(`${USER_STATUS_API}?user_id=${encodeURIComponent(userId)}`);
        const data = await res.json();

        if (!res.ok) {
          throw new Error(data.error || "会員情報の取得に失敗しました。");
        }

        const plan = normalizePlan(data.plan || "free");
        const subscriptionStatus = String(data.subscription_status || "inactive").toLowerCase();
        const voiceLimit = Number(data.monthly_voice_limit ?? data.voice_limit ?? 0);
        const voiceUsed = Number(data.monthly_voice_used ?? data.voice_used ?? 0);
        const voiceRemaining = Math.max(voiceLimit - voiceUsed, 0);
        const extraVoiceRemaining = Number(data.extra_voice_remaining ?? 0);
        const deepEnabled = !!data.deep_enabled;
        const pendingPlan = normalizePlan(data.pending_plan || "");
        const currentPeriodEnd = data.current_period_end || "";

        currentPlan = plan;
        currentPendingPlan = pendingPlan;
        window.currentPendingPlan = pendingPlan;
        window.currentPeriodEnd = currentPeriodEnd;
        currentStatusInfo = data;

        setText("memberGreeting", `${userId} さんの会員ページ`);
        setText("planLabel", planNames[plan] || plan);
        setText(
          "planCaption",
          subscriptionStatus === "active" || subscriptionStatus === "trialing" || subscriptionStatus === "past_due"
            ? "現在の会員状態は有効です。今の利用状況を静かに確認できます。"
            : "まだ会員化は完了していません。必要に応じてプランを選べます。"
        );
        setText("subscriptionStatus", statusNames[subscriptionStatus] || subscriptionStatus);
        setText("deepEnabled", deepEnabled ? "利用可能" : "利用不可");
        setText("voiceMain", `${voiceRemaining} / ${voiceLimit}`);
        setText("voiceUsed", `${voiceUsed}`);
        setText("voiceRemaining", `${voiceRemaining}`);
        setText("extraVoiceRemaining", `${extraVoiceRemaining}`);
        setText("voiceLimit", `${voiceLimit}`);
        setText("updatedAtDisplay", formatDate(data.updated_at));
        setText("stripeMail", data.stripe_customer_email || "未設定");

        const fillPercent = voiceLimit > 0 ? Math.min((voiceUsed / voiceLimit) * 100, 100) : 0;
        const meterFill = document.getElementById("meterFill");
        if (meterFill) meterFill.style.width = `${fillPercent}%`;

        setStatusDot(subscriptionStatus);
        showPlanChangeNotice(pendingPlan, currentPeriodEnd);
        renderPlanCards(plan, pendingPlan, currentPeriodEnd);

        loading.hidden = true;
      } catch (err) {
        loading.hidden = true;
        errorBox.hidden = false;
        errorText.textContent = err.message || "会員情報の取得に失敗しました。";
        setBillingMessage("会員状態の取得に失敗しました。", true);
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      loadMembershipStatus();
    });
  </script>
