      async function loadUserStatus() {
        const token = getAuthToken();

        if (!token) {
          renderPlanCards(null);
          showBillingMessage("ログイン情報が見つからないため、申込み表示を制限しています。", true);
          return;
        }

        try {
          const res = await fetch(
            `${HISTORY_API_BASE}/history/list`,
            {
              method: "GET",
              headers: {
                Authorization: "Bearer " + token
              }
            }
          );

          const rawText = await res.text();
          let data = null;

          try {
            data = rawText ? JSON.parse(rawText) : null;
          } catch (error) {
            console.error("user status parse error:", error, rawText);
            throw new Error("会員状態を確認できませんでした。");
          }

          if (!res.ok) {
            const apiMessage =
              (data && data.error) ||
              (data && data.message) ||
              ("HTTP " + res.status);
            throw new Error(apiMessage);
          }

          const payload = extractUserStatusPayload(data);

          const normalized = {
            plan: normalizePlan(
              payload.plan ||
              payload.current_plan ||
              payload.membership_plan
            ),
            subscriptionStatus: normalizeSubscriptionStatus(
              payload.subscription_status ||
              payload.status
            ),
            currentPeriodEnd:
              payload.current_period_end ||
              payload.currentPeriodEnd ||
              "",
            cancelAtPeriodEnd:
              Boolean(payload.cancel_at_period_end) ||
              Boolean(payload.cancelAtPeriodEnd),
            monthlyVoiceLimit:
              Number(payload.monthly_voice_limit || 0),
            monthlyVoiceUsed:
              Number(payload.monthly_voice_used || 0),
            extraVoiceRemaining:
              Number(payload.extra_voice_remaining || 0)
          };

          if (normalized.plan === "premium") {
            showBillingMessage(
              normalized.cancelAtPeriodEnd
                ? "現在プレミアム会員です。解約予約中ですが、次回更新日までは利用できます。"
                : "現在プレミアム会員です。このページでは月額の重複申込みを表示していません。",
              false
            );
          } else if (normalized.plan === "normal") {
            showBillingMessage(
              normalized.cancelAtPeriodEnd
                ? "現在ライト会員です。解約予約中ですが、次回更新日までは利用できます。"
                : "現在ライト会員です。このページでは月額の重複申込みを表示していません。",
              false
            );
          } else {
            showBillingMessage("", false);
          }

          renderPlanCards(normalized);
        } catch (error) {
          console.error("user status load error:", error);
          showBillingMessage(
            "会員状態を確認できませんでした。安全のため、月額申込みは表示していません。",
            true
          );
          renderPlanCards(null);
        }
      }


      function removeHistoryCard(historyId) {
        allHistoryItems = allHistoryItems.filter(function (item) {
          return getHistoryItemId(item) !== String(historyId);
        });

        if (allHistoryItems.length && visibleHistoryCount < HISTORY_PAGE_SIZE) {
          visibleHistoryCount = HISTORY_PAGE_SIZE;
        }

        if (visibleHistoryCount > allHistoryItems.length) {
          visibleHistoryCount = Math.max(HISTORY_PAGE_SIZE, allHistoryItems.length);
        }

        renderVisibleHistory();
      }

