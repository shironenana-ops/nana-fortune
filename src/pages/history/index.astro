        list.addEventListener("click", function (event) {
          const button = event.target && event.target.closest
            ? event.target.closest("[data-delete-history-id]")
            : null;

          if (!button) return;

          event.preventDefault();
          event.stopPropagation();

          const historyId = button.getAttribute("data-delete-history-id");
          deleteHistoryItem(historyId, button);
        });
      }

      function setupHistoryMoreHandler() {
        const button = document.getElementById("historyMoreButton");
        if (!button) return;

        button.addEventListener("click", function () {
          showMoreHistory();
        });
      }


      async function loadHistory() {
        const list = document.getElementById("historyList");
        const token = getAuthToken();

        allHistoryItems = [];
        visibleHistoryCount = HISTORY_PAGE_SIZE;
        updateHistoryMoreButton();
        list.innerHTML = '<div class="loading-card">読み込み中...</div>';
        hideNotice();
        showDebug("");

        if (!token) {
          renderLoginExpired(list);
          showDebug(
            "確認ポイント:\n" +
            "localStorage.token = " + String(Boolean(localStorage.getItem("token")))
          );
          return;
        }

        const url = HISTORY_API_BASE + "/history/list";

        try {
          const response = await fetch(url, {
            method: "GET",
            headers: {
              Authorization: "Bearer " + token
            }
          });

          const rawText = await response.text();

          let data = null;
          try {
            data = rawText ? JSON.parse(rawText) : null;
          } catch (parseError) {
            console.error("history load parse error:", parseError, rawText);
            throw new Error("履歴を読み込めませんでした。少し時間を置いて、もう一度お試しください。");
          }

          if (!response.ok) {
            const apiMessage =
              (data && data.error) ||
              (data && data.message) ||
              ("HTTP " + response.status);

            if (
              response.status === 401 ||
              isUnauthorizedMessage(apiMessage) ||
              isUnauthorizedMessage(rawText)
            ) {
              renderLoginExpired(list);
              return;
            }

            throw new Error(apiMessage);
          }

          const items = extractItems(data);

          if (!items.length) {
            allHistoryItems = [];
            visibleHistoryCount = HISTORY_PAGE_SIZE;
            updateHistoryMoreButton();
            list.innerHTML = '<div class="empty-card">まだ履歴がありません。</div>';
            showDebug(
              "API URL:\n" + url + "\n\n" +
              "Response:\n" + JSON.stringify(data, null, 2)
            );
            return;
          }

          renderHistory(items);

          showDebug(
            "API URL:\n" + url + "\n\n" +
            "取得件数: " + items.length + "\n\n" +
            "Response:\n" + JSON.stringify(data, null, 2)
          );
        } catch (error) {
          console.error("history load error:", error);

          if (isUnauthorizedMessage(error && error.message ? error.message : error)) {
            renderLoginExpired(list);
            return;
          }

          list.innerHTML = '<div class="empty-card">履歴を読み込めませんでした。<br />少し時間を置いて、もう一度お試しください。</div>';
          showNotice("履歴を読み込めませんでした\n\n少し時間を置いて\nもう一度お試しください", true);
          showDebug(
            "API URL:\n" + url + "\n\n" +
            "error:\n" + String(error && error.stack ? error.stack : error)
          );
        }
      }

      document.addEventListener("DOMContentLoaded", function () {
        setupAuthNav();
        setupHistoryDeleteHandler();
        setupHistoryMoreHandler();

        const reloadButton = document.getElementById("reloadHistoryButton");
        if (reloadButton) {
          reloadButton.addEventListener("click", function () {
            loadHistory();
            loadUserStatus();
          });
        }
loadUserStatus();
        loadHistory();
      });
    </script>
  </body>
</html>
