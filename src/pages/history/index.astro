      function renderPlanCards(statusInfo) {
        const container = document.getElementById("planCards");
        if (!container) return;

        if (!statusInfo) {
          container.innerHTML = buildUnknownCards();
          return;
        }

        if (statusInfo.plan === "premium") {
          container.innerHTML = buildPremiumMemberCards(statusInfo);
          return;
        }

        if (statusInfo.plan === "normal") {
          container.innerHTML = buildNormalMemberCards(statusInfo);
          return;
        }

        if (isPaidLikeUser(statusInfo)) {
          container.innerHTML = buildUnknownCards();
          return;
        }

        container.innerHTML = buildFreePlanCards();

