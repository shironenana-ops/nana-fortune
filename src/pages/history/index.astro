      function normalizeStatus(status) {
        return String(status || "").toLowerCase();
      }

      function getStatusInfo(status) {
        const normalized = normalizeStatus(status);

        if (normalized === "completed") {
          return {
            text: "✅ 完了",
            className: "history-status history-status--completed",
            description: "鑑定結果を確認できます。"
          };
        }

        if (normalized === "processing" || normalized === "pending") {
          return {
            text: "🔄 処理中",
            className: "history-status history-status--processing",
            description: "現在、音声鑑定を処理しています。"
          };
        }

        if (normalized === "error" || normalized === "failed") {
          return {
            text: "❌ エラー",
            className: "history-status history-status--error",
            description: "鑑定処理に失敗しました。再試行してください。"
          };
        }

        return {
          text: "・状態不明",
          className: "history-status history-status--unknown",
          description: "状態を判定できませんでした。"
        };
      }

      function formatDate(rawDate) {
        if (!rawDate) return "日時不明";

        const dt = new Date(rawDate);
        if (!isNaN(dt.getTime())) {
          return dt.toLocaleString("ja-JP", {
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            hour: "2-digit",
            minute: "2-digit"
          });
        }

        return String(rawDate);
      }

      function extractItems(data) {
        if (Array.isArray(data)) {
          return data;
        }

        if (data && Array.isArray(data.items)) {
          return data.items;
        }

        if (data && typeof data.body === "string") {
          try {
            const parsed = JSON.parse(data.body);
            if (Array.isArray(parsed)) return parsed;
            if (parsed && Array.isArray(parsed.items)) return parsed.items;
          } catch (error) {
            console.error("body parse error:", error);
          }
        }

        if (data && data.body && typeof data.body === "object") {
          if (Array.isArray(data.body)) return data.body;
          if (Array.isArray(data.body.items)) return data.body.items;
        }

        return [];
      }

      function buildHistoryActions(item, status) {
        const normalized = normalizeStatus(status);
        const historyId =
          item && (item.history_id || item.id)
            ? String(item.history_id || item.id)
            : "";

        const deleteAction = historyId
          ? '<button class="history-action danger" type="button" data-delete-history-id="' +
            escapeHtml(historyId) +
            '">削除する</button>'
          : "";

        if (normalized === "completed") {
          if (!historyId) return "";

          return (
            '<div class="history-actions">' +
              '<a class="history-action primary" href="/history/' +
              encodeURIComponent(historyId) +
              '">結果を見る</a>' +
              deleteAction +
            '</div>'
          );
        }

        if (normalized === "processing" || normalized === "pending") {
          if (!historyId) {
            return (
              '<div class="history-actions">' +
                '<button class="history-action" type="button" onclick="window.location.reload()">再読み込み</button>' +
              '</div>'
            );
          }

          return (
            '<div class="history-actions">' +
              '<a class="history-action primary" href="/premium/voice-processing?id=' +
              encodeURIComponent(historyId) +
              '">処理画面を開く</a>' +
              '<button class="history-action" type="button" onclick="window.location.reload()">再読み込み</button>' +
              deleteAction +
            '</div>'
          );
        }

        if (normalized === "error" || normalized === "failed") {
          return (
            '<div class="history-actions">' +
              '<a class="history-action primary" href="/premium/voice">再鑑定する</a>' +
              deleteAction +
            '</div>'
          );
        }

        if (deleteAction) {
          return '<div class="history-actions">' + deleteAction + '</div>';
        }

        return "";
      }

      function getHistoryItemId(item) {
        return String((item && (item.history_id || item.id)) || "");
      }

      function sortHistoryItems(items) {
        return items.slice().sort(function (a, b) {
          const ta =
            a && (a.created_at || a.timestamp || a.createdAt)
              ? (a.created_at || a.timestamp || a.createdAt)
              : "";
          const tb =
            b && (b.created_at || b.timestamp || b.createdAt)
              ? (b.created_at || b.timestamp || b.createdAt)
              : "";
          return String(tb).localeCompare(String(ta));
        });
      }

      function updateHistoryMoreButton() {
        const wrap = document.getElementById("historyMoreWrap");
        if (!wrap) return;

        if (allHistoryItems.length > visibleHistoryCount) {
          wrap.classList.add("is-show");
        } else {
          wrap.classList.remove("is-show");
        }
      }

      function renderVisibleHistory() {
        const list = document.getElementById("historyList");
        list.innerHTML = "";

        if (!allHistoryItems.length) {
          list.innerHTML = '<div class="empty-card">まだ履歴がありません。</div>';
          updateHistoryMoreButton();
          return;
        }

        allHistoryItems.slice(0, visibleHistoryCount).forEach(function (item) {
          const rawDate =
            (item && (item.created_at || item.timestamp || item.createdAt)) ||
            (item && item.history_id && String(item.history_id).includes("#")
              ? String(item.history_id).split("#")[0]
              : "") ||
            "";

          const title =
            (item && (item.title || item.input_title || item.category || item.kind)) ||
            "音声鑑定";

          const status = (item && item.status) || "completed";
          const statusInfo = getStatusInfo(status);

          const summary =
            (item && item.result && item.result.summary) ||
            (item && item.summary) ||
            (item && item.result_preview) ||
            (item && item.result_text) ||
            statusInfo.description;

          const historyId = (item && (item.history_id || item.id)) || "";

          const card = document.createElement("article");
          card.className = "history-card";

          if (normalizeStatus(status) === "completed" && historyId) {
            card.classList.add("is-clickable");
          }

          card.innerHTML =
            '<div class="history-meta">' +
              '<div>' +
                '<div class="history-date">' + escapeHtml(formatDate(rawDate)) + '</div>' +
                '<h3>' + escapeHtml(title) + '</h3>' +
              '</div>' +
              '<div class="' + escapeHtml(statusInfo.className) + '">' + escapeHtml(statusInfo.text) + '</div>' +
            '</div>' +
            '<div class="history-summary">' + escapeHtml(summary) + '</div>' +
            buildHistoryActions(item, status);

          if (normalizeStatus(status) === "completed" && historyId) {
            card.addEventListener("click", function (event) {
              const target = event.target;
              if (target && target.closest && target.closest(".history-actions")) {
                return;
              }
              window.location.href = "/history/" + encodeURIComponent(historyId);
            });
          }

          list.appendChild(card);
        });

        updateHistoryMoreButton();
      }

      function renderHistory(items) {
        allHistoryItems = sortHistoryItems(items);
        visibleHistoryCount = HISTORY_PAGE_SIZE;
        renderVisibleHistory();
      }

      function showMoreHistory() {
        visibleHistoryCount += HISTORY_PAGE_SIZE;
        renderVisibleHistory();
      }

      async function deleteHistory(historyId, button) {
        if (!historyId) {
          showNotice("削除対象の履歴が見つかりません。", true);
          return;
        }

        const token = getAuthToken();
        if (!token) {
          showNotice("削除するにはログインしてください。", true);
          redirectToLogin();
          return;
        }

        if (!window.confirm("この履歴を削除しますか？")) {
          return;
        }

        const originalText = button ? button.textContent : "";
        if (button) {
          button.disabled = true;
          button.textContent = "削除中...";
        }

        try {
          const response = await fetch(HISTORY_API_BASE + "/history/delete", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: "Bearer " + token
            },
            body: JSON.stringify({ history_id: historyId })
          });

          const rawText = await response.text();
          let data = null;
          try {
            data = rawText ? JSON.parse(rawText) : null;
          } catch (parseError) {
            console.error("history delete parse error:", parseError, rawText);
            throw new Error("履歴を削除できませんでした。少し時間を置いて、もう一度お試しください。");
          }

          if (!response.ok || (data && data.ok === false)) {
            const apiMessage =
              (data && data.message) ||
              (data && data.error) ||
              ("HTTP " + response.status);
            throw new Error(apiMessage);
          }

          const card = button && button.closest ? button.closest(".history-card") : null;
          if (card) {
            card.remove();
          } else {
            await loadHistory();
          }

          const list = document.getElementById("historyList");
          if (list && !list.querySelector(".history-card")) {
            list.innerHTML = '<div class="empty-card">まだ履歴がありません。</div>';
          }

          showNotice("履歴を削除しました。", false);
        } catch (error) {
          console.error("history delete error:", error);
          showNotice("履歴を削除できませんでした。\n少し時間を置いて、もう一度お試しください。", true);
          if (button) {
            button.disabled = false;
            button.textContent = originalText || "削除する";
          }
        }
      }

      function extractUserStatusPayload(data) {
        if (!data) return {};

        if (data.item && typeof data.item === "object") return data.item;
        if (data.user && typeof data.user === "object") return data.user;
        if (data.body && typeof data.body === "string") {
          try {
            return JSON.parse(data.body);
          } catch (error) {
            console.error("user status body parse error:", error);
          }
        }
        if (data.body && typeof data.body === "object") return data.body;

        return data;
      }

      function normalizePlan(rawPlan) {
        const plan = String(rawPlan || "").toLowerCase();

        if (plan === "premium") return "premium";
        if (plan === "normal" || plan === "light" || plan === "member") return "normal";
        return "free";
      }

      function normalizeSubscriptionStatus(rawStatus) {
        return String(rawStatus || "").toLowerCase();
      }

      function isPaidLikeUser(statusInfo) {
        if (!statusInfo) return false;

        if (statusInfo.plan === "premium" || statusInfo.plan === "normal") {
          return true;
        }

        const sub = normalizeSubscriptionStatus(statusInfo.subscriptionStatus);
        return sub === "active" || sub === "trialing" || sub === "past_due";
      }

