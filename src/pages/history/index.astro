---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>鑑定履歴 | 白音七</title>
    <meta name="description" content="白音七の鑑定履歴一覧" />

    <style is:global>
      :root {
        --bg-1: #050816;
        --bg-2: #0b1330;
        --panel: rgba(15, 20, 40, 0.88);
        --line: rgba(202, 168, 79, 0.22);
        --line-strong: rgba(202, 168, 79, 0.36);
        --gold: #f2dd9a;
        --gold-strong: #fff0bf;
        --text: #f8f3df;
        --muted: #dbc979;
        --shadow: 0 20px 60px rgba(0, 0, 0, 0.45);

        --ok-bg: rgba(56, 142, 60, 0.18);
        --ok-bd: rgba(129, 199, 132, 0.38);
        --ok-tx: #d6f5da;

        --wait-bg: rgba(255, 193, 7, 0.16);
        --wait-bd: rgba(255, 224, 130, 0.38);
        --wait-tx: #fff1bf;

        --err-bg: rgba(198, 40, 40, 0.18);
        --err-bd: rgba(239, 154, 154, 0.34);
        --err-tx: #ffd6d6;

        --info-bg: rgba(255, 255, 255, 0.04);
        --info-bd: rgba(255, 255, 255, 0.12);
        --info-tx: #e9defd;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        position: relative;
        min-height: 100vh;
        font-family: "Hiragino Mincho ProN", "Yu Mincho", "YuMincho", serif;
        color: var(--text);
        background: #050816;
        isolation: isolate;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -2;
        pointer-events: none;
        opacity: 0.9;
        background:
          url("/images/bg-cosmic-luxury.png") center top / cover no-repeat,
          linear-gradient(135deg, var(--bg-1) 0%, #07112a 50%, #020615 100%);
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background:
          radial-gradient(circle at 16% 12%, rgba(182, 140, 255, 0.12), transparent 28%),
          radial-gradient(circle at 84% 18%, rgba(242, 221, 154, 0.08), transparent 24%),
          linear-gradient(
            180deg,
            rgba(2, 3, 10, 0.22) 0%,
            rgba(4, 7, 20, 0.38) 45%,
            rgba(10, 7, 32, 0.60) 100%
          );
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
      }

      .header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(4, 8, 20, 0.82);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(202, 168, 79, 0.12);
      }

      .header-inner {
        min-height: 82px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold-strong);
        letter-spacing: 0.08em;
      }

      .logo-mark {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: radial-gradient(circle at 30% 30%, #fff6cf, #c79d36 70%);
        box-shadow: 0 0 16px rgba(255, 226, 138, 0.6);
      }

      .nav {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
      }

      .nav-link {
        color: var(--gold);
        font-size: 0.95rem;
        font-weight: 700;
        transition: color 0.18s ease, transform 0.18s ease;
      }

      .nav-link:hover {
        color: var(--gold-strong);
        transform: translateY(-1px);
      }

      .nav-pill,
      .nav-logout {
        appearance: none;
        -webkit-appearance: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0 17px;
        border-radius: 999px;
        border: 1px solid rgba(202, 168, 79, 0.38);
        background:
          linear-gradient(180deg, rgba(242, 221, 154, 0.12), rgba(202, 168, 79, 0.06)),
          rgba(255, 255, 255, 0.02);
        color: var(--gold-strong);
        cursor: pointer;
        font: inherit;
        font-weight: 700;
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      }

      .nav-pill:hover,
      .nav-logout:hover {
        transform: translateY(-1px);
        border-color: rgba(242, 221, 154, 0.62);
        background:
          linear-gradient(180deg, rgba(242, 221, 154, 0.2), rgba(202, 168, 79, 0.1)),
          rgba(255, 255, 255, 0.03);
      }

      .nav-user {
        color: var(--gold-strong);
      }

      .page {
        padding: 40px 0 88px;
      }

      .hero,
      .panel,
      .history-wrap {
        border: 1px solid rgba(242, 221, 154, 0.24);
        border-radius: 28px;
        background:
          radial-gradient(circle at 18% 8%, rgba(255, 240, 191, 0.035), transparent 34%),
          radial-gradient(circle at 82% 18%, rgba(182, 140, 255, 0.05), transparent 38%),
          linear-gradient(180deg, rgba(8, 12, 28, 0.88), rgba(8, 9, 26, 0.84));
        box-shadow: var(--shadow);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
      }

      .hero {
        padding: 40px;
        margin-bottom: 28px;
      }

      .panel {
        padding: 34px;
        margin-bottom: 28px;
      }

      .history-wrap {
        padding: 34px;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        border: 1px solid rgba(202, 168, 79, 0.28);
        color: var(--gold);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        margin-bottom: 16px;
      }

      .hero h1,
      .panel h2,
      .history-wrap h2 {
        margin: 0 0 12px;
        color: var(--gold-strong);
        line-height: 1.35;
      }

      .hero p,
      .panel p,
      .history-wrap p {
        margin: 0;
        color: var(--muted);
        line-height: 1.9;
      }

      .billing-message {
        display: none;
        margin: 0 0 18px;
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid var(--line-strong);
        color: var(--gold);
        background: rgba(202, 168, 79, 0.08);
        line-height: 1.8;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .billing-message.is-show {
        display: block;
      }

      .billing-message.is-error {
        border-color: var(--err-bd);
        background: rgba(198, 40, 40, 0.12);
        color: var(--err-tx);
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 18px;
      }

      .menu-card,
      .history-card,
      .loading-card,
      .empty-card,
      .notice-card,
      .debug-card,
      .member-status-card {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: linear-gradient(180deg, rgba(20, 24, 48, 0.94), rgba(21, 17, 38, 0.88));
      }

      .menu-card,
      .member-status-card {
        padding: 24px;
      }

      .menu-card.featured {
        border-color: rgba(182, 140, 255, 0.42);
        box-shadow: 0 0 30px rgba(182, 140, 255, 0.12);
      }

      .menu-card.current,
      .member-status-card.current {
        border-color: rgba(242, 221, 154, 0.4);
        background:
          linear-gradient(135deg, rgba(242, 221, 154, 0.08), rgba(182, 140, 255, 0.08)),
          linear-gradient(180deg, rgba(20, 24, 48, 0.94), rgba(21, 17, 38, 0.88));
      }

      .menu-card h3,
      .history-card h3,
      .member-status-card h3 {
        margin: 0 0 10px;
        color: var(--gold-strong);
      }

      .price {
        margin: 16px 0;
        font-size: 1.32rem;
        font-weight: 700;
        color: var(--gold-strong);
      }

      .plan-note {
        margin-top: 12px;
        color: var(--muted);
        line-height: 1.8;
        font-size: 0.92rem;
      }

      .member-status-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 32px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        margin-bottom: 12px;
      }

      .member-status-badge.free {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.14);
        color: var(--text);
      }

      .member-status-badge.normal {
        background: rgba(242, 221, 154, 0.12);
        border: 1px solid rgba(242, 221, 154, 0.28);
        color: var(--gold-strong);
      }

      .member-status-badge.premium {
        background: rgba(182, 140, 255, 0.18);
        border: 1px solid rgba(182, 140, 255, 0.34);
        color: #f0e6ff;
      }

      .btn-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 22px;
        border-radius: 999px;
        border: 1px solid transparent;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
      }

      .btn-gold {
        color: #1a1405;
        background: linear-gradient(135deg, #f0d46a 0%, #cfa640 100%);
        box-shadow: 0 10px 24px rgba(207, 166, 64, 0.28);
      }

      .btn-violet {
        color: #fff8ff;
        background: linear-gradient(135deg, #7f5af0 0%, #b68cff 100%);
        box-shadow: 0 10px 24px rgba(127, 90, 240, 0.26);
      }

      .btn-secondary {
        color: var(--gold-strong);
        border-color: rgba(202, 168, 79, 0.28);
        background: rgba(255, 255, 255, 0.03);
      }

      .btn-disabled {
        opacity: 0.55;
        cursor: default;
        pointer-events: none;
      }

      .history-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 18px;
      }

      .history-status-tools {
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-bottom: 18px;
      }

      .notice-card {
        display: none;
        padding: 14px 16px;
        border: 1px solid var(--info-bd);
        background: var(--info-bg);
        color: var(--info-tx);
        line-height: 1.8;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .notice-card.is-show {
        display: block;
      }

      .notice-card.is-error {
        border-color: var(--err-bd);
        background: rgba(198, 40, 40, 0.12);
        color: var(--err-tx);
      }

      .debug-card {
        display: none;
        padding: 16px;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.8;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .debug-card.is-show {
        display: block;
      }

      .history-list {
        display: grid;
        gap: 16px;
      }

      .history-more-wrap {
        display: none;
        justify-content: center;
        margin-top: 18px;
      }

      .history-more-wrap.is-show {
        display: flex;
      }

      .history-more-button {
        min-width: min(100%, 280px);
      }

      .loading-card,
      .empty-card {
        padding: 24px;
        color: var(--muted);
      }

      .history-card {
        position: relative;
        overflow: hidden;
        padding: 24px;
        background:
          linear-gradient(135deg, rgba(182, 140, 255, 0.08), transparent 42%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
          rgba(14, 18, 38, 0.92);
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      .history-card::before {
        content: "";
        position: absolute;
        inset: 0 auto auto 0;
        width: 72px;
        height: 1px;
        background: linear-gradient(90deg, rgba(242, 221, 154, 0.8), transparent);
      }

      .history-card.is-clickable {
        cursor: pointer;
      }

      .history-card.is-clickable:hover {
        transform: translateY(-2px);
        border-color: rgba(202, 168, 79, 0.34);
      }

      .history-meta {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 12px;
      }

      .history-date {
        color: var(--gold);
        font-size: 0.88rem;
        margin-bottom: 8px;
      }

      .history-status {
        padding: 6px 12px;
        border-radius: 999px;
        border: 1px solid rgba(202, 168, 79, 0.24);
        color: var(--muted);
        font-size: 0.85rem;
      }

      .history-status--completed {
        background: var(--ok-bg);
        border-color: var(--ok-bd);
        color: var(--ok-tx);
      }

      .history-status--processing {
        background: var(--wait-bg);
        border-color: var(--wait-bd);
        color: var(--wait-tx);
      }

      .history-status--error {
        background: var(--err-bg);
        border-color: var(--err-bd);
        color: var(--err-tx);
      }

      .history-status--unknown {
        background: rgba(255,255,255,0.08);
        border-color: rgba(255,255,255,0.14);
        color: var(--text);
      }

      .history-summary {
        line-height: 1.85;
        color: var(--muted);
        margin-bottom: 14px;
      }

      .history-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .history-action {
        appearance: none;
        -webkit-appearance: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 999px;
        border: 1px solid rgba(202, 168, 79, 0.34);
        background:
          linear-gradient(180deg, rgba(242, 221, 154, 0.08), rgba(127, 181, 255, 0.03)),
          rgba(255, 255, 255, 0.03);
        color: var(--gold-strong);
        font-size: 0.92rem;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        transition: transform 0.18s ease, filter 0.18s ease, box-shadow 0.18s ease;
      }

      .history-action:hover {
        transform: translateY(-1px);
        filter: brightness(1.08);
      }

      .history-action.primary {
        border: 1px solid rgba(255, 241, 193, 0.76);
        background: linear-gradient(180deg, #fff0bf 0%, #d9b55a 56%, #b68a2a 100%);
        box-shadow:
          0 0 20px rgba(242, 221, 154, 0.18),
          inset 0 1px 0 rgba(255, 255, 255, 0.45);
        color: #1a1202;
      }

      .history-action.danger {
        border-color: rgba(210, 105, 105, 0.42);
        background: rgba(84, 28, 36, 0.24);
        color: #f0b8b8;
      }


      .footer {
        border-top: 1px solid rgba(202, 168, 79, 0.22);
        background: rgba(2, 3, 10, 0.92);
      }

      .footer-inner {
        min-height: 96px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
        color: #b99e48;
        font-size: 0.92rem;
      }

      .footer-links {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
      }

      .footer-links a {
        color: #b99e48;
      }

      .footer-links a:hover {
        color: var(--gold-strong);
      }

      .footer-note {
        width: 100%;
        margin-top: -8px;
        color: rgba(245, 232, 191, 0.62);
        line-height: 1.8;
        font-size: 0.86rem;
      }

      @media (max-width: 720px) {
        .container {
          width: min(100% - 20px, 1120px);
        }

        .hero,
        .panel,
        .history-wrap {
          padding: 22px;
          border-radius: 22px;
        }

        .header-inner {
          min-height: auto;
          padding: 14px 0;
          align-items: stretch;
          justify-content: center;
          flex-direction: column;
          gap: 12px;
        }

        .logo {
          width: 100%;
          justify-content: center;
          font-size: 1.65rem;
        }

        .nav {
          width: 100%;
          justify-content: center;
          gap: 8px;
        }

        .nav-link {
          font-size: 0.82rem;
          padding: 7px 4px;
        }

        .nav-user {
          width: 100%;
          text-align: center;
          overflow-wrap: anywhere;
        }

        .nav-pill,
        .nav-logout {
          min-height: 40px;
          padding: 0 13px;
          font-size: 0.82rem;
          white-space: nowrap;
        }

        .btn-row,
        .history-actions {
          width: 100%;
          flex-direction: column;
          align-items: stretch;
        }

        .btn,
        .history-action {
          width: 100%;
        }

        .history-card {
          padding: 20px;
        }

        .footer-inner {
          min-height: auto;
          padding: 24px 0;
          flex-direction: column;
          align-items: flex-start;
        }
      }

      .history-action.danger {
        border-color: rgba(239, 154, 154, 0.42);
        background: rgba(198, 40, 40, 0.12);
        color: #ffd6d6;
      }

      .history-action.danger:hover {
        border-color: rgba(239, 154, 154, 0.72);
        background: rgba(198, 40, 40, 0.22);
        color: #ffffff;
      }

      .history-action[disabled] {
        opacity: 0.58;
        cursor: not-allowed;
        transform: none !important;
      }


      @media (max-width: 768px) {
        body::before,
        body::after {
          position: absolute;
          min-height: 100%;
        }

        body::before {
          opacity: 0.82;
        }
      }

</style>
  </head>

  <body>
    <header class="header">
      <div class="container header-inner">
        <a href="/" class="logo">
          <span class="logo-mark"></span>
          <span>白音七</span>
        </a>

        <nav class="nav" id="authNav">
          <a class="nav-link" href="/">TOP</a>
          <a class="nav-link" href="/members">会員ページ</a>
          <a class="nav-link" href="/premium">会員限定鑑定</a>
          <a class="nav-link" href="/privacy">プライバシーポリシー</a>
        </nav>
      </div>
    </header>

    <main class="page">
      <div class="container">
        <section class="hero">
          <div class="badge">HISTORY</div>
          <h1>鑑定履歴</h1>
          <p>
            保存した鑑定結果を、新しい順に一覧で確認できます。<br />
            過去の流れを振り返ることで、今の自分の変化が見えやすくなります。
          </p>
        </section>

        <section class="panel">
          <div class="badge">PLAN SELECT</div>
          <h2>履歴から、次の一手へ</h2>
          <p style="margin-bottom: 8px;">
            過去の鑑定を見返したあとに、必要な深さだけ追加できます。
          </p>
          <p style="margin-bottom: 24px; color: var(--gold);">
            会員状態に応じて、表示される申込み内容が変わります。
          </p>

          <div id="billingMessage" class="billing-message"></div>
          <div id="planCards" class="cards">
            <div class="loading-card">会員状態を確認しています...</div>
          </div>
        </section>

        <section class="history-wrap">
          <div class="history-head">
            <div>
              <h2>あなたの鑑定一覧</h2>
              <p>新しい順に表示します。</p>
            </div>

            <div class="btn-row">
              <a href="/premium/voice" class="btn btn-violet">音声鑑定へ</a>
              <a href="/members" class="btn btn-secondary">会員ページへ</a>
              <button id="reloadHistoryButton" class="btn btn-secondary" type="button">再読み込み</button>
            </div>
          </div>

          <div class="history-status-tools">
            <div id="historyNotice" class="notice-card"></div>
            <div id="debugBox" class="debug-card"></div>
          </div>

          <div id="historyList" class="history-list">
            <div class="loading-card">読み込み中...</div>
          </div>

          <div id="historyMoreWrap" class="history-more-wrap">
            <button id="historyMoreButton" class="history-action history-more-button" type="button">
              もう少し見る
            </button>
          </div>
        </section>
      </div>
    </main>


    <footer class="footer">
      <div class="container footer-inner">
        <div>© {new Date().getFullYear()} 白音七</div>

        <div class="footer-links">
          <a href="/">TOP</a>
          <a href="/members">会員ページ</a>
          <a href="/history">履歴一覧</a>
          <a href="/privacy">プライバシーポリシー</a>
          <a href="/disclaimer">免責事項</a>
          <a href="/contact">お問い合わせ</a>
        </div>

        <div class="footer-note">
          この占いは、日々の気持ちを整えるためのものです。<br />
          医療・法律・投資などの専門的判断にはご利用いただけません。
        </div>
      </div>
    </footer>

    <script is:inline src="/js/billing.js"></script>

    <script is:inline>
      const API_BASE = "https://mydmaywesh.execute-api.ap-northeast-1.amazonaws.com/prod";
      const HISTORY_API_BASE = API_BASE;
      const DEBUG_HISTORY = false;
      const HISTORY_PAGE_SIZE = 5;
      let allHistoryItems = [];
      let visibleHistoryCount = HISTORY_PAGE_SIZE;

      function escapeHtml(value) {
        return String(value ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function showNotice(message, isError) {
        const el = document.getElementById("historyNotice");
        if (!el) return;

        if (!message) {
          el.textContent = "";
          el.className = "notice-card";
          return;
        }

        el.textContent = message;
        el.className = "notice-card is-show" + (isError ? " is-error" : "");
      }

