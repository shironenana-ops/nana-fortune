---
import "../../styles/global.css";

export const prerender = false;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>鑑定履歴詳細 | 白音七</title>
    <meta name="description" content="白音七の鑑定履歴詳細ページ" />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/members">会員ページ</a>
          <a href="/history">履歴一覧</a>
          <a href="/privacy">プライバシーポリシー</a>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main class="fortune-history-detail-page">
      <div class="fortune-container">
        <section class="fortune-history-detail-frame fortune-detail-page-frame">
          <div class="fortune-detail-hero">
            <div class="fortune-detail-kicker">SHIRONE7 DIVINATION DETAIL</div>
            <h1 id="detailTitle" class="fortune-history-detail-title fortune-detail-page-title">
              静かに導かれる、あなたの流れ
            </h1>
            <p id="detailLead" class="fortune-detail-page-lead">
              保存された鑑定結果を、静かに受け取り、振り返るためのページです。
            </p>
          </div>

          <div id="detail" class="fortune-detail-loading">読み込み中...</div>
        </section>
      </div>
    </main>

    <script>
      const API_BASE = "https://mydmaywesh.execute-api.ap-northeast-1.amazonaws.com/prod";
      import { shironeIconMap } from "../../lib/shironeIconMap";
      import {
        getShironePhaseDetail,
        getShironeTypeByBirthDate,
        getShironeTypeDisplayName,
      } from "../../lib/shironeTypes";

      const authArea = document.getElementById("authArea");
      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      if (token && email) {
        authArea.innerHTML = `
          <span class="fortune-user">${email}</span>
          <button id="logoutBtn" class="fortune-nav-logout" type="button">ログアウト</button>
        `;

        document.getElementById("logoutBtn").addEventListener("click", () => {
          localStorage.removeItem("token");
          localStorage.removeItem("loginEmail");
          localStorage.removeItem("user_id");
          localStorage.removeItem("userId");
          window.location.href = "/";
        });
      } else {
        authArea.innerHTML = `
          <a href="/login" class="fortune-nav-pill">会員ログイン</a>
        `;
      }

      function escapeHtml(str) {
        return String(str ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function nl2br(str) {
        return escapeHtml(str).replace(/\n/g, "<br>");
      }

      const iconHintTones = new Set(["gold", "purple", "blue", "green", "gray"]);
      const typeIconImages = {
        moonlight: "/images/types-icons/moon-lantern.png",
        stargazer: "/images/types-icons/sky-compass.png",
        "water-mirror": "/images/types-icons/water-mirror.png",
        "flower-keeper": "/images/types-icons/sakura-emblem.png",
        windpath: "/images/types-icons/wind-feather.png",
        "fire-knot": "/images/types-icons/fire-knot.png",
        shirone: "/images/types-icons/magic-circle.png",
        sumine: "/images/types-icons/crystal-geometry.png",
        futane: "/images/types-icons/twin-moons.png",
        amane: "/images/types-icons/holy-light.png"
      };
      const biorhythmLabels = {
        physical: "体",
        emotional: "心",
        intellectual: "思考"
      };
      const biorhythmLevelLabels = {
        low: "静かな波",
        middle: "穏やか",
        high: "満ちる波"
      };
      const biorhythmLevelValues = {
        low: 1,
        middle: 2,
        high: 3
      };
      const biorhythmWaveSeries = [
        { key: "physical", label: "身体", period: 23, className: "physical" },
        { key: "emotional", label: "感情", period: 28, className: "emotional" },
        { key: "intellectual", label: "思考", period: 33, className: "intellectual" }
      ];
      const biorhythmWaveRange = 15;
      const biorhythmSvgWidth = 600;
      const biorhythmSvgHeight = 220;
      const biorhythmSvgPaddingX = 32;
      const biorhythmSvgMidY = 108;
      const biorhythmSvgAmplitude = 68;

      function normalizeIconHintTone(tone) {
        const value = String(tone || "gray");
        return iconHintTones.has(value) ? value : "gray";
      }

      function normalizeIconHint(hint) {
        if (!hint || typeof hint !== "object") return null;

        const icon = String(hint.icon || "").trim();
        const label = String(hint.label || "").trim();
        const value = String(hint.value || "").trim();

        if (!icon && !label && !value) return null;

        return {
          icon: icon || "・",
          label: label || "手がかり",
          key: String(hint.key || "").trim(),
          value,
          tone: normalizeIconHintTone(hint.tone)
        };
      }

      function extractIconHints(source) {
        if (!source || typeof source !== "object") return [];

        const candidates = [
          source.iconHints,
          source.icon_hints,
          source.result?.iconHints,
          source.result?.icon_hints,
          source.historyPayloadV2?.result?.iconHints,
          source.history_payload_v2?.result?.iconHints,
          source.result?.historyPayloadV2?.result?.iconHints,
          source.result?.history_payload_v2?.result?.iconHints
        ];

        const rawHints = candidates.find((candidate) => Array.isArray(candidate));
        if (!rawHints) return [];

        return rawHints.map(normalizeIconHint).filter(Boolean);
      }

      function renderIllustrationIcon(src, alt, className = "") {
        if (!src) return "";

        return `
          <img
            class="${escapeHtml(className)}"
            src="${escapeHtml(src)}"
            alt="${escapeHtml(alt)}"
            loading="lazy"
            decoding="async"
          />
        `;
      }

      function getHintIconName(hint) {
        const key = String(hint?.key || "").toLowerCase();
        const label = String(hint?.label || "");
        const value = String(hint?.value || "");

        if (key.includes("numerology") || label.includes("数") || value.includes("LP")) return "lpBadge";
        if (key.includes("astrology") || label.includes("星")) return "zodiac";
        if (key.includes("biorhythm") || label.includes("波")) return "thinkingWave";
        return "";
      }

      function renderIconHints(source) {
        const iconHints = Array.isArray(source)
          ? source.map(normalizeIconHint).filter(Boolean)
          : extractIconHints(source);

        if (!iconHints.length) return "";

        return `
          <section class="fortune-icon-hints-section" aria-label="今日の小さな手がかり">
            <h2 class="fortune-icon-hints-title">今日の小さな手がかり</h2>
            <div class="fortune-icon-hints-grid">
              ${iconHints
                .map((hint) => {
                  const iconName = getHintIconName(hint);
                  const iconSrc = shironeIconMap[iconName];
                  const iconAlt = iconName === "lpBadge"
                    ? "数秘の手がかりを示すアイコン"
                    : iconName === "zodiac"
                      ? "星の手がかりを示すアイコン"
                      : iconName === "thinkingWave"
                        ? "波の手がかりを示すアイコン"
                        : "";

                  return `
                    <article class="fortune-icon-hint-card tone-${hint.tone}">
                      <div class="fortune-illustration-icon fortune-icon-hint-symbol">
                        ${iconSrc ? renderIllustrationIcon(iconSrc, iconAlt, "fortune-illustration-icon-image") : escapeHtml(hint.icon)}
                      </div>
                      <div class="fortune-icon-hint-text">
                        <div class="fortune-icon-hint-label">${escapeHtml(hint.label)}</div>
                        <div class="fortune-icon-hint-value">${escapeHtml(hint.value)}</div>
                      </div>
                    </article>
                  `;
                })
                .join("")}
            </div>
          </section>
        `;
      }

      function renderHistoryKeyCards(result) {
        const cards = [
          { label: "鑑定日", value: result.fortuneDate, icon: shironeIconMap.calendar, alt: "月の暦のアイコン" },
          { label: "星座", value: result.zodiac, icon: shironeIconMap.zodiac, alt: "星座盤のアイコン" },
          { label: "ライフパス", value: result.lifePathNumber, icon: shironeIconMap.lifepath, alt: "星の道のアイコン" },
          { label: "パーソナルデイ", value: result.personalDayNumber, icon: shironeIconMap.personalDay, alt: "今日の光のアイコン" },
          { label: "名前ナンバー", value: result.nameNumber, icon: shironeIconMap.nameNumber, alt: "名前とペンのアイコン" },
          { label: "キーワード", value: result.keyword, icon: shironeIconMap.keyword, alt: "鍵とリボンのアイコン", featured: true }
        ].filter((card) => card.value);

        if (!cards.length) return "";

        return `
          <section class="fortune-key-section" aria-label="今日の鍵">
            <div class="fortune-section-head">
              <span class="fortune-section-kicker">TODAY'S KEY</span>
              <h2>今日の鍵</h2>
            </div>
            <div class="fortune-key-grid">
              ${cards
                .map(
                  (card) => `
                    <article class="fortune-key-card${card.featured ? " is-featured" : ""}">
                      <span class="fortune-illustration-icon fortune-key-symbol">${renderIllustrationIcon(card.icon, card.alt, "fortune-illustration-icon-image")}</span>
                      <div>
                        <p class="fortune-key-label">${escapeHtml(card.label)}</p>
                        <p class="fortune-key-value">${escapeHtml(card.value)}</p>
                      </div>
                    </article>
                  `
                )
                .join("")}
            </div>
          </section>
        `;
      }

      function renderHistoryShironeTypeCard(birthDate) {
        const shironeType = getShironeTypeByBirthDate(String(birthDate || ""));
        if (!shironeType) return "";

        const displayName = getShironeTypeDisplayName(shironeType);
        const phaseLabel = shironeType.phase ? shironeType.phase.label : "";
        const title = phaseLabel ? `${displayName}・${phaseLabel}` : displayName;
        const iconSrc = typeIconImages[shironeType.slug];
        const phaseDetail = shironeType.phase
          ? getShironePhaseDetail(shironeType, shironeType.phase.key)
          : "";
        const phaseHtml = shironeType.phase
          ? `
              <div class="fortune-seven-type-phase">
                <span>${escapeHtml(shironeType.phase.label)}</span>
                <p>${escapeHtml(phaseDetail || shironeType.phase.description)}</p>
              </div>
            `
          : shironeType.specialNote
            ? `<div class="fortune-seven-type-phase"><p>${escapeHtml(shironeType.specialNote)}</p></div>`
            : "";
        const iconHtml = iconSrc
          ? `<img src="${escapeHtml(iconSrc)}" alt="${escapeHtml(displayName)}" loading="lazy" decoding="async" />`
          : `<span>${escapeHtml(shironeType.icon || displayName.slice(0, 1))}</span>`;

        return `
          <section class="fortune-seven-type-card" aria-label="あなたの属性">
            <div class="fortune-section-head">
              <span class="fortune-section-kicker">SHIRONE ATTRIBUTE</span>
              <h2>あなたの属性</h2>
            </div>
            <div class="fortune-seven-type-main">
              <div class="fortune-seven-type-icon" aria-hidden="true">${iconHtml}</div>
              <div>
                <h3>${escapeHtml(title)}</h3>
                <span>${escapeHtml(shironeType.reading)}</span>
                <p>${escapeHtml(shironeType.catchphrase)}</p>
                ${phaseHtml}
              </div>
            </div>
          </section>
        `;
      }

      function extractBiorhythm(source) {
        if (!source || typeof source !== "object") return null;

        const candidates = [
          source.knowledgePayload?.context?.biorhythm,
          source.knowledge_payload?.context?.biorhythm,
          source.historyPayloadV2?.knowledgePayload?.context?.biorhythm,
          source.history_payload_v2?.knowledgePayload?.context?.biorhythm,
          source.result?.knowledgePayload?.context?.biorhythm,
          source.result?.knowledge_payload?.context?.biorhythm,
          source.result?.historyPayloadV2?.knowledgePayload?.context?.biorhythm,
          source.result?.history_payload_v2?.knowledgePayload?.context?.biorhythm
        ];

        return (
          candidates.find(
            (candidate) =>
              candidate &&
              typeof candidate === "object" &&
              candidate.physical &&
              candidate.emotional &&
              candidate.intellectual
          ) || null
        );
      }

      function normalizeBiorhythmLevel(level) {
        const value = String(level || "middle");
        return Object.prototype.hasOwnProperty.call(biorhythmLevelValues, value) ? value : "middle";
      }

      function parseDateValue(value) {
        const match = String(value || "").match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if (!match) return null;

        const year = Number(match[1]);
        const month = Number(match[2]);
        const day = Number(match[3]);
        const date = new Date(Date.UTC(year, month - 1, day));

        if (
          date.getUTCFullYear() !== year ||
          date.getUTCMonth() !== month - 1 ||
          date.getUTCDate() !== day
        ) {
          return null;
        }

        return date;
      }

      function daysBetween(fromDate, toDate) {
        const dayMs = 24 * 60 * 60 * 1000;
        return Math.round((toDate.getTime() - fromDate.getTime()) / dayMs);
      }

      function getWavePoint(dayOffset, elapsedDays, period) {
        const graphWidth = biorhythmSvgWidth - biorhythmSvgPaddingX * 2;
        const x =
          biorhythmSvgPaddingX +
          ((dayOffset + biorhythmWaveRange) / (biorhythmWaveRange * 2)) * graphWidth;
        const wave = Math.sin((2 * Math.PI * (elapsedDays + dayOffset)) / period);
        const y = biorhythmSvgMidY - wave * biorhythmSvgAmplitude;

        return { x, y };
      }

      function renderBiorhythmWavePath(elapsedDays, period) {
        return Array.from({ length: biorhythmWaveRange * 2 + 1 }, (_, index) => {
          const dayOffset = index - biorhythmWaveRange;
          const point = getWavePoint(dayOffset, elapsedDays, period);
          return `${index === 0 ? "M" : "L"} ${point.x.toFixed(1)} ${point.y.toFixed(1)}`;
        }).join(" ");
      }

      function renderBiorhythmWaveGraph(birthDate, fortuneDate) {
        const birth = parseDateValue(birthDate);
        const today = parseDateValue(fortuneDate);
        if (!birth || !today) return "";

        const elapsedDays = daysBetween(birth, today);
        const todayX = biorhythmSvgWidth / 2;
        const paths = biorhythmWaveSeries
          .map((series) => {
            const todayPoint = getWavePoint(0, elapsedDays, series.period);
            return `
              <path class="fortune-bio-wave-line ${series.className}" d="${renderBiorhythmWavePath(elapsedDays, series.period)}" />
              <circle class="fortune-bio-wave-point ${series.className}" cx="${todayPoint.x.toFixed(1)}" cy="${todayPoint.y.toFixed(1)}" r="4.2" />
            `;
          })
          .join("");

        return `
          <div class="fortune-bio-wave-wrap">
            <p class="fortune-bio-wave-lead">
              今日を中心に<br />
              身体・感情・思考の波を静かに映しています
            </p>
            <svg class="fortune-bio-wave" viewBox="0 0 ${biorhythmSvgWidth} ${biorhythmSvgHeight}" role="img" aria-label="この日を中心にした心と体と思考の波形">
              <line class="fortune-bio-wave-axis" x1="${biorhythmSvgPaddingX}" y1="${biorhythmSvgMidY}" x2="${biorhythmSvgWidth - biorhythmSvgPaddingX}" y2="${biorhythmSvgMidY}" />
              <line class="fortune-bio-wave-today" x1="${todayX}" y1="24" x2="${todayX}" y2="${biorhythmSvgHeight - 34}" />
              <text class="fortune-bio-wave-label" x="${biorhythmSvgPaddingX}" y="${biorhythmSvgHeight - 12}">-15日</text>
              <text class="fortune-bio-wave-label today" x="${todayX}" y="${biorhythmSvgHeight - 12}">今日</text>
              <text class="fortune-bio-wave-label end" x="${biorhythmSvgWidth - biorhythmSvgPaddingX}" y="${biorhythmSvgHeight - 12}">+15日</text>
              ${paths}
            </svg>
            <div class="fortune-bio-wave-legend" aria-label="波形の凡例">
              ${biorhythmWaveSeries
                .map(
                  (series) => `
                    <span class="${series.className}">
                      <i></i>${escapeHtml(series.label)}
                    </span>
                  `
                )
                .join("")}
            </div>
          </div>
        `;
      }

      function renderBiorhythmGauge(source, birthDate, fortuneDate) {
        const biorhythm = extractBiorhythm(source);
        if (!biorhythm) return "";
        const waveGraph = renderBiorhythmWaveGraph(birthDate, fortuneDate);

        const rows = ["physical", "emotional", "intellectual"].map((key) => {
          const level = normalizeBiorhythmLevel(biorhythm[key]);
          const value = biorhythmLevelValues[level];

          return `
            <article class="fortune-bio-card level-${level}">
              <div class="fortune-bio-card-head">
                <span>${escapeHtml(biorhythmLabels[key])}</span>
                <strong>${escapeHtml(biorhythmLevelLabels[level])}</strong>
              </div>
              <div class="fortune-bio-gauge" aria-label="${escapeHtml(biorhythmLabels[key])} ${escapeHtml(biorhythmLevelLabels[level])}">
                ${[1, 2, 3]
                  .map((step) => `<span class="${step <= value ? "is-lit" : ""}"></span>`)
                  .join("")}
              </div>
              <p>${escapeHtml(biorhythmLevelLabels[level])}</p>
            </article>
          `;
        });

        return `
          <section class="fortune-biorhythm-section" aria-label="今日の波">
            <div class="fortune-section-head">
              <span class="fortune-section-kicker">TODAY'S WAVE</span>
              <h2>今日の波</h2>
            </div>
            ${waveGraph}
            <div class="fortune-bio-grid">
              ${rows.join("")}
            </div>
          </section>
        `;
      }

      function getUserId() {
        return (
          localStorage.getItem("user_id") ||
          localStorage.getItem("userId") ||
          localStorage.getItem("loginEmail") ||
          ""
        );
      }

      function getAuthToken() {
        return localStorage.getItem("token") || "";
      }

      function getHistoryIdFromPath() {
        const pathParts = window.location.pathname.split("/");
        const rawHistoryId = pathParts[pathParts.length - 1] || "";
        return decodeURIComponent(rawHistoryId);
      }

      function formatDate(item) {
        const raw =
          item?.created_at ||
          item?.createdAt ||
          item?.timestamp ||
          item?.updated_at ||
          "";

        if (!raw) return "日時不明";

        const d = new Date(raw);
        if (Number.isNaN(d.getTime())) return raw;

        return d.toLocaleString("ja-JP", {
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit"
        });
      }

      function normalizeStatus(status) {
        return String(status || "").toLowerCase();
      }

      function getStatusInfo(status) {
        const normalized = normalizeStatus(status);

        if (normalized === "completed") {
          return {
            label: "✅ 完了",
            className: "fortune-detail-status completed",
            lead: "鑑定は完了しています。今日の流れと、今のあなたに必要な視点を受け取ってください。"
          };
        }

        if (normalized === "processing" || normalized === "pending" || normalized === "transcribing") {
          return {
            label: "🔄 処理中",
            className: "fortune-detail-status processing",
            lead: "ただいま鑑定を生成しています。少し時間を空けてから再読み込みしてください。"
          };
        }

        if (normalized === "error" || normalized === "failed") {
          return {
            label: "確認が必要です",
            className: "fortune-detail-status error",
            lead: "鑑定を確認できませんでした。少し時間を置いて、もう一度お試しください。"
          };
        }

        return {
          label: "・状態不明",
          className: "fortune-detail-status unknown",
          lead: "鑑定の状態を確認しています。少し時間を置いて再読み込みしてください。"
        };
      }

      function getHistoryKind(item) {
        const type = String(item?.type || "").toLowerCase();
        const source = String(item?.source || "").toLowerCase();

        if (type === "normal" || source === "free_result") {
          return "normal";
        }

        if (type === "voice" || source === "premium_voice") {
          return "voice";
        }

        return "unknown";
      }

      function extractNormalResult(item) {
        const result = item?.result && typeof item.result === "object" ? item.result : {};

        return {
          engineVersion: result.engineVersion || result.engine_version || item?.engineVersion || item?.engine_version || "",
          fortuneDate: result.fortuneDate || result.fortune_date || item?.fortuneDate || item?.fortune_date || "",
          theme: result.theme || result.todayTheme || result.today_theme || "",
          keyword: result.keyword || result.keyWord || "",
          summary: result.summary || item?.summary || item?.result_preview || "",
          today: result.today || result.flow || result.todayResult || result.today_flow || result.todayFlow || "",
          mind: result.mind || result.mindset || result.heart || "",
          outer: result.outer || result.outerResult || result.outer_impression || result.outerImpression || "",
          action: result.action || result.luckyAction || result.actionResult || result.action_hint || result.actionHint || "",
          caution: result.caution || result.avoid || result.warning || "",
          luckyAction: result.luckyAction || result.lucky_action || "",
          yearNumber: result.yearNumber || result.year_number || item?.yearNumber || "",
          lifePathNumber: result.lifePathNumber || result.life_path_number || "",
          personalDayNumber: result.personalDayNumber || result.personal_day_number || "",
          nameNumber: result.nameNumber || result.name_number || "",
          zodiac: result.zodiac || item?.zodiac || "",
          nameScore: result.nameScore || result.name_score || "",
          name: item?.name || result.name || "",
          birthday: item?.birth_date || result.birthday || result.birth_date || "",
          gender: item?.gender || result.gender || ""
        };
      }

      const shironeReadingTitleSet = new Set(["今日の一文", "今の余白", "無理しない一歩"]);
      const summarySectionTitleSet = new Set([
        "今日のまとめ",
        "今日のテーマ",
        "今日の流れ",
        "心の向き",
        "外から見えるあなた",
        "周囲に映るあなた",
        "今日の行動ヒント",
        "今日の小さな一歩",
        "避けたいこと",
        "気をつけたい流れ"
      ]);

      function normalizeReadingSection(section) {
        if (!section) return null;

        if (typeof section === "string") {
          const body = section.trim();
          return body ? { title: "", body } : null;
        }

        if (typeof section !== "object") return null;

        const title = String(section.title || section.heading || section.label || section.name || "").trim();
        const body = String(
          section.body ||
            section.text ||
            section.content ||
            section.value ||
            section.description ||
            section.message ||
            ""
        ).trim();

        if (!title && !body) return null;
        return { title, body };
      }

      function collectReadingSectionsFromArray(source) {
        if (!Array.isArray(source)) return [];

        return source
          .map(normalizeReadingSection)
          .filter(Boolean)
          .filter((section) => {
            if (shironeReadingTitleSet.has(section.title)) return true;
            if (summarySectionTitleSet.has(section.title)) return false;
            return section.title.includes("読み解き") || section.title.includes("一文") || section.title.includes("余白") || section.title.includes("一歩");
          });
      }

      function getUniqueReadingSections(sections) {
        const seen = new Set();
        return sections.filter((section) => {
          const key = `${section.title}\n${section.body}`;
          if (seen.has(key)) return false;
          seen.add(key);
          return true;
        });
      }

      function extractShironeReadingSections(item, normalResult) {
        const result = item?.result && typeof item.result === "object" ? item.result : {};
        const candidates = [
          result.sections,
          result.reading?.sections,
          result.content?.sections,
          result.knowledgePayload?.sections,
          result.knowledgePayload?.reading?.sections,
          result.knowledge_payload?.sections,
          result.knowledge_payload?.reading?.sections,
          item?.sections,
          item?.reading?.sections,
          item?.content?.sections,
          item?.knowledgePayload?.sections,
          item?.knowledgePayload?.reading?.sections,
          item?.knowledge_payload?.sections,
          item?.knowledge_payload?.reading?.sections,
          item?.historyPayloadV2?.result?.sections,
          item?.historyPayloadV2?.knowledgePayload?.sections,
          item?.historyPayloadV2?.knowledgePayload?.reading?.sections,
          item?.history_payload_v2?.result?.sections,
          item?.history_payload_v2?.knowledgePayload?.sections,
          item?.history_payload_v2?.knowledgePayload?.reading?.sections
        ];

        const sectionMatches = getUniqueReadingSections(candidates.flatMap(collectReadingSectionsFromArray));
        if (sectionMatches.length) return sectionMatches;

        const duplicateTexts = new Set(
          [
            normalResult.summary,
            normalResult.theme,
            normalResult.today,
            normalResult.mind,
            normalResult.outer,
            normalResult.action,
            normalResult.luckyAction,
            normalResult.caution
          ]
            .map((value) => String(value || "").trim())
            .filter(Boolean)
        );

        const fallbackText = [
          result.shironeReading,
          result.shirone_reading,
          result.interpretation,
          result.narrative,
          result.detail,
          result.body,
          result.fullText,
          result.full_text,
          result.reading?.body,
          result.reading?.text,
          result.reading?.content,
          result.knowledgePayload?.reading?.body,
          result.knowledgePayload?.reading?.text,
          result.knowledgePayload?.result,
          result.knowledge_payload?.reading?.body,
          result.knowledge_payload?.reading?.text,
          result.knowledge_payload?.result,
          item?.storedResult,
          item?.fullText,
          item?.full_text,
          item?.body,
          item?.detail,
          item?.narrative,
          item?.interpretation
        ]
          .map((value) => String(value || "").trim())
          .find((value) => value && !duplicateTexts.has(value));

        return fallbackText ? [{ title: "", body: fallbackText }] : [];
      }

      function renderShironeReadingSections(sections) {
        const validSections = getUniqueReadingSections(
          (Array.isArray(sections) ? sections : [])
            .map(normalizeReadingSection)
            .filter(Boolean)
        );

        if (!validSections.length) return "";

        return `
          <section class="fortune-shirone-reading-section" aria-label="白音七からの読み解き">
            <div class="fortune-section-head">
              <span class="fortune-section-kicker">SHIRONE READING</span>
              <h2>白音七からの読み解き</h2>
            </div>
            <div class="fortune-shirone-reading-list">
              ${validSections
                .map(
                  (section) => `
                    <article class="fortune-shirone-reading-item">
                      ${section.title ? `<h3>${escapeHtml(section.title)}</h3>` : ""}
                      ${section.body ? `<p>${nl2br(section.body)}</p>` : ""}
                    </article>
                  `
                )
                .join("")}
            </div>
          </section>
        `;
      }

      function extractVoiceResult(item) {
        const result = item?.result && typeof item.result === "object" ? item.result : {};

        const summary =
          result.summary ||
          item.summary ||
          item.result_preview ||
          item.result_text ||
          "";

        const fullText =
          result.full_text ||
          result.fullText ||
          item.result_text ||
          "";

        const todayFlow =
          result.today_flow ||
          result.todayFlow ||
          result.today ||
          "";

        const outerImpression =
          result.outer_impression ||
          result.outerImpression ||
          result.outer ||
          "";

        const actionHint =
          result.action_hint ||
          result.actionHint ||
          result.action ||
          "";

        return {
          summary,
          fullText,
          todayFlow,
          outerImpression,
          actionHint
        };
      }

      function renderMeta(item, title, kindLabel) {
        const dateText = formatDate(item);
        const historyId = item?.history_id || item?.id || "不明";
        const userId = item?.user_id || getUserId() || "不明";

        return `
