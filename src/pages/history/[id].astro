        min-height: 82px;
        gap: 0.75rem;
        padding: 0.9rem 1rem;
        border: 1px solid rgba(226, 191, 92, 0.18);
        border-radius: 16px;
        background:
          radial-gradient(circle at 50px 50%, rgba(216, 190, 117, 0.14), transparent 44px),
          rgba(13, 15, 36, 0.94);
        box-shadow: none;
      }

      .fortune-icon-hint-card::after {
        content: "";
        position: absolute;
        inset: 0;
