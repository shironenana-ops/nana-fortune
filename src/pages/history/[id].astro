        margin: 0;
        color: #fff0bd;
        font-size: clamp(1.08rem, 2vw, 1.28rem);
        letter-spacing: 0;
      }

      .fortune-key-section {
        margin: 1.25rem 0;
      }

      .fortune-key-section + .fortune-detail-section {
        display: none;
      }

      .fortune-key-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
