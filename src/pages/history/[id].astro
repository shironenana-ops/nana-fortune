        font-size: 1rem;
        font-weight: 800;
        overflow-wrap: anywhere;
      }

      .fortune-icon-hint-card.tone-purple {
        border-color: rgba(189, 154, 255, 0.24);
      }

      .fortune-icon-hint-card.tone-blue {
        border-color: rgba(137, 188, 255, 0.24);
