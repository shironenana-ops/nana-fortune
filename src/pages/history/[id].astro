        border-radius: 14px;
        object-fit: contain;
      }

      .fortune-key-symbol .fortune-illustration-icon-image {
        width: 48px;
        height: 48px;
      }

      .fortune-key-label,
      .fortune-key-value {
        margin: 0;
        letter-spacing: 0;
      }

      .fortune-key-label {
        color: rgba(255, 240, 189, 0.66);
        font-size: 0.78rem;
        font-weight: 800;
        text-shadow: 0 1px 8px rgba(0, 0, 0, 0.34);
      }

      .fortune-key-value {
        color: #fff4cf;
        font-size: clamp(1rem, 2vw, 1.18rem);
