        `;
      }

      function renderEmptyDetail(item) {
        const statusInfo = getStatusInfo(item?.status);

        document.getElementById("detailTitle").textContent = "鑑定履歴";
        document.getElementById("detailLead").textContent =
          "保存された鑑定結果を確認するページです。";

        return `
          <div class="fortune-detail-status-row">
            <span class="${statusInfo.className}">${escapeHtml(statusInfo.label)}</span>
          </div>

          <section class="fortune-detail-section">
            <h2 class="fortune-detail-section-title">鑑定結果</h2>
