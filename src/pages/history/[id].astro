            rgba(14, 14, 38, 0.8) 112px,
            rgba(14, 14, 38, 0.95) 100%
          );
      }

      .fortune-key-symbol,
      .fortune-icon-hint-symbol {
        display: grid;
        place-items: center;
        border: 1px solid rgba(255, 236, 179, 0.2);
        background:
          radial-gradient(circle at 36% 24%, rgba(255, 236, 179, 0.13), transparent 55%),
          rgba(255, 255, 255, 0.045);
        color: #ffe8a3;
        box-shadow: 0 0 16px rgba(226, 191, 92, 0.09);
      }

      .fortune-key-symbol {
        flex: 0 0 54px;
        width: 54px;
