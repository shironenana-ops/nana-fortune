---
import "../../styles/global.css";

export const prerender = false;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>鑑定履歴詳細 | 白音七</title>
    <meta name="description" content="白音七の鑑定履歴詳細ページ" />
  </head>

  <body class="fortune-body">
    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav" id="navArea">
          <a href="/">TOP</a>
          <a href="/members">会員ページ</a>
          <a href="/history">履歴一覧</a>
          <a href="/privacy">プライバシーポリシー</a>
          <span id="authArea"></span>
        </nav>
      </div>
    </header>

    <main class="fortune-history-detail-page">
      <div class="fortune-container">
        <section class="fortune-history-detail-frame fortune-detail-page-frame">
          <div class="fortune-detail-hero">
            <div class="fortune-detail-kicker">SHIRONE7 DIVINATION DETAIL</div>
            <h1 id="detailTitle" class="fortune-history-detail-title fortune-detail-page-title">
              静かに導かれる、あなたの流れ
            </h1>
            <p id="detailLead" class="fortune-detail-page-lead">
              保存された鑑定結果を、静かに受け取り、振り返るためのページです。
            </p>
          </div>

          <div id="detail" class="fortune-detail-loading">読み込み中...</div>
        </section>
      </div>
    </main>

    <script>
      const API_BASE = "https://mydmaywesh.execute-api.ap-northeast-1.amazonaws.com/prod";
      import { shironeIconMap } from "../../lib/shironeIconMap";

      const authArea = document.getElementById("authArea");
      const token = localStorage.getItem("token");
      const email = localStorage.getItem("loginEmail");

      if (token && email) {
        authArea.innerHTML = `
          <span class="fortune-user">${email}</span>
          <button id="logoutBtn" class="fortune-nav-logout" type="button">ログアウト</button>
        `;

        document.getElementById("logoutBtn").addEventListener("click", () => {
          localStorage.removeItem("token");
          localStorage.removeItem("loginEmail");
          localStorage.removeItem("user_id");
          localStorage.removeItem("userId");
          window.location.href = "/";
        });
      } else {
        authArea.innerHTML = `
          <a href="/login" class="fortune-nav-pill">会員ログイン</a>
        `;
      }

      function escapeHtml(str) {
        return String(str ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function nl2br(str) {
        return escapeHtml(str).replace(/\n/g, "<br>");
      }

      const iconHintTones = new Set(["gold", "purple", "blue", "green", "gray"]);

      function normalizeIconHintTone(tone) {
        const value = String(tone || "gray");
        return iconHintTones.has(value) ? value : "gray";
      }

      function normalizeIconHint(hint) {
        if (!hint || typeof hint !== "object") return null;

        const icon = String(hint.icon || "").trim();
        const label = String(hint.label || "").trim();
        const value = String(hint.value || "").trim();

        if (!icon && !label && !value) return null;

        return {
          icon: icon || "・",
          label: label || "手がかり",
          key: String(hint.key || "").trim(),
          value,
          tone: normalizeIconHintTone(hint.tone)
        };
      }

      function extractIconHints(source) {
        if (!source || typeof source !== "object") return [];

        const candidates = [
          source.iconHints,
          source.icon_hints,
          source.result?.iconHints,
          source.result?.icon_hints,
          source.historyPayloadV2?.result?.iconHints,
          source.history_payload_v2?.result?.iconHints,
          source.result?.historyPayloadV2?.result?.iconHints,
          source.result?.history_payload_v2?.result?.iconHints
        ];

        const rawHints = candidates.find((candidate) => Array.isArray(candidate));
        if (!rawHints) return [];

        return rawHints.map(normalizeIconHint).filter(Boolean);
      }

      function renderIllustrationIcon(src, alt, className = "") {
        if (!src) return "";

        return `
          <img
            class="${escapeHtml(className)}"
            src="${escapeHtml(src)}"
            alt="${escapeHtml(alt)}"
            loading="lazy"
            decoding="async"
          />
        `;
      }

      function getHintIconName(hint) {
        const key = String(hint?.key || "").toLowerCase();
        const label = String(hint?.label || "");
        const value = String(hint?.value || "");

        if (key.includes("numerology") || label.includes("数") || value.includes("LP")) return "lpBadge";
        if (key.includes("astrology") || label.includes("星")) return "zodiac";
        if (key.includes("biorhythm") || label.includes("波")) return "thinkingWave";
        return "";
      }

      function renderIconHints(source) {
        const iconHints = Array.isArray(source)
          ? source.map(normalizeIconHint).filter(Boolean)
          : extractIconHints(source);

        if (!iconHints.length) return "";

        return `
          <section class="fortune-icon-hints-section" aria-label="今日の小さな手がかり">
            <h2 class="fortune-icon-hints-title">今日の小さな手がかり</h2>
            <div class="fortune-icon-hints-grid">
              ${iconHints
                .map((hint) => {
                  const iconName = getHintIconName(hint);
                  const iconSrc = shironeIconMap[iconName];
                  const iconAlt = iconName === "lpBadge"
                    ? "数秘の手がかりを示すアイコン"
                    : iconName === "zodiac"
                      ? "星の手がかりを示すアイコン"
                      : iconName === "thinkingWave"
                        ? "波の手がかりを示すアイコン"
                        : "";

                  return `
                    <article class="fortune-icon-hint-card tone-${hint.tone}">
                      <div class="fortune-illustration-icon fortune-icon-hint-symbol">
                        ${iconSrc ? renderIllustrationIcon(iconSrc, iconAlt, "fortune-illustration-icon-image") : escapeHtml(hint.icon)}
                      </div>
                      <div class="fortune-icon-hint-text">
                        <div class="fortune-icon-hint-label">${escapeHtml(hint.label)}</div>
                        <div class="fortune-icon-hint-value">${escapeHtml(hint.value)}</div>
                      </div>
                    </article>
                  `;
                })
                .join("")}
            </div>
          </section>
        `;
      }

      function renderHistoryKeyCards(result) {
        const cards = [
          { label: "鑑定日", value: result.fortuneDate, icon: shironeIconMap.calendar, alt: "月の暦のアイコン" },
          { label: "星座", value: result.zodiac, icon: shironeIconMap.zodiac, alt: "星座盤のアイコン" },
          { label: "ライフパス", value: result.lifePathNumber, icon: shironeIconMap.lifepath, alt: "星の道のアイコン" },
          { label: "パーソナルデイ", value: result.personalDayNumber, icon: shironeIconMap.personalDay, alt: "今日の光のアイコン" },
          { label: "名前ナンバー", value: result.nameNumber, icon: shironeIconMap.nameNumber, alt: "名前とペンのアイコン" },
          { label: "キーワード", value: result.keyword, icon: shironeIconMap.keyword, alt: "鍵とリボンのアイコン", featured: true }
        ].filter((card) => card.value);

        if (!cards.length) return "";

        return `
          <section class="fortune-key-section" aria-label="今日の鍵">
            <div class="fortune-section-head">
              <span class="fortune-section-kicker">TODAY'S KEY</span>
              <h2>今日の鍵</h2>
            </div>
            <div class="fortune-key-grid">
              ${cards
                .map(
                  (card) => `
                    <article class="fortune-key-card${card.featured ? " is-featured" : ""}">
                      <span class="fortune-illustration-icon fortune-key-symbol">${renderIllustrationIcon(card.icon, card.alt, "fortune-illustration-icon-image")}</span>
                      <div>
                        <p class="fortune-key-label">${escapeHtml(card.label)}</p>
                        <p class="fortune-key-value">${escapeHtml(card.value)}</p>
                      </div>
                    </article>
                  `
                )
                .join("")}
            </div>
          </section>
        `;
      }

      function getUserId() {
        return (
          localStorage.getItem("user_id") ||
          localStorage.getItem("userId") ||
          localStorage.getItem("loginEmail") ||
          ""
        );
      }

      function getAuthToken() {
        return localStorage.getItem("token") || "";
      }

      function getHistoryIdFromPath() {
        const pathParts = window.location.pathname.split("/");
        const rawHistoryId = pathParts[pathParts.length - 1] || "";
        return decodeURIComponent(rawHistoryId);
      }

      function formatDate(item) {
        const raw =
          item?.created_at ||
          item?.createdAt ||
          item?.timestamp ||
          item?.updated_at ||
          "";

        if (!raw) return "日時不明";

        const d = new Date(raw);
        if (Number.isNaN(d.getTime())) return raw;

        return d.toLocaleString("ja-JP", {
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit"
        });
      }

      function normalizeStatus(status) {
        return String(status || "").toLowerCase();
      }

      function getStatusInfo(status) {
        const normalized = normalizeStatus(status);

        if (normalized === "completed") {
          return {
            label: "✅ 完了",
            className: "fortune-detail-status completed",
            lead: "鑑定は完了しています。今日の流れと、今のあなたに必要な視点を受け取ってください。"
          };
        }

        if (normalized === "processing" || normalized === "pending" || normalized === "transcribing") {
          return {
            label: "🔄 処理中",
            className: "fortune-detail-status processing",
            lead: "ただいま鑑定を生成しています。少し時間を空けてから再読み込みしてください。"
          };
        }

        if (normalized === "error" || normalized === "failed") {
          return {
            label: "確認が必要です",
            className: "fortune-detail-status error",
            lead: "鑑定を確認できませんでした。少し時間を置いて、もう一度お試しください。"
          };
        }

        return {
          label: "・状態不明",
          className: "fortune-detail-status unknown",
          lead: "鑑定の状態を確認しています。少し時間を置いて再読み込みしてください。"
        };
      }

      function getHistoryKind(item) {
        const type = String(item?.type || "").toLowerCase();
        const source = String(item?.source || "").toLowerCase();

        if (type === "normal" || source === "free_result") {
          return "normal";
        }

        if (type === "voice" || source === "premium_voice") {
          return "voice";
        }

        return "unknown";
      }

      function extractNormalResult(item) {
        const result = item?.result && typeof item.result === "object" ? item.result : {};

        return {
          engineVersion: result.engineVersion || result.engine_version || item?.engineVersion || item?.engine_version || "",
          fortuneDate: result.fortuneDate || result.fortune_date || item?.fortuneDate || item?.fortune_date || "",
          theme: result.theme || result.todayTheme || result.today_theme || "",
          keyword: result.keyword || result.keyWord || "",
          summary: result.summary || item?.summary || item?.result_preview || "",
          today: result.today || result.flow || result.todayResult || result.today_flow || result.todayFlow || "",
          mind: result.mind || result.mindset || result.heart || "",
          outer: result.outer || result.outerResult || result.outer_impression || result.outerImpression || "",
          action: result.action || result.luckyAction || result.actionResult || result.action_hint || result.actionHint || "",
          caution: result.caution || result.avoid || result.warning || "",
          luckyAction: result.luckyAction || result.lucky_action || "",
          yearNumber: result.yearNumber || result.year_number || item?.yearNumber || "",
          lifePathNumber: result.lifePathNumber || result.life_path_number || "",
          personalDayNumber: result.personalDayNumber || result.personal_day_number || "",
          nameNumber: result.nameNumber || result.name_number || "",
          zodiac: result.zodiac || item?.zodiac || "",
          nameScore: result.nameScore || result.name_score || "",
          name: item?.name || result.name || "",
          birthday: item?.birth_date || result.birthday || result.birth_date || "",
          gender: item?.gender || result.gender || ""
        };
      }

      function extractVoiceResult(item) {
        const result = item?.result && typeof item.result === "object" ? item.result : {};

        const summary =
          result.summary ||
          item.summary ||
          item.result_preview ||
          item.result_text ||
          "";

        const fullText =
          result.full_text ||
          result.fullText ||
          item.result_text ||
          "";

        const todayFlow =
          result.today_flow ||
          result.todayFlow ||
          result.today ||
          "";

        const outerImpression =
          result.outer_impression ||
          result.outerImpression ||
          result.outer ||
          "";

        const actionHint =
          result.action_hint ||
          result.actionHint ||
          result.action ||
          "";

        return {
          summary,
          fullText,
          todayFlow,
          outerImpression,
          actionHint
        };
      }

      function renderMeta(item, title, kindLabel) {
        const dateText = formatDate(item);
        const historyId = item?.history_id || item?.id || "不明";
        const userId = item?.user_id || getUserId() || "不明";

        return `
          <div class="fortune-detail-meta-card">
            <dl class="fortune-detail-meta">
              <div class="fortune-detail-meta-row">
                <dt>日時</dt>
                <dd>${escapeHtml(dateText)}</dd>
              </div>
              <div class="fortune-detail-meta-row">
                <dt>タイトル</dt>
                <dd>${escapeHtml(title)}</dd>
              </div>
              <div class="fortune-detail-meta-row">
                <dt>種別</dt>
                <dd>${escapeHtml(kindLabel)}</dd>
              </div>
              <div class="fortune-detail-meta-row">
                <dt>履歴ID</dt>
                <dd>${escapeHtml(historyId)}</dd>
              </div>
              <div class="fortune-detail-meta-row">
                <dt>ユーザー</dt>
                <dd>${escapeHtml(userId)}</dd>
              </div>
            </dl>
          </div>
        `;
      }

      function renderNormalDetail(item) {
        const statusInfo = getStatusInfo(item?.status);
        const result = extractNormalResult(item);
        const title = item?.title || "今日の鑑定";
        const displayName = result.name ? `${result.name}さん` : "あなた";
        const isEngineV1 = String(result.engineVersion || item?.source || "").includes("v1") || Boolean(result.theme || result.mind || result.caution || result.personalDayNumber);

        document.getElementById("detailTitle").textContent = `${displayName}の鑑定履歴`;
        document.getElementById("detailLead").textContent =
          isEngineV1
            ? "白音七 今日の占いエンジンで読み解いた結果です。"
            : "保存された通常鑑定の結果を、今日の流れとして振り返るページです。";

        let html = `
          <div class="fortune-detail-status-row">
            <span class="${statusInfo.className}">${escapeHtml(statusInfo.label)}</span>
          </div>

          ${renderMeta(item, title, "通常鑑定")}

          ${renderIconHints(item)}
          ${renderHistoryKeyCards(result)}

          <section class="fortune-detail-section">
            <h2 class="fortune-detail-section-title">今日の鍵</h2>
            <div class="fortune-detail-main-card">
              <p class="fortune-detail-main-text">
                ${result.name ? `<strong>お名前：</strong>${escapeHtml(result.name)}<br>` : ""}
                ${result.birthday ? `<strong>生年月日：</strong>${escapeHtml(result.birthday)}<br>` : ""}
                ${result.fortuneDate ? `<strong>鑑定日：</strong>${escapeHtml(result.fortuneDate)}<br>` : ""}
                ${result.zodiac ? `<strong>星座：</strong>${escapeHtml(result.zodiac)}<br>` : ""}
                ${result.lifePathNumber ? `<strong>ライフパス：</strong>${escapeHtml(result.lifePathNumber)}<br>` : ""}
                ${result.personalDayNumber ? `<strong>パーソナルデイ：</strong>${escapeHtml(result.personalDayNumber)}<br>` : ""}
                ${result.nameNumber ? `<strong>名前ナンバー：</strong>${escapeHtml(result.nameNumber)}<br>` : ""}
                ${result.keyword ? `<strong>キーワード：</strong>${escapeHtml(result.keyword)}<br>` : ""}
                ${result.yearNumber ? `<strong>イヤーナンバー：</strong>${escapeHtml(result.yearNumber)}` : ""}
              </p>
            </div>
          </section>
        `;

        if (result.summary) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">今日のまとめ</h2>
              <div class="fortune-detail-main-card highlight">
                <p class="fortune-detail-main-text">${nl2br(result.summary)}</p>
              </div>
            </section>
          `;
        }

        if (result.theme) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">今日のテーマ</h2>
              <div class="fortune-detail-main-card highlight">
                <p class="fortune-detail-main-text">${nl2br(result.theme)}</p>
              </div>
            </section>
          `;
        }

        if (result.today) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">今日の流れ</h2>
              <div class="fortune-detail-main-card">
                <p class="fortune-detail-main-text">${nl2br(result.today)}</p>
              </div>
            </section>
          `;
        }

        if (result.mind) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">心の向き</h2>
              <div class="fortune-detail-main-card">
                <p class="fortune-detail-main-text">${nl2br(result.mind)}</p>
              </div>
            </section>
          `;
        }

        if (result.outer) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">外から見えるあなた</h2>
              <div class="fortune-detail-main-card">
                <p class="fortune-detail-main-text">${nl2br(result.outer)}</p>
              </div>
            </section>
          `;
        }

        if (result.action || result.luckyAction) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">今日の行動ヒント</h2>
              <div class="fortune-detail-main-card">
                <p class="fortune-detail-main-text">${nl2br(result.action || result.luckyAction)}</p>
              </div>
            </section>
          `;
        }

        if (result.caution) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">避けたいこと</h2>
              <div class="fortune-detail-main-card">
                <p class="fortune-detail-main-text">${nl2br(result.caution)}</p>
              </div>
            </section>
          `;
        }

        if (!result.summary && !result.theme && !result.today && !result.mind && !result.outer && !result.action && !result.caution) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">鑑定結果</h2>
              <div class="fortune-detail-info-box">
                表示できる通常鑑定結果がありません。
              </div>
            </section>
          `;
        }

        html += `
          <div class="fortune-history-detail-actions fortune-detail-actions">
            <a class="fortune-btn secondary" href="/history">履歴一覧へ戻る</a>
            <a class="fortune-btn secondary" href="/members">会員ページへ戻る</a>
            <a class="fortune-btn violet" href="/diagnosis">もう一度占う</a>
          </div>
        `;

        return html;
      }

      function renderVoiceCompletedDetail(item) {
        const statusInfo = getStatusInfo(item?.status);
        const title = item?.title || item?.input_title || item?.category || "音声鑑定";
        const resultData = extractVoiceResult(item);

        document.getElementById("detailTitle").textContent = "音声鑑定の履歴";
        document.getElementById("detailLead").textContent =
          "保存された音声鑑定の結果を、静かに受け取り、振り返るためのページです。";

        let html = `
          <div class="fortune-detail-status-row">
            <span class="${statusInfo.className}">${escapeHtml(statusInfo.label)}</span>
          </div>

          ${renderMeta(item, title, "音声鑑定")}

          ${renderIconHints(item)}

          <section class="fortune-detail-section">
            <h2 class="fortune-detail-section-title">静かな導入</h2>
            <div class="fortune-detail-main-card">
              <p class="fortune-detail-main-text">${escapeHtml(statusInfo.lead)}</p>
            </div>
          </section>
        `;

        if (resultData.summary) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">今回の鑑定要約</h2>
              <div class="fortune-detail-main-card">
                <p class="fortune-detail-main-text">${nl2br(resultData.summary)}</p>
              </div>
            </section>
          `;
        }

        if (resultData.fullText && resultData.fullText !== resultData.summary) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">詳細メッセージ</h2>
              <div class="fortune-detail-main-card">
                <p class="fortune-detail-main-text">${nl2br(resultData.fullText)}</p>
              </div>
            </section>
          `;
        }

        if (resultData.todayFlow || resultData.outerImpression || resultData.actionHint) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">読み解きの断片</h2>
              <div class="fortune-detail-subgrid">
                ${
                  resultData.todayFlow
                    ? `
                      <article class="fortune-detail-subcard">
                        <h3>今日の流れ</h3>
                        <p>${nl2br(resultData.todayFlow)}</p>
                      </article>
                    `
                    : ""
                }

                ${
                  resultData.outerImpression
                    ? `
                      <article class="fortune-detail-subcard">
                        <h3>外側から見える傾向</h3>
                        <p>${nl2br(resultData.outerImpression)}</p>
                      </article>
                    `
                    : ""
                }

                ${
                  resultData.actionHint
                    ? `
                      <article class="fortune-detail-subcard">
                        <h3>行動ヒント</h3>
                        <p>${nl2br(resultData.actionHint)}</p>
                      </article>
                    `
                    : ""
                }
              </div>
            </section>
          `;
        }

        if (!resultData.summary && !resultData.fullText && !resultData.todayFlow && !resultData.outerImpression && !resultData.actionHint) {
          html += `
            <section class="fortune-detail-section">
              <h2 class="fortune-detail-section-title">鑑定結果</h2>
              <div class="fortune-detail-info-box">
                まだ表示できる鑑定結果がありません。
              </div>
            </section>
          `;
        }

        html += `
          <div class="fortune-history-detail-actions fortune-detail-actions">
            <a class="fortune-btn secondary" href="/history">履歴一覧へ戻る</a>
            <a class="fortune-btn secondary" href="/members">会員ページへ戻る</a>
            <a class="fortune-btn violet" href="/premium/voice">もう一度音声鑑定する</a>
          </div>
        `;

        return html;
      }

      function renderProcessingDetail(item) {
        const statusInfo = getStatusInfo(item?.status);
        const title = item?.title || item?.input_title || item?.category || "鑑定";

        document.getElementById("detailTitle").textContent = "鑑定処理中";
        document.getElementById("detailLead").textContent =
          "鑑定結果を生成しています。少し時間を空けてから再読み込みしてください。";

        return `
          <div class="fortune-detail-status-row">
            <span class="${statusInfo.className}">${escapeHtml(statusInfo.label)}</span>
          </div>

          ${renderMeta(item, title, "処理中")}

          <section class="fortune-detail-section">
            <h2 class="fortune-detail-section-title">処理状況</h2>
            <div class="fortune-detail-info-box">
              ${escapeHtml(statusInfo.lead)}
            </div>
          </section>

          <div class="fortune-history-detail-actions fortune-detail-actions">
            <a class="fortune-btn secondary" href="/history">履歴一覧へ戻る</a>
            <a class="fortune-btn secondary" href="/members">会員ページへ戻る</a>
            <button class="fortune-btn violet" type="button" onclick="window.location.reload()">再読み込み</button>
          </div>
        `;
      }

      function renderErrorDetail(item) {
        const statusInfo = getStatusInfo(item?.status);
        const title = item?.title || item?.input_title || item?.category || "鑑定";

        document.getElementById("detailTitle").textContent = "鑑定を確認できませんでした";
        document.getElementById("detailLead").textContent =
          "少し時間を置いて、もう一度お試しください。";

        const gentleErrorMessage =
          "鑑定を確認できませんでした。少し時間を置いて、もう一度お試しください。";

        return `
          <div class="fortune-detail-status-row">
            <span class="${statusInfo.className}">${escapeHtml(statusInfo.label)}</span>
          </div>

          ${renderMeta(item, title, "確認が必要")}

          <section class="fortune-detail-section">
            <h2 class="fortune-detail-section-title">確認のご案内</h2>
            <div class="fortune-detail-error-box">${nl2br(gentleErrorMessage)}</div>
          </section>

          <div class="fortune-history-detail-actions fortune-detail-actions">
            <a class="fortune-btn secondary" href="/history">履歴一覧へ戻る</a>
            <a class="fortune-btn secondary" href="/members">会員ページへ戻る</a>
            <a class="fortune-btn violet" href="/premium/voice">再鑑定する</a>
          </div>
        `;
      }

      function renderEmptyDetail(item) {
        const statusInfo = getStatusInfo(item?.status);

        document.getElementById("detailTitle").textContent = "鑑定履歴";
        document.getElementById("detailLead").textContent =
          "保存された鑑定結果を確認するページです。";

        return `
          <div class="fortune-detail-status-row">
            <span class="${statusInfo.className}">${escapeHtml(statusInfo.label)}</span>
          </div>

          <section class="fortune-detail-section">
            <h2 class="fortune-detail-section-title">鑑定結果</h2>
            <div class="fortune-detail-info-box">
              まだ表示できる鑑定結果がありません。
            </div>
          </section>

          <div class="fortune-history-detail-actions fortune-detail-actions">
            <a class="fortune-btn secondary" href="/history">履歴一覧へ戻る</a>
            <a class="fortune-btn secondary" href="/members">会員ページへ戻る</a>
          </div>
        `;
      }

      function renderDetail(item) {
        const target = document.getElementById("detail");
        const status = normalizeStatus(item?.status);
        const kind = getHistoryKind(item);

        let html = "";

        if (status === "completed") {
          if (kind === "normal") {
            html = renderNormalDetail(item);
          } else if (kind === "voice") {
            html = renderVoiceCompletedDetail(item);
          } else {
            html = renderVoiceCompletedDetail(item);
          }
        } else if (status === "processing" || status === "pending" || status === "transcribing") {
          html = renderProcessingDetail(item);
        } else if (status === "error" || status === "failed") {
          html = renderErrorDetail(item);
        } else {
          html = renderEmptyDetail(item);
        }

        target.className = "";
        target.innerHTML = html;
      }

      function renderSimpleError(message) {
        const target = document.getElementById("detail");

        document.getElementById("detailTitle").textContent = "鑑定を確認できませんでした";
        document.getElementById("detailLead").textContent =
          "少し時間を置いて、もう一度お試しください。";

        target.className = "fortune-detail-error-state";
        target.innerHTML = `
          <div class="fortune-detail-error-box">${escapeHtml(message)}</div>
          <div class="fortune-history-detail-actions fortune-detail-actions" style="margin-top: 18px;">
            <a class="fortune-btn secondary" href="/history">履歴一覧へ戻る</a>
            <a class="fortune-btn violet" href="/members">会員ページへ戻る</a>
          </div>
        `;
      }

      async function loadDetail() {
        const token = getAuthToken();
        const historyId = getHistoryIdFromPath();

        if (!token) {
          renderSimpleError("ログインしてください。");
          return;
        }

        if (!historyId) {
          renderSimpleError("鑑定の受付情報を確認できませんでした。もう一度、音声鑑定ページからお試しください。");
          return;
        }

        try {
          const res = await fetch(
            `${API_BASE}/history/detail?history_id=${encodeURIComponent(historyId)}`,
            {
              method: "GET",
              headers: {
                Authorization: "Bearer " + token
              }
            }
          );

          if (!res.ok) {
            throw new Error(`API error: ${res.status}`);
          }

          const data = await res.json();
          const item = data?.item || data;

          if (!item || typeof item !== "object") {
            throw new Error("鑑定データが見つかりません。");
          }

          renderDetail(item);
        } catch (err) {
          console.error(err);
          renderSimpleError("鑑定を確認できませんでした。少し時間を置いて、もう一度お試しください。");
        }
      }

      loadDetail();
    </script>

    <style is:global>
