        overflow-wrap: anywhere;
        text-shadow: 0 1px 10px rgba(0, 0, 0, 0.42);
      }

      .fortune-icon-hints-section {
        margin: 1.2rem 0;
      }

      .fortune-icon-hints-title {
        margin: 0 0 0.75rem;
