            rgba(13, 15, 36, 0.78) 112px,
            rgba(13, 15, 36, 0.94) 100%
          );
      }

      .fortune-key-card > * {
        position: relative;
        z-index: 1;
      }

      .fortune-key-card.is-featured {
        border-color: rgba(255, 224, 141, 0.34);
        background:
          radial-gradient(circle at 54px 50%, rgba(255, 224, 141, 0.22), transparent 48px),
