              <div class="fortune-detail-meta-row">
                <dt>ユーザー</dt>
                <dd>${escapeHtml(userId)}</dd>
              </div>
            </dl>
          </div>
        `;
      }

      function renderNormalDetail(item) {
        const statusInfo = getStatusInfo(item?.status);
        const result = extractNormalResult(item);
        const title = item?.title || "今日の鑑定";
