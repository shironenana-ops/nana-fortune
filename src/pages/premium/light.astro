---
import "../../styles/global.css";
import SeoHead from "../../components/SeoHead.astro";

const pageTitle = "ライト鑑定 | 白音七";
const pageDescription =
  "白音七のライト鑑定案内ページです。現在は正式公開に向けて準備中です。";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead title={pageTitle} description={pageDescription} />
  </head>

  <body class="fortune-body reading-light-body">
    <div class="reading-light-bg" aria-hidden="true"></div>

    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav">
          <a href="/">TOP</a>
          <a href="/members">会員ページ</a>
          <a href="/premium">会員限定鑑定</a>
          <a href="/history">履歴一覧</a>
        </nav>
      </div>
    </header>

    <main class="fortune-premium-page reading-door-page">
      <section class="fortune-container reading-door-shell">
        <article class="fortune-premium-page-frame reading-door-frame">
          <div class="reading-door-kicker">LIGHT READING</div>
          <h1>ライト鑑定</h1>

          <p class="reading-door-lead">
            今日の流れと、今のあなたに必要なメッセージを、<br />
            無料鑑定よりも少し丁寧に受け取るための鑑定です。<br /><br />
            正式なご案内まで、今しばらくお待ちください。
          </p>

          <div class="reading-door-grid" aria-label="ライト鑑定の案内">
            <section class="reading-door-panel">
              <h2>この鑑定について</h2>
              <p>
                ライト鑑定は、日々の迷いや小さな節目に、もう一歩だけ深く寄り添うための鑑定として準備しています。
              </p>
            </section>

            <section class="reading-door-panel">
              <h2>現在の状態</h2>
              <p>
                現在は正式公開に向けて、鑑定の受け取り方を静かに整えています。
              </p>
            </section>

            <section class="reading-door-panel">
              <h2>これからのご案内</h2>
              <p>
                準備が整いましたら、内容と価格を確認できる形でご案内します。
              </p>
            </section>
          </div>

          <section class="reading-input-shell" aria-label="ライト鑑定の準備中案内">
            <div class="reading-input-head">
              <span>準備中</span>
              <strong>light</strong>
            </div>

            <p class="reading-input-message">
              ライト鑑定への扉は、現在静かに準備中です。<br />
              この画面で入力を求めたり、料金が発生したりすることはありません。
            </p>

            <div class="reading-preparing-actions">
              <button class="fortune-btn gold" type="button" aria-disabled="true">
                ライト鑑定（準備中）
              </button>
              <a href="/premium" class="fortune-btn secondary">会員限定鑑定へ戻る</a>
              <a href="/members" class="fortune-btn secondary">会員ページへ</a>
            </div>
          </section>

          <p class="reading-door-note">
            一度届けられた鑑定本文は、その人の大切な履歴として残ります。<br />
            新しい鑑定を受け取るための扉は、現在の会員状態に合わせて整えていきます。
          </p>
        </article>
      </section>
    </main>

    <style>
      :global(body.reading-light-body) {
        overflow-x: hidden;
        background-color: #070511;
      }

      .reading-light-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(7, 5, 17, 0.34), rgba(7, 5, 17, 0.78)),
          radial-gradient(circle at 50% 8%, rgba(226, 190, 92, 0.16), transparent 34%),
          url("/images/backgrounds/reading/mobile/reading-light-mobile-01.webp");
        background-size: cover, cover, cover;
        background-position: center center, top center, center center;
        background-repeat: no-repeat;
      }

      :global(body.reading-light-body .fortune-header),
      .reading-door-shell {
        position: relative;
        z-index: 1;
      }

      .reading-door-shell {
        padding: 48px 0 88px;
      }

      .reading-door-frame {
        position: relative;
        overflow: hidden;
        padding: clamp(28px, 5vw, 46px);
        background:
          radial-gradient(circle at 84% 16%, rgba(226, 190, 92, 0.16), transparent 30%),
          linear-gradient(180deg, rgba(12, 14, 32, 0.88), rgba(24, 15, 38, 0.84));
        box-shadow:
          0 22px 70px rgba(0, 0, 0, 0.38),
          inset 0 0 0 1px rgba(255, 238, 185, 0.04);
      }

      .reading-door-frame::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at 14% 10%, rgba(255, 229, 158, 0.13), transparent 24%),
          radial-gradient(circle at 88% 34%, rgba(214, 174, 64, 0.1), transparent 30%);
      }

      .reading-door-frame > * {
        position: relative;
        z-index: 1;
        min-width: 0;
      }

      .reading-door-kicker {
        display: inline-flex;
        margin-bottom: 16px;
        padding: 8px 14px;
        border: 1px solid rgba(202, 168, 79, 0.28);
        border-radius: 999px;
        color: #f2dd9a;
        background: rgba(202, 168, 79, 0.06);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
      }

      .reading-door-frame h1 {
        margin: 0 0 14px;
        color: #fff0bf;
        font-size: clamp(2rem, 5vw, 3rem);
      }

      .reading-door-lead,
      .reading-door-note,
      .reading-door-panel p {
        color: rgba(255, 236, 179, 0.78);
        line-height: 1.9;
        overflow-wrap: anywhere;
        word-break: break-all;
      }

      .reading-door-lead {
        margin: 0 0 26px;
      }

      .reading-door-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin: 24px 0;
      }

      .reading-door-panel {
        box-sizing: border-box;
        min-width: 0;
        padding: 20px;
        border: 1px solid rgba(255, 236, 179, 0.12);
        border-radius: 18px;
        background: rgba(5, 7, 20, 0.42);
      }

      .reading-door-panel h2 {
        margin: 0 0 10px;
        color: #fff0bf;
        font-size: 1.1rem;
      }

      .reading-door-panel p,
      .reading-door-note {
        margin: 0;
      }

      .reading-door-note {
        padding-top: 18px;
        border-top: 1px solid rgba(202, 168, 79, 0.18);
      }

      .reading-input-shell {
        box-sizing: border-box;
        min-width: 0;
        margin: 28px 0;
        padding: clamp(20px, 4vw, 28px);
        border: 1px solid rgba(214, 174, 64, 0.22);
        border-radius: 24px;
        background:
          radial-gradient(circle at 88% 12%, rgba(214, 174, 64, 0.12), transparent 26%),
          rgba(5, 7, 20, 0.68);
      }

      .reading-input-head {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
        color: rgba(255, 236, 179, 0.72);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
      }

      .reading-input-head strong {
        color: #fff0bf;
        font-size: 1rem;
        letter-spacing: 0;
      }

      .reading-input-message {
        margin: 0;
        color: rgba(255, 236, 179, 0.78);
        line-height: 1.85;
      }

      .reading-preparing-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 20px;
      }

      @media (max-width: 820px) {
        .reading-light-bg {
          background-image:
            linear-gradient(rgba(7, 5, 17, 0.3), rgba(7, 5, 17, 0.82)),
            url("/images/backgrounds/reading/mobile/reading-light-mobile-01.webp");
          background-size: cover;
          background-position: center center;
          background-repeat: no-repeat;
        }

        .reading-door-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .reading-door-shell {
          padding: 28px 0 64px;
        }

        .reading-door-frame {
          width: 100%;
          max-width: 360px;
          box-sizing: border-box;
          padding: 22px 18px;
          border-radius: 24px;
        }

        .reading-door-lead br,
        .reading-door-note br,
        .reading-input-message br {
          display: none;
        }

        .reading-door-panel {
          padding: 18px;
        }

        .reading-preparing-actions .fortune-btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </body>
</html>
