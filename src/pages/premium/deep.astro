---
import "../../styles/global.css";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>深掘り鑑定 | 白音七</title>
    <meta
      name="description"
      content="白音七の深掘り鑑定案内ページです。現在は生成処理や料金発生には接続していません。"
    />
  </head>

  <body class="fortune-body reading-deep-body">
    <div class="reading-deep-bg" aria-hidden="true"></div>

    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav">
          <a href="/">TOP</a>
          <a href="/members">会員ページ</a>
          <a href="/premium">会員限定鑑定</a>
          <a href="/history">履歴一覧</a>
        </nav>
      </div>
    </header>

    <main class="fortune-premium-page reading-door-page">
      <section class="fortune-container reading-door-shell">
        <article class="fortune-premium-page-frame reading-door-frame reading-door-frame--deep">
          <div class="reading-door-kicker">DEEP READING</div>
          <h1>深掘り鑑定</h1>

          <p class="reading-door-lead">
            今の状況、心の奥にあるテーマ、<br />
            これから選ぶ道を、時間をかけて読み解きます。<br /><br />
            人生の節目や、大きな迷いがある時のための鑑定です。
          </p>

          <div class="reading-door-grid" aria-label="深掘り鑑定の案内">
            <section class="reading-door-panel">
              <h2>使える想定</h2>
              <p>
                premium会員で、新しく深掘り鑑定を作れる想定です。
                premiumはdeep固定ではなく、ライト鑑定も選べます。
              </p>
            </section>

            <section class="reading-door-panel">
              <h2>このページの役割</h2>
              <p>
                現時点では案内ページです。
                URLを直接開いても、本番の深掘り生成は始まりません。
              </p>
            </section>

            <section class="reading-door-panel">
              <h2>これから整えること</h2>
              <p>
                将来はAPI側で token と membershipTier を確認してから、
                深掘り鑑定の生成へ進む形にします。
              </p>
            </section>
          </div>

          <section class="reading-input-shell" aria-label="深掘り鑑定の入力">
            <div class="reading-input-head">
              <span>READING PLAN</span>
              <strong>deep</strong>
            </div>

            <form id="deepReadingForm" class="reading-form" data-reading-plan="deep">
              <label>
                <span>お名前</span>
                <input type="text" name="name" autocomplete="name" placeholder="例: 白音 七" />
              </label>

              <label>
                <span>生年月日</span>
                <input type="date" name="birthDate" />
              </label>

              <label class="reading-form__wide">
                <span>相談したいこと / 今気になっていること</span>
                <textarea
                  name="question"
                  rows="5"
                  placeholder="今の状況や、心に残っている迷いをそのまま書いてください"
                ></textarea>
              </label>

              <label class="reading-form__wide">
                <span>詳しく見てほしいテーマ</span>
                <textarea
                  name="focusTheme"
                  rows="4"
                  placeholder="仕事、関係性、これからの選択など、特に深く見たいテーマがあれば書いてください"
                ></textarea>
              </label>

              <p id="deepReadingMessage" class="reading-input-message" aria-live="polite">
                現在は入力ページの準備段階です。<br />
                この画面から本番の深掘り鑑定はまだ生成されません。
              </p>

              <button class="fortune-btn violet" type="submit">鑑定を準備する</button>
            </form>
          </section>

          <p class="reading-door-note">
            一度届けた鑑定本文は、その人のものです。<br />
            会員ランクが変わっても、本人の履歴であれば見返せる設計にします。
          </p>

          <div class="reading-door-actions">
            <a href="/premium" class="fortune-btn violet">会員限定鑑定へ戻る</a>
            <a href="/members" class="fortune-btn secondary">会員ページへ</a>
          </div>
        </article>
      </section>
    </main>

    <script>
      const readingPlan = "deep";
      const form = document.getElementById("deepReadingForm");
      const message = document.getElementById("deepReadingMessage");

      form?.addEventListener("submit", (event) => {
        event.preventDefault();

        if (message) {
        message.innerHTML = `
          この鑑定は現在準備中です。<br />
          正式な生成処理は、次の工程で接続されます。
        `;
      }
      });
    </script>

    <style>
      :global(body.reading-deep-body) {
        overflow-x: hidden;
        background-color: #050412;
      }

      .reading-deep-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(5, 4, 18, 0.42), rgba(5, 4, 18, 0.76)),
          url("/images/backgrounds/reading/mobile/reading-deep-mobile-01.webp");
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
      }

      :global(body.reading-deep-body .fortune-header),
      .reading-door-shell {
        position: relative;
        z-index: 1;
      }

      .reading-door-shell {
        padding: 48px 0 88px;
      }

      .reading-door-frame {
        padding: clamp(28px, 5vw, 46px);
      }

      .reading-door-frame--deep {
        position: relative;
        overflow: hidden;
        background:
          radial-gradient(circle at 88% 18%, rgba(177, 124, 255, 0.18), transparent 30%),
          linear-gradient(180deg, rgba(10, 14, 34, 0.9), rgba(16, 11, 40, 0.86));
      }

      .reading-door-frame--deep::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at 16% 10%, rgba(255, 226, 155, 0.12), transparent 22%),
          radial-gradient(circle at 88% 30%, rgba(177, 124, 255, 0.13), transparent 28%);
      }

      .reading-door-frame--deep > * {
        position: relative;
        z-index: 1;
      }

      .reading-door-kicker {
        display: inline-flex;
        margin-bottom: 16px;
        padding: 8px 14px;
        border: 1px solid rgba(182, 140, 255, 0.34);
        border-radius: 999px;
        color: #d9c2ff;
        background: rgba(177, 124, 255, 0.07);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
      }

      .reading-door-frame h1 {
        margin: 0 0 14px;
        color: #fff0bf;
        font-size: clamp(2rem, 5vw, 3rem);
      }

      .reading-door-lead,
      .reading-door-note,
      .reading-door-panel p {
        color: rgba(255, 236, 179, 0.78);
        line-height: 1.9;
      }

      .reading-door-lead {
        margin: 0 0 26px;
      }

      .reading-door-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin: 24px 0;
      }

      .reading-door-panel {
        padding: 20px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.035);
      }

      .reading-door-panel h2 {
        margin: 0 0 10px;
        color: #fff0bf;
        font-size: 1.1rem;
      }

      .reading-door-panel p,
      .reading-door-note {
        margin: 0;
      }

      .reading-door-note {
        padding-top: 18px;
        border-top: 1px solid rgba(202, 168, 79, 0.18);
      }

      .reading-input-shell {
        margin: 28px 0;
        padding: clamp(20px, 4vw, 28px);
        border: 1px solid rgba(177, 124, 255, 0.24);
        border-radius: 24px;
        background:
          radial-gradient(circle at 88% 12%, rgba(177, 124, 255, 0.14), transparent 28%),
          rgba(5, 7, 20, 0.62);
      }

      .reading-input-head {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
        color: rgba(255, 236, 179, 0.72);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
      }

      .reading-input-head strong {
        color: #fff0bf;
        font-size: 1rem;
        letter-spacing: 0;
      }

      .reading-form {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .reading-form label,
      .reading-form label span {
        display: block;
      }

      .reading-form label span {
        margin-bottom: 8px;
        color: #fff0bf;
        font-weight: 700;
      }

      .reading-form input,
      .reading-form textarea {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 16px;
        padding: 13px 14px;
        color: #fff8df;
        background: rgba(5, 8, 20, 0.52);
        font: inherit;
      }

      .reading-form textarea {
        resize: vertical;
      }

      .reading-form__wide,
      .reading-input-message,
      .reading-form .fortune-btn {
        grid-column: 1 / -1;
      }

      .reading-input-message {
        margin: 2px 0 0;
        color: rgba(255, 236, 179, 0.78);
        line-height: 1.85;
      }

      .reading-door-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 26px;
      }

      @media (max-width: 820px) {
        .reading-deep-bg {
          background-image:
            linear-gradient(rgba(5, 4, 18, 0.38), rgba(5, 4, 18, 0.78)),
            url("/images/backgrounds/reading/mobile/reading-deep-mobile-01.webp");
          background-size: cover;
          background-position: center center;
          background-repeat: no-repeat;
        }

        .reading-door-grid {
          grid-template-columns: 1fr;
        }

        .reading-form {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
