---
export const prerender = false;

import "../../styles/global.css";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>音声鑑定の準備中 | 白音七</title>
    <meta
      name="description"
      content="白音七の音声鑑定受付は現在準備中です。正式なご案内までお待ちください。"
    />
  </head>

  <body class="fortune-body voice-processing-body">
    <div class="voice-processing-bg" aria-hidden="true"></div>

    <header class="fortune-header">
      <div class="fortune-container fortune-header-inner">
        <a href="/" class="fortune-logo">
          <span class="fortune-logo-mark"></span>
          <span>白音七</span>
        </a>

        <button
          class="fortune-mobile-menu-button"
          type="button"
          aria-label="メニューを開く"
          aria-expanded="false"
          onclick="const nav=this.parentElement.querySelector('.fortune-nav'); const open=!nav.classList.contains('is-open'); nav.classList.toggle('is-open', open); this.setAttribute('aria-expanded', String(open)); this.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="fortune-nav">
          <a href="/">TOP</a>
          <a href="/members">会員ページ</a>
          <a href="/premium">会員限定鑑定</a>
          <a href="/history">履歴一覧</a>
        </nav>
      </div>
    </header>

    <main class="fortune-premium-page voice-processing-page">
      <section class="fortune-container voice-processing-shell">
        <article class="fortune-premium-page-frame voice-processing-frame">
          <div class="voice-processing-kicker">VOICE READING</div>
          <h1>音声鑑定 準備中</h1>

          <p class="voice-processing-lead">
            音声鑑定の受付は、現在準備中です。<br />
            準備が整いましたら、履歴から音声で受け取れる形をご案内します。
          </p>

          <section class="voice-processing-notice" aria-label="音声鑑定の受付案内">
            <h2>正式なご案内まで、今しばらくお待ちください。</h2>
            <p>
              この画面で音声の解析状況を確認したり、音声を新しく作成したりすることはありません。<br />
              料金が発生することもありません。
            </p>

            <div class="voice-processing-actions">
              <a href="/premium/voice" class="fortune-btn violet">音声鑑定へ戻る</a>
              <a href="/history" class="fortune-btn secondary">履歴を見る</a>
              <a href="/premium" class="fortune-btn secondary">会員限定鑑定へ戻る</a>
            </div>
          </section>
        </article>
      </section>
    </main>

    <style>
      :global(body.voice-processing-body) {
        overflow-x: hidden;
        background-color: #070511;
      }

      .voice-processing-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          linear-gradient(rgba(7, 5, 17, 0.38), rgba(7, 5, 17, 0.82)),
          radial-gradient(circle at 18% 12%, rgba(255, 232, 164, 0.13), transparent 28%),
          radial-gradient(circle at 78% 24%, rgba(177, 124, 255, 0.16), transparent 30%),
          url("/images/backgrounds/reading/mobile/reading-deep-mobile-01.webp");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
      }

      :global(body.voice-processing-body .fortune-header),
      .voice-processing-shell {
        position: relative;
        z-index: 1;
      }

      .voice-processing-shell {
        padding: 52px 0 92px;
      }

      .voice-processing-frame {
        position: relative;
        overflow: hidden;
        padding: clamp(28px, 5vw, 52px);
        background:
          radial-gradient(circle at 82% 18%, rgba(177, 124, 255, 0.18), transparent 32%),
          linear-gradient(180deg, rgba(10, 14, 34, 0.9), rgba(21, 13, 44, 0.86));
        box-shadow:
          0 22px 74px rgba(0, 0, 0, 0.42),
          inset 0 0 0 1px rgba(216, 196, 255, 0.04);
      }

      .voice-processing-frame::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at 16% 10%, rgba(255, 226, 155, 0.12), transparent 24%),
          radial-gradient(circle at 88% 32%, rgba(177, 124, 255, 0.13), transparent 28%);
      }

      .voice-processing-frame > * {
        position: relative;
        z-index: 1;
        min-width: 0;
      }

      .voice-processing-kicker {
        display: inline-flex;
        margin-bottom: 16px;
        padding: 8px 14px;
        border: 1px solid rgba(182, 140, 255, 0.34);
        border-radius: 999px;
        color: #d9c2ff;
        background: rgba(177, 124, 255, 0.07);
        font-size: 0.82rem;
        letter-spacing: 0.08em;
      }

      .voice-processing-frame h1 {
        margin: 0 0 14px;
        color: #fff0bf;
        font-size: clamp(2rem, 5vw, 3rem);
      }

      .voice-processing-lead,
      .voice-processing-notice p {
        color: rgba(255, 236, 179, 0.78);
        line-height: 1.9;
        overflow-wrap: anywhere;
        word-break: break-all;
      }

      .voice-processing-lead {
        margin: 0 0 28px;
      }

      .voice-processing-notice {
        box-sizing: border-box;
        min-width: 0;
        padding: clamp(20px, 4vw, 30px);
        border: 1px solid rgba(216, 196, 255, 0.16);
        border-radius: 24px;
        background:
          radial-gradient(circle at 90% 14%, rgba(177, 124, 255, 0.12), transparent 28%),
          rgba(5, 7, 20, 0.66);
      }

      .voice-processing-notice h2 {
        margin: 0 0 12px;
        color: #fff0bf;
        font-size: clamp(1.2rem, 3vw, 1.55rem);
        overflow-wrap: anywhere;
        word-break: break-all;
      }

      .voice-processing-notice p {
        margin: 0;
      }

      .voice-processing-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 22px;
      }

      @media (max-width: 640px) {
        .voice-processing-shell {
          padding: 30px 0 68px;
        }

        .voice-processing-frame {
          width: 100%;
          max-width: 360px;
          box-sizing: border-box;
          padding: 22px 18px;
          border-radius: 24px;
        }

        .voice-processing-lead br,
        .voice-processing-notice br {
          display: none;
        }

        .voice-processing-actions .fortune-btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </body>
</html>
