---
import "../../styles/global.css";
export const prerender = false;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>音声鑑定を解析中 | 白音七</title>
    <style>
      .voice-waiting-card {
        position: relative;
        overflow: hidden;
        display: grid;
        gap: 18px;
        justify-items: center;
        margin: 26px 0;
        padding: clamp(28px, 6vw, 44px) 22px;
        border: 1px solid rgba(214, 174, 64, 0.26);
        border-radius: 28px;
        background:
          radial-gradient(circle at 50% 30%, rgba(214, 174, 64, 0.1), transparent 34%),
          radial-gradient(circle at 18% 20%, rgba(177, 124, 255, 0.12), transparent 30%),
          rgba(255, 255, 255, 0.035);
        text-align: center;
      }

      .voice-waiting-orbit {
        position: relative;
        width: min(48vw, 156px);
        aspect-ratio: 1;
        display: grid;
        place-items: center;
      }

      .voice-waiting-orbit::before,
      .voice-waiting-orbit::after {
        content: "";
        position: absolute;
        inset: 10%;
        border: 1px solid rgba(255, 236, 179, 0.2);
        border-radius: 999px;
        animation: moonBreath 4.8s ease-in-out infinite;
      }

      .voice-waiting-orbit::after {
        inset: 25%;
        border-color: rgba(177, 124, 255, 0.2);
        animation-delay: 1.1s;
      }

      .voice-waiting-moon {
        position: relative;
        width: 54px;
        height: 54px;
        border-radius: 999px;
        border: 1px solid rgba(255, 236, 179, 0.34);
        box-shadow:
          inset 12px -8px 0 rgba(255, 236, 179, 0.09),
          0 0 28px rgba(214, 174, 64, 0.18);
        animation: moonFloat 5.6s ease-in-out infinite;
      }

      .voice-waiting-star {
        position: absolute;
        color: rgba(255, 236, 179, 0.72);
        font-size: 0.82rem;
        line-height: 1;
        animation: starBlink 4.6s ease-in-out infinite;
      }

      .voice-waiting-star:nth-child(2) {
        top: 18%;
        right: 18%;
      }

      .voice-waiting-star:nth-child(3) {
        bottom: 20%;
        left: 16%;
        animation-delay: 1.2s;
      }

      .voice-waiting-star:nth-child(4) {
        top: 30%;
        left: 22%;
        animation-delay: 2s;
      }

      .voice-waiting-copy h2 {
        margin: 0 0 12px;
        color: #fff0bf;
        font-size: clamp(1.45rem, 4vw, 2rem);
        letter-spacing: 0.04em;
      }

      .voice-waiting-copy p {
        margin: 0;
        color: rgba(255, 236, 179, 0.78);
        line-height: 1.9;
      }

      .voice-waiting-stage {
        min-height: 3.8em;
      }

      .voice-ready-panel {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 12px;
        justify-items: center;
        margin-top: 2px;
        padding-top: 18px;
        border-top: 1px solid rgba(214, 174, 64, 0.18);
      }

      .voice-ready-panel[hidden] {
        display: none;
      }

      .voice-ready-panel p {
        margin: 0;
        color: #fff0bf;
        font-weight: 700;
        line-height: 1.7;
      }

      .voice-waiting-ripples {
        position: absolute;
        inset: auto 12% 14px;
        height: 24px;
        display: flex;
        justify-content: center;
        gap: 10px;
        opacity: 0.42;
        pointer-events: none;
      }

      .voice-waiting-ripples span {
        width: 42px;
        height: 10px;
        border: 1px solid rgba(255, 236, 179, 0.22);
        border-radius: 999px;
        animation: soundRipple 4.8s ease-in-out infinite;
      }

      .voice-waiting-ripples span:nth-child(2) {
        animation-delay: 0.55s;
      }

      .voice-waiting-ripples span:nth-child(3) {
        animation-delay: 1.1s;
      }

      @keyframes moonBreath {
        0%, 100% {
          transform: scale(0.96);
          opacity: 0.35;
        }
        50% {
          transform: scale(1.08);
          opacity: 0.72;
        }
      }

      @keyframes moonFloat {
        0%, 100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-6px);
        }
      }

      @keyframes starBlink {
        0%, 100% {
          opacity: 0.28;
          transform: scale(0.9);
        }
        50% {
          opacity: 0.9;
          transform: scale(1.08);
        }
      }

      @keyframes soundRipple {
        0%, 100% {
          transform: scaleX(0.72);
          opacity: 0.18;
        }
        50% {
          transform: scaleX(1.18);
          opacity: 0.6;
        }
      }

      @media (max-width: 640px) {
        .voice-waiting-card {
          margin: 22px 0;
          border-radius: 22px;
        }

        .voice-waiting-orbit {
          width: min(58vw, 132px);
        }

        .voice-waiting-ripples {
          gap: 6px;
        }

        .voice-waiting-ripples span {
          width: 32px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .voice-waiting-orbit::before,
        .voice-waiting-orbit::after,
        .voice-waiting-moon,
        .voice-waiting-star,
        .voice-waiting-ripples span {
          animation: none;
        }
      }
    </style>
  </head>

  <body class="fortune-body">
    <main class="fortune-session-page">
      <section class="fortune-container">
        <div class="fortune-session-frame">
          <div class="fortune-session-head">
            <div class="fortune-member-kicker">VOICE PROCESSING</div>
            <h1 class="fortune-session-title" id="sessionTitle">音声鑑定を解析中です</h1>
            <p class="fortune-session-lead" id="processingText">
              音声を受け付けました。文字起こしと鑑定生成を進めています。
            </p>
          </div>

          <section class="voice-waiting-card" aria-label="音声鑑定の待機案内">
            <div class="voice-waiting-orbit" aria-hidden="true">
              <div class="voice-waiting-moon"></div>
              <span class="voice-waiting-star">✦</span>
              <span class="voice-waiting-star">✧</span>
              <span class="voice-waiting-star">✦</span>
            </div>

            <div class="voice-waiting-copy">
              <h2 id="waitingMainText">声を読み解いています</h2>
              <p id="waitingStageText" class="voice-waiting-stage">
                声にした言葉を受け取っています
              </p>
              <p>
                結果が届くまで<br />
                少しだけ目を休めてお待ちください
              </p>
            </div>

            <div id="readyPanel" class="voice-ready-panel" hidden>
              <p>準備ができました</p>
              <button id="openResultButton" class="fortune-btn violet" type="button">そっと開く</button>
            </div>

            <div class="voice-waiting-ripples" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </section>

          <div class="fortune-card">
            <h2>現在の状態</h2>
            <p id="statusText">受付直後です。しばらくお待ちください。</p>
          </div>

          <div class="fortune-session-actions">
            <a href="/history" class="fortune-btn secondary">履歴一覧を見る</a>
            <a href="/premium/voice" class="fortune-btn violet">音声鑑定へ戻る</a>
          </div>
        </div>
      </section>
    </main>

    <script>
      const HISTORY_API_BASE = "https://mydmaywesh.execute-api.ap-northeast-1.amazonaws.com/prod";
      const token = localStorage.getItem("token");
      const params = new URLSearchParams(window.location.search);
      const historyId = params.get("history_id") || params.get("id") || "";
      const sessionTitle = document.getElementById("sessionTitle");
      const statusText = document.getElementById("statusText");
      const processingText = document.getElementById("processingText");
      const waitingMainText = document.getElementById("waitingMainText");
      const waitingStageText = document.getElementById("waitingStageText");
      const readyPanel = document.getElementById("readyPanel");
      const openResultButton = document.getElementById("openResultButton");
      const startedAt = Date.now();
      const MIN_WAIT_MS = 20000;
      let isCompleted = false;
      let isFailed = false;

      function getElapsedMs() {
        return Date.now() - startedAt;
      }

      function getResultUrl() {
        return `/history/${encodeURIComponent(historyId)}`;
      }

      function updateWaitingText() {
        if (!waitingStageText || isFailed) return;

        if (isCompleted && getElapsedMs() >= MIN_WAIT_MS) {
          waitingStageText.textContent = "あなたの鑑定が整いました";
          return;
        }

        const elapsed = getElapsedMs();
        if (elapsed < 7000) {
          waitingStageText.textContent = "声にした言葉を受け取っています";
        } else if (elapsed < 14000) {
          waitingStageText.innerHTML = "あなたの相談を<br />静かに読み解いています";
        } else {
          waitingStageText.innerHTML = "今日のあなたに届くよう<br />言葉の温度を整えています";
        }
      }

      function showReadyIfPossible() {
        if (!isCompleted || getElapsedMs() < MIN_WAIT_MS || !readyPanel) return;

        readyPanel.hidden = false;
        sessionTitle.textContent = "音声鑑定が整いました";
        waitingMainText.textContent = "鑑定が整いました";
        waitingStageText.innerHTML = "声にした言葉を<br />今日のあなたへ届ける準備ができました";
        processingText.textContent = "あなたの鑑定が整いました。";
        statusText.textContent = "「そっと開く」から、鑑定結果を開封できます。";
      }

      openResultButton?.addEventListener("click", () => {
        if (!historyId) return;
        window.location.href = getResultUrl();
      });

      async function pollStatus() {
        if (!token) {
          statusText.textContent = "ログインしてください。";
          return;
        }

        if (!historyId) {
          statusText.textContent =
            "鑑定の受付情報を確認できませんでした。もう一度、音声鑑定ページからお試しください。";
          return;
        }

        try {
          const response = await fetch(
            `${HISTORY_API_BASE}/history/detail?history_id=${encodeURIComponent(historyId)}`,
            {
              method: "GET",
              headers: {
                Authorization: `Bearer ${token}`
              }
            }
          );

          if (!response.ok) {
            statusText.textContent = "解析状況を確認中です。";
            return;
          }

          const data = await response.json();
          const status = data?.status || data?.item?.status || "";

          if (!status) {
            statusText.textContent = "解析状況を確認中です。";
            return;
          }

          if (status === "completed" || data?.result || data?.item?.result_s3_key) {
            isCompleted = true;
            statusText.textContent =
              getElapsedMs() >= MIN_WAIT_MS
                ? "「そっと開く」から、鑑定結果を開封できます。"
                : "鑑定が整いつつあります。もう少しだけ、このままお待ちください。";
            showReadyIfPossible();
            return;
          }

          if (status === "failed") {
            isFailed = true;
            processingText.textContent = "鑑定を整えきれませんでした。履歴一覧から状態をご確認ください。";
            statusText.textContent = "必要でしたら、音声鑑定からもう一度お試しください。";
            return;
          }

          statusText.textContent = "鑑定を整えています。";
        } catch (error) {
          console.error(error);
          statusText.textContent = "解析状況を確認中です。";
        }
      }

      updateWaitingText();
      setInterval(() => {
        updateWaitingText();
        showReadyIfPossible();
      }, 1000);
      pollStatus();
      setInterval(pollStatus, 5000);
    </script>
  </body>
</html>
