{
  "name": "nana-fortune",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:reading-server": "node scripts/build-reading-engine.mjs",
    "build:reading-foundation": "node scripts/build-reading-foundation.mjs",
    "build:reading-api-handler": "node scripts/build-reading-api-handler.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:reading-server": "node --test tests/shironeEngineServerParity.test.mjs",
    "test:reading-foundation": "node --test tests/readingServerFoundation.test.mjs",
    "test:reading-preparation": "node --test tests/readingRequestPreparation.test.mjs",
    "test:reading-bedrock": "node --test tests/readingBedrockRenderer.test.mjs",
    "test:reading-api-handler": "node --test tests/readingApiHandler.test.mjs",
    "test:reading-bedrock-smoke": "npm run build:reading-server && npm run build:reading-foundation && node scripts/smoke-reading-bedrock.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@aws-sdk/client-bedrock-runtime": "3.1089.0",
    "@aws-sdk/client-dynamodb": "3.1089.0",
    "astro": "^6.4.8",
    "sharp": "^0.34.3"
  }
}
